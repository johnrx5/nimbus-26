---
import Layout from '../layouts/Layout.astro';
import logoWhite from '../assets/NB_br_Logo White/NB_br_Logo White_0325.png';
import logoBlack from '../assets/NB_br_Logo Black/NB_br_Logo Black_0325.png';
---

<Layout title="Nimbus Healthcare - Provider Intake">
  <main>
    <section class="bg-[#1A1816] h-screen flex flex-col overflow-hidden" id="intake-app">
      <!-- Progress Bar -->
      <div class="w-full h-[3px] bg-cream/5 intake-progress-track shrink-0">
        <div class="h-full bg-teal transition-all duration-500 ease-out" id="progress-bar" style="width: 10%"></div>
      </div>

      <!-- Sticky Top Bar -->
      <div class="px-6 shrink-0 intake-sticky-header">
        <div class="max-w-[620px] mx-auto relative flex items-center justify-between py-5">
          <!-- Left: Back -->
          <div class="flex items-center gap-3">
            <button
              id="intake-back"
              class="w-10 h-10 rounded-full border border-cream/15 flex items-center justify-center text-cream/50 hover:text-cream hover:border-cream/30 transition-colors cursor-pointer intake-back-btn"
              aria-label="Go back"
            >
              <svg width="18" height="18" viewBox="0 0 18 18" fill="none">
                <path d="M11 4L6 9l5 5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </button>
            <span class="font-montserrat text-cream/50 text-xs font-semibold tracking-[0.15em] uppercase intake-muted" id="intake-phase">Back</span>
          </div>

          <!-- Center: Logo -->
          <div class="absolute left-1/2 -translate-x-1/2">
            <img src={logoWhite.src} alt="Nimbus Healthcare" class="h-[30px]" id="logo-white" />
            <img src={logoBlack.src} alt="Nimbus Healthcare" class="h-[30px] hidden" id="logo-black" />
          </div>

          <!-- Right: Counter + Theme -->
          <div class="flex items-center gap-4">
            <span class="font-inter text-cream/40 text-sm intake-muted" id="intake-counter">10%</span>
            <button
              id="theme-toggle"
              class="w-10 h-10 rounded-full border border-cream/15 flex items-center justify-center text-cream/50 hover:text-cream hover:border-cream/30 transition-colors cursor-pointer intake-back-btn"
              aria-label="Toggle light mode"
            >
              <svg id="icon-sun" width="18" height="18" viewBox="0 0 18 18" fill="none">
                <circle cx="9" cy="9" r="3.5" stroke="currentColor" stroke-width="1.3"/>
                <path d="M9 2v1.5M9 14.5V16M2 9h1.5M14.5 9H16M4.05 4.05l1.06 1.06M12.89 12.89l1.06 1.06M4.05 13.95l1.06-1.06M12.89 5.11l1.06-1.06" stroke="currentColor" stroke-width="1.3" stroke-linecap="round"/>
              </svg>
              <svg id="icon-moon" width="18" height="18" viewBox="0 0 18 18" fill="none" class="hidden">
                <path d="M15.36 10.68A6.5 6.5 0 017.32 2.64a7.5 7.5 0 108.04 8.04z" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </button>
          </div>
        </div>
      </div>

      <!-- Scrollable Content -->
      <div class="flex-1 overflow-y-auto px-6 pb-8" id="intake-content">
        <div class="max-w-[620px] mx-auto">

          <!-- ========== STEP 1: Welcome / Clinical Setup ========== -->
          <!-- Step 1: Active -->
          <div id="step-1-active" class="mt-4">
            <p class="font-montserrat text-teal text-xs font-semibold tracking-[0.15em] uppercase mb-2 intake-label">Clinic Onboarding</p>
            <h1 class="font-fraunces text-cream text-[clamp(28px,4vw,40px)] leading-[1.15] tracking-[-0.02em] mb-4 intake-heading">
              Welcome — let's get your clinic set up with Nimbus
            </h1>
            <p class="font-inter text-cream/50 text-base leading-[1.6] mb-5 intake-body">
              We'll walk you through everything step by step. This should take about 10 minutes. Here's what to expect:
            </p>

            <div class="rounded-2xl border border-cream/10 bg-cream/[0.03] px-5 py-5 mb-8">
              <ol class="space-y-3">
                <li class="font-inter text-cream/60 text-sm flex items-start gap-3 intake-body">
                  <span class="text-teal font-semibold shrink-0">1.</span>
                  Enter clinic and admin information
                </li>
                <li class="font-inter text-cream/60 text-sm flex items-start gap-3 intake-body">
                  <span class="text-teal font-semibold shrink-0">2.</span>
                  Acknowledge the program agreement
                </li>
                <li class="font-inter text-cream/60 text-sm flex items-start gap-3 intake-body">
                  <span class="text-teal font-semibold shrink-0">3.</span>
                  Add a payment method
                </li>
                <li class="font-inter text-cream/60 text-sm flex items-start gap-3 intake-body">
                  <span class="text-teal font-semibold shrink-0">4.</span>
                  Set up payment receiving
                </li>
                <li class="font-inter text-cream/60 text-sm flex items-start gap-3 intake-body">
                  <span class="text-teal font-semibold shrink-0">5.</span>
                  You're all set
                </li>
              </ol>
            </div>

            <p class="font-inter text-cream font-semibold text-base intake-bold mb-5">
              First — how does your clinic handle prescribing?
            </p>

            <div class="flex flex-col gap-4" id="clinical-setup-options">
              <button class="option-btn" data-value="direct">Yes — we have in-house prescribers</button>
              <button class="option-btn" data-value="guided">No — we'd like Nimbus to provide clinical oversight</button>
              <button class="option-btn" data-value="hybrid">Both — we use a hybrid model</button>
            </div>
          </div>

          <!-- Step 1: Collapsed -->
          <div id="step-1-collapsed" class="hidden">
            <div class="flex items-center justify-between py-2">
              <div>
                <p class="font-montserrat text-teal text-[10px] font-semibold tracking-[0.15em] uppercase mb-1 intake-label">Clinic Onboarding</p>
                <p class="font-inter text-cream/50 text-sm intake-body">Welcome — let's get your clinic set up</p>
              </div>
              <button class="edit-step-btn flex items-center gap-2 border border-cream/15 rounded-full px-4 py-2 text-cream text-sm font-inter font-medium hover:border-cream/30 transition-colors cursor-pointer intake-back-btn intake-heading" data-edit-step="1">
                <span id="step-1-answer">—</span>
                <svg width="14" height="14" viewBox="0 0 14 14" fill="none">
                  <path d="M10.08 1.92a1.5 1.5 0 012.12 0l.38.38a1.5 1.5 0 010 2.12L5.5 11.5 2 12.5l1-3.5 7.08-7.08z" stroke="currentColor" stroke-width="1.1" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </button>
            </div>
            <div class="border-t border-cream/10 mt-4 intake-border"></div>
          </div>

          <!-- ========== STEP 2: Clinic Information ========== -->
          <div id="step-2-active" class="hidden mt-8">
            <p class="font-montserrat text-teal text-xs font-semibold tracking-[0.15em] uppercase mb-2 intake-label">Clinic Info</p>
            <h2 class="font-fraunces text-cream text-[clamp(28px,4vw,40px)] leading-[1.15] tracking-[-0.02em] mb-4 intake-heading">
              Tell us about your clinic
            </h2>
            <p class="font-inter text-cream/50 text-base leading-[1.6] mb-10 intake-body">
              Basic details so we can set up your account.
            </p>

            <!-- Clinic Name -->
            <div class="mb-6">
              <label class="font-inter text-cream font-semibold text-base block mb-3 intake-bold">Clinic Name <span class="text-red-400 text-sm">*</span></label>
              <input type="text" id="clinic-name" placeholder="Enter clinic name" class="w-full bg-transparent border border-cream/15 rounded-2xl px-5 py-4 font-inter text-cream text-base placeholder:text-cream/25 focus:outline-none focus:border-cream/40 transition-colors intake-input">
            </div>

            <!-- NPI -->
            <div class="mb-6">
              <label class="font-inter text-cream font-semibold text-base block mb-3 intake-bold">NPI</label>
              <div class="flex gap-3">
                <input type="text" id="clinic-npi" placeholder="NPI (optional)" class="flex-1 bg-transparent border border-cream/15 rounded-2xl px-5 py-4 font-inter text-cream text-base placeholder:text-cream/25 focus:outline-none focus:border-cream/40 transition-colors intake-input">
                <button class="flex items-center gap-2 border border-teal/40 text-teal font-inter text-sm font-medium rounded-2xl px-5 py-4 hover:bg-teal/5 transition-colors cursor-pointer whitespace-nowrap" id="npi-lookup-btn">
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none">
                    <circle cx="11" cy="11" r="8" stroke="currentColor" stroke-width="2"/>
                    <path d="M21 21l-4.35-4.35" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
                  </svg>
                  Lookup
                </button>
              </div>
            </div>

            <!-- Clinic Description -->
            <div class="mb-8">
              <label class="font-inter text-cream font-semibold text-base block mb-3 intake-bold">Clinic Description <span class="text-red-400 text-sm">*</span></label>
              <textarea id="clinic-desc" placeholder="Describe your clinic, services, and specialties..." rows="4" class="w-full bg-transparent border border-cream/15 rounded-2xl px-5 py-4 font-inter text-cream text-base placeholder:text-cream/25 focus:outline-none focus:border-cream/40 transition-colors resize-vertical min-h-[100px] intake-input"></textarea>
            </div>

            <button id="step-2-continue" class="w-full bg-terracotta hover:brightness-110 text-cream font-montserrat font-medium text-base rounded-full px-10 py-4 transition-all cursor-pointer">
              Continue
            </button>
          </div>

          <!-- Step 2: Collapsed -->
          <div id="step-2-collapsed" class="hidden">
            <div class="flex items-center justify-between py-2">
              <div>
                <p class="font-montserrat text-teal text-[10px] font-semibold tracking-[0.15em] uppercase mb-1 intake-label">Clinic Info</p>
                <p class="font-inter text-cream/50 text-sm intake-body">Tell us about your clinic</p>
              </div>
              <button class="edit-step-btn flex items-center gap-2 border border-cream/15 rounded-full px-4 py-2 text-cream text-sm font-inter font-medium hover:border-cream/30 transition-colors cursor-pointer intake-back-btn intake-heading" data-edit-step="2">
                <span id="step-2-answer">—</span>
                <svg width="14" height="14" viewBox="0 0 14 14" fill="none">
                  <path d="M10.08 1.92a1.5 1.5 0 012.12 0l.38.38a1.5 1.5 0 010 2.12L5.5 11.5 2 12.5l1-3.5 7.08-7.08z" stroke="currentColor" stroke-width="1.1" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </button>
            </div>
            <div class="border-t border-cream/10 mt-4 intake-border"></div>
          </div>

          <!-- ========== STEP 3: Clinic Address ========== -->
          <div id="step-3-active" class="hidden mt-8">
            <p class="font-montserrat text-teal text-xs font-semibold tracking-[0.15em] uppercase mb-2 intake-label">Clinic Info</p>
            <h2 class="font-fraunces text-cream text-[clamp(28px,4vw,40px)] leading-[1.15] tracking-[-0.02em] mb-4 intake-heading">
              Where is your clinic located?
            </h2>
            <p class="font-inter text-cream/50 text-base leading-[1.6] mb-10 intake-body">
              We need your physical address for compliance and shipping.
            </p>

            <div class="flex flex-col gap-4 mb-8">
              <div>
                <label class="font-inter text-cream font-semibold text-base block mb-3 intake-bold">Address Line 1 <span class="text-red-400 text-sm">*</span></label>
                <input type="text" id="addr-line1" placeholder="Street address" class="w-full bg-transparent border border-cream/15 rounded-2xl px-5 py-4 font-inter text-cream text-base placeholder:text-cream/25 focus:outline-none focus:border-cream/40 transition-colors intake-input">
              </div>

              <div>
                <label class="font-inter text-cream font-semibold text-base block mb-3 intake-bold">Address Line 2</label>
                <input type="text" id="addr-line2" placeholder="Building, floor, suite (optional)" class="w-full bg-transparent border border-cream/15 rounded-2xl px-5 py-4 font-inter text-cream text-base placeholder:text-cream/25 focus:outline-none focus:border-cream/40 transition-colors intake-input">
              </div>

              <div class="grid grid-cols-3 gap-3">
                <div>
                  <label class="font-inter text-cream font-semibold text-base block mb-3 intake-bold">City <span class="text-red-400 text-sm">*</span></label>
                  <input type="text" id="addr-city" placeholder="City" class="w-full bg-transparent border border-cream/15 rounded-2xl px-5 py-4 font-inter text-cream text-base placeholder:text-cream/25 focus:outline-none focus:border-cream/40 transition-colors intake-input">
                </div>

                <div>
                  <label class="font-inter text-cream font-semibold text-base block mb-3 intake-bold">State <span class="text-red-400 text-sm">*</span></label>
                  <select id="addr-state" class="w-full bg-transparent border border-cream/15 rounded-2xl px-5 py-4 font-inter text-cream text-base focus:outline-none focus:border-cream/40 transition-colors intake-input provider-select">
                    <option value="" disabled selected>State</option>
                    <option>Alabama</option><option>Alaska</option><option>Arizona</option><option>Arkansas</option>
                    <option>California</option><option>Colorado</option><option>Connecticut</option><option>Delaware</option>
                    <option>Florida</option><option>Georgia</option><option>Hawaii</option><option>Idaho</option>
                    <option>Illinois</option><option>Indiana</option><option>Iowa</option><option>Kansas</option>
                    <option>Kentucky</option><option>Louisiana</option><option>Maine</option><option>Maryland</option>
                    <option>Massachusetts</option><option>Michigan</option><option>Minnesota</option><option>Mississippi</option>
                    <option>Missouri</option><option>Montana</option><option>Nebraska</option><option>Nevada</option>
                    <option>New Hampshire</option><option>New Jersey</option><option>New Mexico</option><option>New York</option>
                    <option>North Carolina</option><option>North Dakota</option><option>Ohio</option><option>Oklahoma</option>
                    <option>Oregon</option><option>Pennsylvania</option><option>Rhode Island</option><option>South Carolina</option>
                    <option>South Dakota</option><option>Tennessee</option><option>Texas</option><option>Utah</option>
                    <option>Vermont</option><option>Virginia</option><option>Washington</option><option>West Virginia</option>
                    <option>Wisconsin</option><option>Wyoming</option>
                  </select>
                </div>

                <div>
                  <label class="font-inter text-cream font-semibold text-base block mb-3 intake-bold">ZIP <span class="text-red-400 text-sm">*</span></label>
                  <input type="text" id="addr-zip" placeholder="ZIP" inputmode="numeric" maxlength="10" class="w-full bg-transparent border border-cream/15 rounded-2xl px-5 py-4 font-inter text-cream text-base placeholder:text-cream/25 focus:outline-none focus:border-cream/40 transition-colors intake-input">
                </div>
              </div>
            </div>

            <button id="step-3-continue" class="w-full bg-terracotta hover:brightness-110 text-cream font-montserrat font-medium text-base rounded-full px-10 py-4 transition-all cursor-pointer">
              Continue
            </button>
          </div>

          <!-- Step 3: Collapsed -->
          <div id="step-3-collapsed" class="hidden">
            <div class="flex items-center justify-between py-2">
              <div>
                <p class="font-montserrat text-teal text-[10px] font-semibold tracking-[0.15em] uppercase mb-1 intake-label">Clinic Info</p>
                <p class="font-inter text-cream/50 text-sm intake-body">Where is your clinic located?</p>
              </div>
              <button class="edit-step-btn flex items-center gap-2 border border-cream/15 rounded-full px-4 py-2 text-cream text-sm font-inter font-medium hover:border-cream/30 transition-colors cursor-pointer intake-back-btn intake-heading" data-edit-step="3">
                <span id="step-3-answer">—</span>
                <svg width="14" height="14" viewBox="0 0 14 14" fill="none">
                  <path d="M10.08 1.92a1.5 1.5 0 012.12 0l.38.38a1.5 1.5 0 010 2.12L5.5 11.5 2 12.5l1-3.5 7.08-7.08z" stroke="currentColor" stroke-width="1.1" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </button>
            </div>
            <div class="border-t border-cream/10 mt-4 intake-border"></div>
          </div>

          <!-- ========== STEP 4: Contact ========== -->
          <div id="step-4-active" class="hidden mt-8">
            <p class="font-montserrat text-teal text-xs font-semibold tracking-[0.15em] uppercase mb-2 intake-label">Clinic Info</p>
            <h2 class="font-fraunces text-cream text-[clamp(28px,4vw,40px)] leading-[1.15] tracking-[-0.02em] mb-4 intake-heading">
              How can we reach your clinic?
            </h2>
            <p class="font-inter text-cream/50 text-base leading-[1.6] mb-10 intake-body">
              We'll use this for order confirmations and clinical coordination.
            </p>

            <div class="mb-6">
              <label class="font-inter text-cream font-semibold text-base block mb-3 intake-bold">Primary Phone <span class="text-red-400 text-sm">*</span></label>
              <div class="flex items-center gap-0">
                <div class="flex items-center gap-2 border border-cream/15 border-r-0 rounded-l-2xl px-4 py-4 intake-phone-prefix">
                  <span class="text-sm">🇺🇸</span>
                  <span class="font-inter text-cream/50 text-base intake-muted">+1</span>
                </div>
                <input type="tel" id="contact-phone" placeholder="(555) 555-5522" class="flex-1 bg-transparent border border-cream/15 rounded-r-2xl px-5 py-4 font-inter text-cream text-base placeholder:text-cream/25 focus:outline-none focus:border-cream/40 transition-colors intake-input">
              </div>
            </div>

            <div class="mb-6">
              <label class="font-inter text-cream font-semibold text-base block mb-3 intake-bold">Fax</label>
              <div class="flex items-center gap-0">
                <div class="flex items-center gap-2 border border-cream/15 border-r-0 rounded-l-2xl px-4 py-4 intake-phone-prefix">
                  <span class="text-sm">🇺🇸</span>
                  <span class="font-inter text-cream/50 text-base intake-muted">+1</span>
                </div>
                <input type="tel" id="contact-fax" placeholder="(optional)" class="flex-1 bg-transparent border border-cream/15 rounded-r-2xl px-5 py-4 font-inter text-cream text-base placeholder:text-cream/25 focus:outline-none focus:border-cream/40 transition-colors intake-input">
              </div>
            </div>

            <div class="mb-8">
              <label class="font-inter text-cream font-semibold text-base block mb-3 intake-bold">Email <span class="text-red-400 text-sm">*</span></label>
              <input type="email" id="contact-email" placeholder="clinic@example.com" class="w-full bg-transparent border border-cream/15 rounded-2xl px-5 py-4 font-inter text-cream text-base placeholder:text-cream/25 focus:outline-none focus:border-cream/40 transition-colors intake-input">
            </div>

            <button id="step-4-continue" class="w-full bg-terracotta hover:brightness-110 text-cream font-montserrat font-medium text-base rounded-full px-10 py-4 transition-all cursor-pointer">
              Continue
            </button>
          </div>

          <!-- Step 4: Collapsed -->
          <div id="step-4-collapsed" class="hidden">
            <div class="flex items-center justify-between py-2">
              <div>
                <p class="font-montserrat text-teal text-[10px] font-semibold tracking-[0.15em] uppercase mb-1 intake-label">Clinic Info</p>
                <p class="font-inter text-cream/50 text-sm intake-body">How can we reach your clinic?</p>
              </div>
              <button class="edit-step-btn flex items-center gap-2 border border-cream/15 rounded-full px-4 py-2 text-cream text-sm font-inter font-medium hover:border-cream/30 transition-colors cursor-pointer intake-back-btn intake-heading" data-edit-step="4">
                <span id="step-4-answer">—</span>
                <svg width="14" height="14" viewBox="0 0 14 14" fill="none">
                  <path d="M10.08 1.92a1.5 1.5 0 012.12 0l.38.38a1.5 1.5 0 010 2.12L5.5 11.5 2 12.5l1-3.5 7.08-7.08z" stroke="currentColor" stroke-width="1.1" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </button>
            </div>
            <div class="border-t border-cream/10 mt-4 intake-border"></div>
          </div>

          <!-- ========== STEP 5: Admin Account ========== -->
          <div id="step-5-active" class="hidden mt-8">
            <p class="font-montserrat text-teal text-xs font-semibold tracking-[0.15em] uppercase mb-2 intake-label">Admin Account</p>
            <h2 class="font-fraunces text-cream text-[clamp(28px,4vw,40px)] leading-[1.15] tracking-[-0.02em] mb-4 intake-heading">
              Create your admin account
            </h2>
            <p class="font-inter text-cream/50 text-base leading-[1.6] mb-10 intake-body">
              This will be your login to manage your clinic on the Nimbus platform.
            </p>

            <div class="grid grid-cols-2 gap-4 mb-6">
              <div>
                <label class="font-inter text-cream font-semibold text-base block mb-3 intake-bold">First Name <span class="text-red-400 text-sm">*</span></label>
                <input type="text" id="admin-first" placeholder="Enter your first name" class="w-full bg-transparent border border-cream/15 rounded-2xl px-5 py-4 font-inter text-cream text-base placeholder:text-cream/25 focus:outline-none focus:border-cream/40 transition-colors intake-input">
              </div>

              <div>
                <label class="font-inter text-cream font-semibold text-base block mb-3 intake-bold">Last Name <span class="text-red-400 text-sm">*</span></label>
                <input type="text" id="admin-last" placeholder="Enter your last name" class="w-full bg-transparent border border-cream/15 rounded-2xl px-5 py-4 font-inter text-cream text-base placeholder:text-cream/25 focus:outline-none focus:border-cream/40 transition-colors intake-input">
              </div>
            </div>

            <div class="mb-2">
              <label class="font-inter text-cream font-semibold text-base block mb-3 intake-bold">
                <span class="inline-flex items-center gap-2">
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="none" class="text-cream/40">
                    <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z" stroke="currentColor" stroke-width="1.5"/>
                    <path d="M22 6l-10 7L2 6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
                  </svg>
                  Email <span class="text-red-400 text-sm">*</span>
                </span>
              </label>
              <input type="email" id="admin-email" placeholder="you@example.com" class="w-full bg-transparent border border-cream/15 rounded-2xl px-5 py-4 font-inter text-cream text-base placeholder:text-cream/25 focus:outline-none focus:border-cream/40 transition-colors intake-input">
            </div>
            <p class="font-inter text-cream/30 text-xs mb-6 intake-body">This is the email from your invitation and will be used for login.</p>

            <div class="grid grid-cols-2 gap-4 mb-2">
              <div>
                <label class="font-inter text-cream font-semibold text-base block mb-3 intake-bold">
                  <span class="inline-flex items-center gap-2">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" class="text-cream/40">
                      <rect x="3" y="11" width="18" height="11" rx="2" stroke="currentColor" stroke-width="1.5"/>
                      <path d="M7 11V7a5 5 0 0110 0v4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
                    </svg>
                    Password <span class="text-red-400 text-sm">*</span>
                  </span>
                </label>
