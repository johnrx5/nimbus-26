<style>
  .current-plan-card {
    background: rgba(26, 24, 22, 0.02);
    border: 1px solid rgba(26, 24, 22, 0.05);
    border-radius: 20px;
    padding: 28px;
  }

  .new-plan-card {
    background: #1A1816;
    border-radius: 20px;
    padding: 28px;
  }

  .option-inner-teal {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
    border-radius: 14px;
    padding: 16px 20px;
    cursor: pointer;
    transition: all 0.2s ease;
  }
  .option-inner-teal:hover {
    background: rgba(245, 240, 234, 0.06);
  }

  .radio-dot-teal {
    width: 20px;
    height: 20px;
    border-radius: 50%;
    border: 2px solid rgba(245, 240, 234, 0.3);
    display: flex;
    align-items: center;
    justify-content: center;
    transition: border-color 0.2s ease;
    flex-shrink: 0;
  }
  .radio-dot-inner-teal {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    background: transparent;
    transition: background 0.2s ease;
  }
  .peer:checked ~ .option-inner-teal .radio-dot-teal {
    border-color: #F5F0EA;
  }
  .peer:checked ~ .option-inner-teal .radio-dot-inner-teal {
    background: #F5F0EA;
  }

  .savings-badge {
    font-family: 'Inter', sans-serif;
    font-size: 11px;
    font-weight: 600;
    color: #F5F0EA;
    background: #B87A5D;
    border-radius: 9999px;
    padding: 4px 10px;
    white-space: nowrap;
  }

  .cc-card {
    background: rgba(26, 24, 22, 0.02);
    border: 1px solid rgba(26, 24, 22, 0.05);
    border-radius: 16px;
    padding: 20px 24px;
  }

  .summary-card {
    background: rgba(26, 24, 22, 0.02);
    border: 1px solid rgba(26, 24, 22, 0.05);
    border-radius: 20px;
    padding: 28px;
  }

  .consent-row {
    display: flex;
    align-items: flex-start;
    gap: 14px;
    cursor: pointer;
  }
  .consent-checkbox {
    display: none;
  }
  .checkmark {
    width: 22px;
    height: 22px;
    border: 1.5px solid rgba(26, 24, 22, 0.2);
    border-radius: 6px;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    margin-top: 1px;
    transition: all 0.2s ease;
    color: transparent;
  }
  .consent-checkbox:checked + .checkmark {
    background: #2a9d8f;
    border-color: #2a9d8f;
    color: #F5F0EA;
  }

  .support-callout {
    display: flex;
    align-items: flex-start;
    gap: 12px;
    background: rgba(42, 157, 143, 0.06);
    border: 1px solid rgba(42, 157, 143, 0.12);
    border-radius: 14px;
    padding: 16px 20px;
  }

  /* A/B Toggle */
  .variant-toggle-btn {
    background: #F5F0EA;
    color: rgba(26, 24, 22, 0.4);
    cursor: pointer;
    border: none;
  }
  .variant-toggle-btn.active {
    background: #1A1816;
    color: #F5F0EA;
  }
</style>

<script>
  // Plan pricing data
  const plans: Record<string, { rate: string; billing: string; medication: string }> = {
    monthly: { rate: '$179/month', billing: 'Billed monthly', medication: 'Carnisema (Semaglutide)' },
    quarterly: { rate: '$149/month', billing: 'Billed monthly ($447)', medication: 'Carnisema (Semaglutide)' },
    biannual: { rate: '$129/month', billing: 'Billed monthly ($774)', medication: 'Carnisema (Semaglutide)' },
    'tirz-monthly': { rate: '$299/month', billing: 'Billed monthly', medication: 'Tirzepatide' },
    'tirz-quarterly': { rate: '$248/month', billing: 'Billed monthly ($744)', medication: 'Tirzepatide' },
    'tirz-biannual': { rate: '$219/month', billing: 'Billed monthly ($1,314)', medication: 'Tirzepatide' },
  };

  // Tirzepatide toggle
  const tirzToggle = document.getElementById('tirz-toggle');
  const tirzPricing = document.getElementById('tirz-pricing');
  const tirzArrow = document.getElementById('tirz-arrow');

  function toggleTirz() {
    tirzPricing?.classList.toggle('hidden');
    tirzArrow?.classList.toggle('rotate-180');
  }
  tirzToggle?.addEventListener('click', toggleTirz);

  // Tirzepatide info modal
  const tirzInfoBtn = document.getElementById('tirz-info-btn');
  const tirzModal = document.getElementById('tirz-modal');
  const tirzOverlay = document.getElementById('tirz-overlay');
  const tirzModalClose = document.getElementById('tirz-modal-close');
  const tirzModalGotIt = document.getElementById('tirz-modal-got-it');

  function openTirzModal() {
    tirzModal?.classList.remove('hidden');
    tirzModal?.classList.add('flex');
  }
  function closeTirzModal() {
    tirzModal?.classList.add('hidden');
    tirzModal?.classList.remove('flex');
  }

  tirzInfoBtn?.addEventListener('click', (e) => {
    e.stopPropagation();
    openTirzModal();
  });
  tirzOverlay?.addEventListener('click', closeTirzModal);
  tirzModalClose?.addEventListener('click', closeTirzModal);
  tirzModalGotIt?.addEventListener('click', closeTirzModal);

  // Update summary + consent when plan changes
  const radios = document.querySelectorAll<HTMLInputElement>('input[name="plan"]');
  const summaryRate = document.getElementById('summary-rate');
  const summaryBilling = document.getElementById('summary-billing');
  const summaryMedication = document.getElementById('summary-medication');
  const consentPrice = document.getElementById('consent-price');
  const consentNew = document.getElementById('consent-new');
  const summaryRateB = document.getElementById('summary-rate-b');
  const summaryMedicationB = document.getElementById('summary-medication-b');

  function updatePlan() {
    const selected = document.querySelector<HTMLInputElement>('input[name="plan"]:checked');
    if (!selected) return;
    const plan = plans[selected.value];
    if (summaryRate) summaryRate.textContent = plan.rate;
    if (summaryBilling) summaryBilling.textContent = plan.billing;
    if (summaryMedication) summaryMedication.textContent = plan.medication;
    if (summaryRateB) summaryRateB.textContent = plan.rate;
    if (summaryMedicationB) summaryMedicationB.textContent = plan.medication;
    if (consentPrice) consentPrice.textContent = plan.rate;
    if (consentNew) consentNew.textContent = plan.rate;
  }

  radios.forEach(r => r.addEventListener('change', updatePlan));

  // Consent validation
  const checkboxes = document.querySelectorAll<HTMLInputElement>('.consent-checkbox');
  const acceptBtn = document.getElementById('accept-btn') as HTMLButtonElement;

  function validateConsent() {
    const allChecked = Array.from(checkboxes).every(cb => cb.checked);
    if (allChecked) {
      acceptBtn.disabled = false;
      acceptBtn.classList.remove('bg-terracotta/40', 'text-cream/40', 'cursor-not-allowed');
      acceptBtn.classList.add('bg-terracotta', 'hover:bg-terracotta-hover', 'text-cream', 'cursor-pointer');
    } else {
      acceptBtn.disabled = true;
      acceptBtn.classList.add('bg-terracotta/40', 'text-cream/40', 'cursor-not-allowed');
      acceptBtn.classList.remove('bg-terracotta', 'hover:bg-terracotta-hover', 'text-cream', 'cursor-pointer');
    }
  }

  checkboxes.forEach(cb => cb.addEventListener('change', validateConsent));

  // A/B variant toggle
  const variantA = document.getElementById('variant-a');
  const variantB = document.getElementById('variant-b');
  const oldPlanA = document.getElementById('old-plan-a');
  const oldPlanB = document.getElementById('old-plan-b');
  const summaryAEl = document.getElementById('summary-a');
  const summaryBEl = document.getElementById('summary-b');
  const consentDate = document.getElementById('consent-date');

  function setVariant(variant: string) {
    variantA?.classList.remove('active');
    variantB?.classList.remove('active');

    if (variant === 'b') {
      oldPlanA?.classList.add('hidden');
      oldPlanB?.classList.remove('hidden');
      summaryAEl?.classList.add('hidden');
      summaryBEl?.classList.remove('hidden');
      if (consentDate) consentDate.textContent = 'July 1, 2026';
      variantB?.classList.add('active');
    } else {
      oldPlanA?.classList.remove('hidden');
      oldPlanB?.classList.add('hidden');
      summaryAEl?.classList.remove('hidden');
      summaryBEl?.classList.add('hidden');
      if (consentDate) consentDate.textContent = 'April 1, 2026';
      variantA?.classList.add('active');
    }
  }

  variantA?.addEventListener('click', () => setVariant('a'));
  variantB?.addEventListener('click', () => setVariant('b'));
</script>
