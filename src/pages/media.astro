---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';

const featuredVideo = {
  id: '_gJV3biiqdU',
  title: 'WeightWiseRX Instructional Video',
  date: 'May 2025',
};

const shorts = [
  { id: 'ChQzSXf-ND4', title: 'Can AI replace your pharmacist?' },
  { id: 'aEns-7pt6tk', title: 'FIBER! #glp1 #healthyliving' },
  { id: 'rrNw8O4QvCc', title: "You don't have to tough it out through perimenopause" },
  { id: 'Dc4aGV8gGhg', title: 'This moment hit different' },
  { id: 'Ww1utz_VpFs', title: 'Level Up — Hormone Optimization' },
  { id: 'loHufThBhvs', title: 'Nobody cares about...' },
];

const videos = [
  { id: 'YUWmSHNNUdc', title: 'GLP-1 Medications: How They Manage Blood Sugar & Aid Weight Loss', date: 'Apr 2024' },
  { id: 'VJ3JFMi5Sz8', title: 'Nimbus Mary Testimonial', date: 'Mar 2024' },
  { id: 'sPeLhyyWmoo', title: 'How To Use GLP-1 Medication', date: 'Feb 2024' },
  { id: 'tXyYoPsV7YM', title: 'Hair Restoration: How To Apply Prescription Solution', date: 'Jan 2024' },
  { id: 'zw-0wR0eEKg', title: 'Jobby — Alopecia Journey', date: 'Jan 2024' },
  { id: 'XHXucruRNLI', title: "Women's Hormone Optimization: How To Collect Your Sample", date: 'Dec 2023' },
];
---

<Layout title="Nimbus Healthcare - Media">
  <Navbar />
  <main class="bg-[#1A1816]">

    <!-- Hero -->
    <section class="pt-44 pb-20 px-[10px]">
      <div class="max-w-7xl mx-auto flex flex-col lg:flex-row items-start gap-12 lg:gap-20">
        <!-- Title -->
        <div class="flex-shrink-0 lg:pt-8">
          <h1 class="font-fraunces text-cream text-[clamp(56px,7vw,96px)] leading-[0.95] font-light">
            Media
          </h1>
          <p class="font-inter text-cream/40 text-sm mt-6 max-w-[280px] leading-relaxed">Educational videos, patient stories, and behind-the-scenes content from the Nimbus team.</p>
          <a href="https://www.youtube.com/@NimbusHealthcare" target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-2 mt-6 font-inter text-teal text-sm font-medium hover:text-teal/80 transition-colors">
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.546 12 3.546 12 3.546s-7.505 0-9.377.504A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.504 9.376.504 9.376.504s7.505 0 9.377-.504a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814z"/><path fill="#1A1816" d="M9.545 15.568V8.432L15.818 12l-6.273 3.568z"/></svg>
            Subscribe on YouTube
          </a>
        </div>

        <!-- Featured Video -->
        <div class="flex-1 w-full">
          <div class="relative aspect-video rounded-2xl overflow-hidden bg-[#22201E]">
            <iframe
              src={`https://www.youtube.com/embed/${featuredVideo.id}`}
              title={featuredVideo.title}
              class="absolute inset-0 w-full h-full"
              frameborder="0"
              allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
              allowfullscreen
            ></iframe>
          </div>
          <div class="mt-4">
            <p class="font-inter text-teal text-xs font-semibold tracking-wide">{featuredVideo.date}</p>
            <h2 class="font-inter text-cream text-lg font-semibold mt-1">{featuredVideo.title}</h2>
          </div>
        </div>
      </div>
    </section>

    <!-- Shorts -->
    <section class="py-20 px-[10px]">
      <div class="max-w-7xl mx-auto">
        <h2 class="font-fraunces text-cream text-[clamp(36px,5vw,56px)] leading-[1] font-light mb-10">Shorts</h2>
        <div class="flex gap-4 overflow-x-auto pb-4 -mx-[10px] px-[10px] scrollbar-hide">
          {shorts.map((short) => (
            <a
              href={`https://www.youtube.com/shorts/${short.id}`}
              target="_blank"
              rel="noopener noreferrer"
              class="flex-shrink-0 w-[200px] group"
            >
              <div class="relative aspect-[9/16] rounded-2xl overflow-hidden bg-[#22201E] border border-cream/10">
                <img
                  src={`https://img.youtube.com/vi/${short.id}/maxresdefault.jpg`}
                  alt={short.title}
                  class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300"
                  loading="lazy"
                />
                <div class="absolute inset-0 bg-gradient-to-t from-dark/80 via-transparent to-transparent"></div>
                <!-- Play icon -->
                <div class="absolute inset-0 flex items-center justify-center opacity-0 group-hover:opacity-100 transition-opacity">
                  <div class="w-12 h-12 rounded-full bg-cream/20 backdrop-blur-sm flex items-center justify-center">
                    <svg class="w-5 h-5 text-cream ml-0.5" fill="currentColor" viewBox="0 0 24 24"><path d="M8 5v14l11-7z"/></svg>
                  </div>
                </div>
                <p class="absolute bottom-3 left-3 right-3 font-inter text-cream text-xs font-medium leading-tight">{short.title}</p>
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>

    <!-- More Videos -->
    <section class="py-20 px-[10px]">
      <div class="max-w-7xl mx-auto">
        <h2 class="font-fraunces text-cream text-[clamp(36px,5vw,56px)] leading-[1] font-light mb-10">More Videos</h2>
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
          {videos.map((video) => (
            <a
              href={`https://www.youtube.com/watch?v=${video.id}`}
              target="_blank"
              rel="noopener noreferrer"
              class="group"
            >
              <div class="relative aspect-video rounded-2xl overflow-hidden bg-[#22201E] border border-cream/10">
                <img
                  src={`https://img.youtube.com/vi/${video.id}/maxresdefault.jpg`}
                  alt={video.title}
                  class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300"
                  loading="lazy"
                />
                <!-- Play icon -->
                <div class="absolute inset-0 flex items-center justify-center">
                  <div class="w-14 h-14 rounded-full bg-dark/60 backdrop-blur-sm flex items-center justify-center group-hover:bg-teal/80 transition-colors">
                    <svg class="w-6 h-6 text-cream ml-0.5" fill="currentColor" viewBox="0 0 24 24"><path d="M8 5v14l11-7z"/></svg>
                  </div>
                </div>
              </div>
              <div class="mt-3">
                <p class="font-inter text-teal text-xs font-semibold tracking-wide">{video.date}</p>
                <h3 class="font-inter text-cream text-sm font-semibold mt-1 leading-snug group-hover:text-cream/80 transition-colors">{video.title}</h3>
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>

  </main>

  <!-- Footer -->
  <div class="bg-[#1A1816] pb-[10px] px-[10px]">
    <Footer />
  </div>
</Layout>

<style>
  .scrollbar-hide::-webkit-scrollbar {
    display: none;
  }
  .scrollbar-hide {
    -ms-overflow-style: none;
    scrollbar-width: none;
  }
</style>
