---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Nimbus Healthcare - Review Your Updated Plan">
  <main>
    <section class="min-h-screen bg-cream pb-20 px-5">
      <div id="page-container" class="w-full max-w-[620px] mx-auto transition-all duration-500">

        <!-- Logo -->
        <div class="pt-8 mb-5">
          <img src="/images/nimbus-logo-dark.png" alt="Nimbus Healthcare" class="h-7 w-auto" />
        </div>

        <!-- Header -->
        <div class="mb-5">
          <h1 class="font-fraunces text-dark text-[32px] md:text-[44px] leading-[1.1] mb-3">Review your new plan</h1>
          <p class="font-inter text-dark/50 text-base max-w-[600px]">
            We've made some important improvements to how your plan works, designed to give you more control, more transparency, and better value.
          </p>
        </div>

        <!-- Current Cost -->
        <div class="current-plan-card mb-5">
          <p class="font-inter text-dark text-xs uppercase tracking-wider mb-4 font-bold">Your Old Plan</p>
            <!-- Variant A content -->
            <div id="old-plan-a">
              <h3 class="font-fraunces text-dark/40 text-[28px] leading-tight mb-5"><span class="line-through decoration-dark/15">$297</span><span class="text-lg">/mo</span></h3>
              <div class="space-y-3">
                <div class="flex justify-between items-center">
                  <span class="font-inter text-dark/40 text-sm">Plan</span>
                  <span class="font-inter text-dark/60 text-sm">Charged regardless of engagement</span>
                </div>
                <div class="h-px bg-dark/8"></div>
                <div class="flex justify-between items-center">
                  <span class="font-inter text-dark/40 text-sm">Medication</span>
                  <span class="font-inter text-dark/60 text-sm">Semaglutide</span>
                </div>
                <div class="h-px bg-dark/8"></div>
                <div class="flex justify-between items-center">
                  <span class="font-inter text-dark/40 text-sm">Billing</span>
                  <span class="font-inter text-dark/60 text-sm">Monthly</span>
                </div>
              </div>
            </div>
            <!-- Variant B content (prepaid 6-month) -->
            <div id="old-plan-b" class="hidden">
              <h3 class="font-fraunces text-dark/40 text-[28px] leading-tight mb-5"><span class="line-through decoration-dark/15">$774</span><span class="text-lg"> / 6 months</span></h3>
              <div class="space-y-3">
                <div class="flex justify-between items-center">
                  <span class="font-inter text-dark/40 text-sm">Plan</span>
                  <span class="font-inter text-dark/60 text-sm">6-month prepaid</span>
                </div>
                <div class="h-px bg-dark/8"></div>
                <div class="flex justify-between items-center">
                  <span class="font-inter text-dark/40 text-sm">Medication</span>
                  <span class="font-inter text-dark/60 text-sm">Semaglutide</span>
                </div>
                <div class="h-px bg-dark/8"></div>
                <div class="flex justify-between items-center">
                  <span class="font-inter text-dark/40 text-sm">Paid through</span>
                  <span class="font-inter text-dark/60 text-sm">June 30, 2026</span>
                </div>
                <div class="h-px bg-dark/8"></div>
                <div class="flex justify-between items-center">
                  <span class="font-inter text-dark/40 text-sm">Remaining</span>
                  <span class="font-inter text-teal text-sm font-medium">3 months</span>
                </div>
              </div>
            </div>
        </div>

        <!-- New Pricing Options -->
        <div class="new-plan-card mb-5">
          <p class="font-inter text-cream text-xs uppercase tracking-wider mb-2 font-bold">Your New Plan</p>
          <p class="font-inter text-cream text-xs mb-5">Select pricing</p>

          <!-- Pricing Options -->
          <div class="space-y-2">

            <!-- Monthly -->
            <label class="pricing-option group" data-option="monthly">
              <input type="radio" name="plan" value="monthly" class="hidden peer" checked />
              <div class="option-inner-teal peer-checked:bg-cream/10">
                <div class="flex items-center gap-3">
                  <div class="radio-dot-teal">
                    <div class="radio-dot-inner-teal"></div>
                  </div>
                  <div>
                    <p class="font-inter text-cream text-sm font-semibold">Monthly</p>
                    <p class="font-inter text-cream/50 text-xs">Billed monthly</p>
                  </div>
                </div>
                <div class="text-right">
                  <p class="font-fraunces text-cream text-xl">$179<span class="text-sm text-cream/60">/mo</span></p>
                </div>
              </div>
            </label>

            <!-- 3-Month -->
            <label class="pricing-option group" data-option="quarterly">
              <input type="radio" name="plan" value="quarterly" class="hidden peer" />
              <div class="option-inner-teal peer-checked:bg-cream/10">
                <div class="flex items-center gap-3">
                  <div class="radio-dot-teal">
                    <div class="radio-dot-inner-teal"></div>
                  </div>
                  <div>
                    <p class="font-inter text-cream text-sm font-semibold">3-Month</p>
                    <p class="font-inter text-cream/50 text-xs">Billed monthly</p>
                  </div>
                </div>
                <div class="text-right flex flex-col md:flex-row items-end md:items-center gap-1 md:gap-2">
                  <p class="font-fraunces text-cream text-xl order-1 md:order-2">$149<span class="text-sm text-cream/60">/mo</span></p>
                  <span class="savings-badge order-2 md:order-1">Save 17%</span>
                </div>
              </div>
            </label>

            <!-- 6-Month -->
            <label class="pricing-option group" data-option="biannual">
              <input type="radio" name="plan" value="biannual" class="hidden peer" />
              <div class="option-inner-teal peer-checked:bg-cream/10">
                <div class="flex items-center gap-3">
                  <div class="radio-dot-teal">
                    <div class="radio-dot-inner-teal"></div>
                  </div>
                  <div>
                    <p class="font-inter text-cream text-sm font-semibold">6-Month</p>
                    <p class="font-inter text-cream/50 text-xs">Billed monthly</p>
                  </div>
                </div>
                <div class="text-right flex flex-col md:flex-row items-end md:items-center gap-1 md:gap-2">
                  <p class="font-fraunces text-cream text-xl order-1 md:order-2">$129<span class="text-sm text-cream/60">/mo</span></p>
                  <span class="savings-badge order-2 md:order-1">Save 28%</span>
                </div>
              </div>
            </label>

          </div>

          <!-- Tirzepatide Toggle -->
          <div id="tirz-toggle" class="mt-5 pt-4 border-t border-cream/15 w-full flex items-center justify-between cursor-pointer">
            <div class="flex items-center gap-1.5">
              <span class="font-inter text-cream text-xs">Interested in Tirzepatide?</span>
              <div id="tirz-info-btn" class="inline-flex items-center justify-center w-4 h-4 rounded-full border border-cream/30 text-cream/50 hover:text-cream hover:border-cream/60 transition-colors text-[10px] font-bold cursor-pointer">?</div>
            </div>
            <svg id="tirz-arrow" class="w-4 h-4 text-cream/40 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg>
          </div>

          <!-- Tirzepatide Pricing (hidden by default) -->
          <div id="tirz-pricing" class="hidden mt-3 space-y-2">
            <!-- Monthly -->
            <label class="pricing-option group" data-option="tirz-monthly">
              <input type="radio" name="plan" value="tirz-monthly" class="hidden peer" />
              <div class="option-inner-teal peer-checked:bg-cream/10">
                <div class="flex items-center gap-3">
                  <div class="radio-dot-teal">
                    <div class="radio-dot-inner-teal"></div>
                  </div>
                  <div>
                    <p class="font-inter text-cream text-sm font-semibold">Monthly</p>
                    <p class="font-inter text-cream/50 text-xs">Billed monthly</p>
                  </div>
                </div>
                <div class="text-right">
                  <p class="font-fraunces text-cream text-xl">$299<span class="text-sm text-cream/60">/mo</span></p>
                </div>
              </div>
            </label>

            <!-- 3-Month -->
            <label class="pricing-option group" data-option="tirz-quarterly">
              <input type="radio" name="plan" value="tirz-quarterly" class="hidden peer" />
              <div class="option-inner-teal peer-checked:bg-cream/10">
                <div class="flex items-center gap-3">
                  <div class="radio-dot-teal">
                    <div class="radio-dot-inner-teal"></div>
                  </div>
                  <div>
                    <p class="font-inter text-cream text-sm font-semibold">3-Month</p>
                    <p class="font-inter text-cream/50 text-xs">Billed monthly</p>
                  </div>
                </div>
                <div class="text-right flex flex-col md:flex-row items-end md:items-center gap-1 md:gap-2">
                  <p class="font-fraunces text-cream text-xl order-1 md:order-2">$248<span class="text-sm text-cream/60">/mo</span></p>
                  <span class="savings-badge order-2 md:order-1">Save 17%</span>
                </div>
              </div>
            </label>

            <!-- 6-Month -->
            <label class="pricing-option group" data-option="tirz-biannual">
              <input type="radio" name="plan" value="tirz-biannual" class="hidden peer" />
              <div class="option-inner-teal peer-checked:bg-cream/10">
                <div class="flex items-center gap-3">
                  <div class="radio-dot-teal">
                    <div class="radio-dot-inner-teal"></div>
                  </div>
                  <div>
                    <p class="font-inter text-cream text-sm font-semibold">6-Month</p>
                    <p class="font-inter text-cream/50 text-xs">Billed monthly</p>
                  </div>
                </div>
                <div class="text-right flex flex-col md:flex-row items-end md:items-center gap-1 md:gap-2">
                  <p class="font-fraunces text-cream text-xl order-1 md:order-2">$219<span class="text-sm text-cream/60">/mo</span></p>
                  <span class="savings-badge order-2 md:order-1">Save 27%</span>
                </div>
              </div>
            </label>
          </div>

          <!-- Benefits -->
          <div class="flex flex-wrap justify-center gap-x-5 gap-y-2 mt-5 pt-5 border-t border-cream/15">
            <div class="flex items-center gap-2">
              <svg class="w-4 h-4 text-teal shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
              <span class="font-inter text-cream/80 text-xs">No surprise charges</span>
            </div>
            <div class="flex items-center gap-2">
              <svg class="w-4 h-4 text-teal shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
              <span class="font-inter text-cream/80 text-xs">You're in control</span>
            </div>
            <div class="flex items-center gap-2">
              <svg class="w-4 h-4 text-teal shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
              <span class="font-inter text-cream/80 text-xs">Pause anytime</span>
            </div>
          </div>
        </div>

        <!-- What's New -->
        <div class="summary-card mb-5">
          <p class="font-inter text-dark text-xs uppercase tracking-wider mb-4 font-bold">What's New</p>
          <div class="space-y-4">
            <div class="flex items-start gap-3">
              <svg class="w-4 h-4 text-teal shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
              <p class="font-inter text-dark/60 text-sm leading-relaxed"><strong class="text-dark">One simple price, every month.</strong> No more varying charges based on medication.</p>
            </div>
            <div class="flex items-start gap-3">
              <svg class="w-4 h-4 text-teal shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
              <p class="font-inter text-dark/60 text-sm leading-relaxed"><strong class="text-dark">Automatic payment processing.</strong> Payment is now processed automatically when your provider creates a prescription. No more manual approval each time.</p>
            </div>
            <div class="flex items-start gap-3">
              <svg class="w-4 h-4 text-teal shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
              <p class="font-inter text-dark/60 text-sm leading-relaxed"><strong class="text-dark">Pay As You Engage.</strong> You're charged only after check-in + provider review.</p>
            </div>
            <div class="flex items-start gap-3">
              <svg class="w-4 h-4 text-teal shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
              <p class="font-inter text-dark/60 text-sm leading-relaxed"><strong class="text-dark">Prepaid balance honored.</strong> If you have time remaining on your prepaid plan, your balance will be honored in full. Your new plan begins when your old plan ends.</p>
            </div>
            <div class="flex items-start gap-3">
              <svg class="w-4 h-4 text-teal shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
              <p class="font-inter text-dark/60 text-sm leading-relaxed"><strong class="text-dark">Auto-pause protection.</strong> If you don't engage for 30 days, we'll pause your subscription so you're not charged while inactive.</p>
            </div>
          </div>
        </div>

        <!-- Updated Plan Summary -->
        <div class="summary-card mb-5">
          <p class="font-inter text-dark text-xs uppercase tracking-wider mb-1 font-bold">Updated Plan Summary</p>
          <!-- Variant A summary -->
          <div id="summary-a" class="space-y-3 mt-4">
            <div class="flex justify-between">
              <span class="font-inter text-dark/50 text-sm">Plan</span>
              <span class="font-inter text-dark text-sm font-medium">Pay as you engage</span>
            </div>
            <div class="h-px bg-dark/8"></div>
            <div class="flex justify-between">
              <span class="font-inter text-dark/50 text-sm">Medication</span>
              <span class="font-inter text-dark text-sm font-medium" id="summary-medication">Carnisema (Semaglutide)</span>
            </div>
            <div class="h-px bg-dark/8"></div>
            <div class="flex justify-between">
              <span class="font-inter text-dark/50 text-sm">Rate</span>
              <span class="font-inter text-dark text-sm font-medium" id="summary-rate">$179/month</span>
            </div>
            <div class="h-px bg-dark/8"></div>
            <div class="flex justify-between">
              <span class="font-inter text-dark/50 text-sm">Billing</span>
              <span class="font-inter text-dark text-sm font-medium" id="summary-billing">Billed monthly</span>
            </div>
            <div class="h-px bg-dark/8"></div>
            <div class="flex justify-between">
              <span class="font-inter text-dark/50 text-sm">Effective</span>
              <span class="font-inter text-dark text-sm font-medium">April 1, 2026</span>
            </div>
          </div>
          <!-- Variant B summary (prepaid transition) -->
          <div id="summary-b" class="hidden mt-4">
            <!-- Prepaid remaining callout -->
            <div class="bg-teal/8 rounded-xl p-4 mb-4">
              <div class="flex items-start gap-3">
                <svg class="w-4 h-4 text-teal shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
                <div>
                  <p class="font-inter text-dark text-sm font-medium mb-1">Prepaid balance honored</p>
                  <p class="font-inter text-dark/50 text-xs leading-relaxed">Your remaining 3 months at $175/mo will continue through June 30, 2026. No changes until then.</p>
                </div>
              </div>
            </div>
            <div class="space-y-3">
              <div class="flex justify-between">
                <span class="font-inter text-dark/50 text-sm">Current rate</span>
                <span class="font-inter text-dark text-sm font-medium">$175/mo (prepaid)</span>
              </div>
              <div class="h-px bg-dark/8"></div>
              <div class="flex justify-between">
                <span class="font-inter text-dark/50 text-sm">Remaining</span>
                <span class="font-inter text-teal text-sm font-medium">3 months (through Jun 30)</span>
              </div>
              <div class="h-px bg-dark/8"></div>
              <div class="flex justify-between">
                <span class="font-inter text-dark/50 text-sm">New plan starts</span>
                <span class="font-inter text-dark text-sm font-medium">July 1, 2026</span>
              </div>
              <div class="h-px bg-dark/8"></div>
              <div class="flex justify-between">
                <span class="font-inter text-dark/50 text-sm">New rate</span>
                <span class="font-inter text-dark text-sm font-medium" id="summary-rate-b">$179/month</span>
              </div>
              <div class="h-px bg-dark/8"></div>
              <div class="flex justify-between">
                <span class="font-inter text-dark/50 text-sm">New plan</span>
                <span class="font-inter text-dark text-sm font-medium">Pay as you engage</span>
              </div>
              <div class="h-px bg-dark/8"></div>
              <div class="flex justify-between">
                <span class="font-inter text-dark/50 text-sm">Medication</span>
                <span class="font-inter text-dark text-sm font-medium" id="summary-medication-b">Carnisema (Semaglutide)</span>
              </div>
            </div>
          </div>
        </div>

        <!-- Credit Card on File -->
        <div class="cc-card mb-5">
          <div class="flex items-center justify-between">
            <div class="flex items-center gap-4">
              <!-- Visa icon -->
              <div class="w-12 h-8 flex items-center justify-center rounded-md overflow-hidden bg-white border border-dark/10">
                <img src="/images/visa-pay-logo.svg" alt="Visa" class="w-9 h-auto" />
              </div>
              <div>
                <p class="font-inter text-dark text-sm font-medium">Visa ending in 4821</p>
                <p class="font-inter text-dark/40 text-xs">Expires 09/2027</p>
              </div>
            </div>
            <button class="font-inter text-teal text-sm font-medium hover:text-teal/80 transition-colors cursor-pointer">
              Update
            </button>
          </div>
        </div>

        <!-- Consent -->
        <div class="mb-5">
          <p class="font-inter text-dark text-base font-medium mb-5">By continuing, I acknowledge:</p>

          <div class="space-y-4">
            <label class="consent-row">
              <input type="checkbox" id="consent-1" class="consent-checkbox" />
              <div class="checkmark">
                <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
              </div>
              <span class="font-inter text-dark/60 text-sm leading-relaxed">
                I understand my plan is changing from <strong class="text-dark">$297/month</strong> to <strong class="text-dark" id="consent-price">$179/month</strong> effective <strong class="text-dark" id="consent-date">April 1, 2026</strong>
              </span>
            </label>

            <label class="consent-row">
              <input type="checkbox" id="consent-2" class="consent-checkbox" />
              <div class="checkmark">
                <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
              </div>
              <span class="font-inter text-dark/60 text-sm leading-relaxed">
                I understand my new monthly rate is <strong class="text-dark" id="consent-new">$179/month</strong> (previously <strong class="text-dark/50">$297/month</strong>)
              </span>
            </label>

            <label class="consent-row">
              <input type="checkbox" id="consent-3" class="consent-checkbox" />
              <div class="checkmark">
                <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
              </div>
              <span class="font-inter text-dark/60 text-sm leading-relaxed">
                I have read and agree to the updated
                <a href="#" class="text-teal underline hover:text-teal/80 transition-colors">Terms of Service</a> and
                <a href="#" class="text-teal underline hover:text-teal/80 transition-colors">Subscription Agreement</a>
              </span>
            </label>
          </div>
        </div>

        <!-- Support Callout -->
        <div class="support-callout mb-5">
          <svg class="w-4 h-4 text-teal shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
          <p class="font-inter text-dark/50 text-sm">
            Questions? Chat with <strong class="text-dark/70">Nimy</strong> or contact support at
            <a href="mailto:support@nimbushealthcare.com" class="text-teal hover:text-teal/80 transition-colors">support@nimbushealthcare.com</a>
          </p>
        </div>

        <!-- Actions -->
        <div class="flex items-center justify-between gap-4">
          <a href="/login" class="font-inter text-dark/40 text-sm font-medium flex items-center gap-2 hover:text-dark transition-colors group">
            <svg class="w-4 h-4 group-hover:-translate-x-0.5 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7"/></svg>
            Back
          </a>
          <button id="accept-btn" disabled class="bg-terracotta/40 text-cream/40 font-montserrat font-semibold text-base rounded-full py-4 px-10 transition-all cursor-not-allowed">
            Accept & Continue
            <svg class="w-4 h-4 inline-block ml-1" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
          </button>
        </div>

      </div>
    </section>
  </main>

  <!-- A/B Variant Toggle -->
  <div class="fixed bottom-6 right-6 z-50 flex items-center gap-0 rounded-full overflow-hidden shadow-lg border border-dark/10">
    <button id="variant-a" class="variant-toggle-btn active font-inter text-xs font-semibold px-5 py-3 transition-all">A</button>
    <button id="variant-b" class="variant-toggle-btn font-inter text-xs font-semibold px-5 py-3 transition-all">B</button>
  </div>

  <!-- Tirzepatide Info Modal -->
  <div id="tirz-modal" class="fixed inset-0 z-50 hidden items-center justify-center px-5">
    <div id="tirz-overlay" class="absolute inset-0 bg-dark/60 backdrop-blur-sm"></div>
    <div class="relative bg-cream rounded-2xl max-w-[520px] w-full p-8 shadow-2xl">
      <button id="tirz-modal-close" class="absolute top-4 right-4 w-8 h-8 flex items-center justify-center rounded-full hover:bg-dark/5 transition-colors cursor-pointer">
        <svg class="w-5 h-5 text-dark/40" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/></svg>
      </button>
