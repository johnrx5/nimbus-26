---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog')).sort(
  (a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime()
);

const categories = ['All', ...new Set(posts.map(p => p.data.category).filter(Boolean))];
const featured = posts[0];
const rest = posts.slice(1);

function slug(post: any) {
  return post.id.replace(/\.md$/, '');
}
---

<Layout title="Blog - Nimbus Healthcare">
  <Navbar />
  <main class="bg-cream">

    <!-- Hero -->
    <section class="pt-32 pb-16 px-6 md:px-10">
      <div class="max-w-[1200px] mx-auto">
        <h1 class="font-fraunces text-dark text-[clamp(40px,5vw,64px)] leading-[1.05] tracking-[-0.02em] mb-4">
          The Journal
        </h1>
        <p class="font-inter text-dark/50 text-lg max-w-[600px]">
          Clinical insights, wellness guides, and the science behind modern metabolic care.
        </p>
      </div>
    </section>

    <!-- Category Filter -->
    <section class="px-6 md:px-10 pb-10">
      <div class="max-w-[1200px] mx-auto flex gap-3 flex-wrap" id="category-filters">
        {categories.map(cat => (
          <button
            class:list={[
              'category-pill font-inter text-sm px-5 py-2.5 rounded-full transition-all duration-300 cursor-pointer',
              cat === 'All' ? 'bg-dark text-cream' : 'bg-dark/5 text-dark/60 hover:bg-dark/10'
            ]}
            data-category={cat}
          >
            {cat}
          </button>
        ))}
      </div>
    </section>

    <!-- Featured Post -->
    <section class="px-6 md:px-10 pb-10">
      <div class="max-w-[1200px] mx-auto">
        <a href={`/blog/${slug(featured)}`} class="group block" data-category={featured.data.category}>
          <div class="grid md:grid-cols-2 gap-8 bg-white rounded-2xl overflow-hidden">
            <div class="aspect-[4/3] overflow-hidden">
              <img
                src={featured.data.image}
                alt={featured.data.title}
                class="w-full h-full object-cover group-hover:scale-[1.03] transition-transform duration-500"
              />
            </div>
            <div class="flex flex-col justify-center p-8 md:pr-12">
              {featured.data.category && (
                <span class="font-montserrat text-xs font-semibold uppercase tracking-[0.15em] text-teal mb-4">
                  {featured.data.category}
                </span>
              )}
              <h2 class="font-fraunces text-dark text-[clamp(24px,3vw,36px)] leading-[1.15] tracking-[-0.02em] mb-4 group-hover:text-teal transition-colors duration-300">
                {featured.data.title}
              </h2>
              <p class="font-inter text-dark/50 text-base leading-[1.6] mb-6 line-clamp-3">
                {featured.data.excerpt}
              </p>
              <div class="flex items-center gap-3">
                <span class="font-inter text-dark/40 text-sm">{featured.data.author}</span>
                <span class="text-dark/20">·</span>
                <span class="font-inter text-dark/40 text-sm">
                  {new Date(featured.data.date).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' })}
                </span>
              </div>
            </div>
          </div>
        </a>
      </div>
    </section>

    <!-- Post Grid -->
    <section class="px-6 md:px-10 pb-24">
      <div class="max-w-[1200px] mx-auto">
        <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6" id="post-grid">
          {rest.map(post => (
            <a
              href={`/blog/${slug(post)}`}
              class="group blog-card block bg-white rounded-2xl overflow-hidden transition-all duration-300 hover:-translate-y-1 hover:shadow-lg"
              data-category={post.data.category}
            >
              <div class="aspect-[16/10] overflow-hidden">
                <img
                  src={post.data.image}
                  alt={post.data.title}
                  class="w-full h-full object-cover group-hover:scale-[1.03] transition-transform duration-500"
                />
              </div>
              <div class="p-6">
                {post.data.category && (
                  <span class="font-montserrat text-xs font-semibold uppercase tracking-[0.15em] text-teal mb-3 block">
                    {post.data.category}
                  </span>
                )}
                <h3 class="font-fraunces text-dark text-xl leading-[1.2] tracking-[-0.02em] mb-3 group-hover:text-teal transition-colors duration-300 line-clamp-2">
                  {post.data.title}
                </h3>
                <p class="font-inter text-dark/50 text-sm leading-[1.6] mb-4 line-clamp-2">
                  {post.data.excerpt}
                </p>
                <div class="flex items-center gap-3">
                  <span class="font-inter text-dark/40 text-xs">{post.data.author}</span>
                  <span class="text-dark/20">·</span>
                  <span class="font-inter text-dark/40 text-xs">
                    {new Date(post.data.date).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' })}
                  </span>
                </div>
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>

  </main>
  <div class="bg-cream px-[10px] pb-[10px]">
    <div class="bg-[#EAE4DD] rounded-[14px]">
      <Footer />
    </div>
  </div>
</Layout>

<script>
  const pills = document.querySelectorAll('.category-pill');
  const featured = document.querySelector('[data-category]') as HTMLElement;
  const cards = document.querySelectorAll('.blog-card') as NodeListOf<HTMLElement>;

  pills.forEach(pill => {
    pill.addEventListener('click', () => {
      const cat = pill.getAttribute('data-category');

      pills.forEach(p => {
        p.classList.remove('bg-dark', 'text-cream');
        p.classList.add('bg-dark/5', 'text-dark/60');
      });
      pill.classList.remove('bg-dark/5', 'text-dark/60');
      pill.classList.add('bg-dark', 'text-cream');

      cards.forEach(card => {
        if (cat === 'All' || card.getAttribute('data-category') === cat) {
          card.style.display = '';
        } else {
          card.style.display = 'none';
        }
      });
    });
  });
</script>
