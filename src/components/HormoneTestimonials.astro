---
const testimonials = [
  {
    quote: "For years, I told doctors I just didn't feel 'right.' NimCore® was the first place that didn't just listen — they investigated. Seeing the data and finally understanding the 'why' behind my symptoms was a complete turning point.",
    name: 'Alex T.',
    detail: 'Age 42',
  },
  {
    quote: "I was exhausted all the time and my doctor kept saying my labs were 'normal.' NimCore® ran a full panel and found what everyone else missed. Three months in, I feel like a completely different person.",
    name: 'Sarah M.',
    detail: 'Age 38',
  },
  {
    quote: "The combination of real clinical oversight and access to compounded medications changed everything for me. No more guessing, no more generic advice — just a plan built around my actual data.",
    name: 'James R.',
    detail: 'Age 51',
  },
  {
    quote: "After menopause hit, I thought feeling this way was just my new normal. NimCore® showed me it didn't have to be. My energy is back, my sleep is better, and I finally feel like myself again.",
    name: 'Michelle K.',
    detail: 'Age 47',
  },
  {
    quote: "I've tried other hormone clinics before but they all felt like a 15-minute conveyor belt. NimCore® actually tracks my progress every 90 days and adjusts my protocol based on real results.",
    name: 'David L.',
    detail: 'Age 44',
  },
];
---

<section class="pt-6" id="hormone-testimonials">
  <div class="py-24">
    <div class="max-w-[900px] mx-auto text-center px-10" data-animate>

      <!-- Quote -->
      <blockquote class="font-fraunces text-cream text-[clamp(24px,3vw,40px)] leading-[1.35] font-normal mb-12" id="testimonial-quote">
        {testimonials[0].quote}
      </blockquote>

      <!-- Attribution -->
      <p class="font-fraunces text-cream text-2xl font-semibold mb-1" id="testimonial-name">
        {testimonials[0].name}
      </p>
      <p class="font-inter text-cream/40 text-sm" id="testimonial-detail">
        {testimonials[0].detail}
      </p>

      <!-- Navigation -->
      <div class="flex items-center justify-center gap-6 mt-14">
        <!-- Prev -->
        <button
          id="testimonial-prev"
          class="w-12 h-12 rounded-full border border-cream/20 flex items-center justify-center text-cream/40 hover:text-cream hover:border-cream/40 transition-colors cursor-pointer"
          aria-label="Previous testimonial"
        >
          <svg class="w-5 h-5" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
            <path d="M12.5 15L7.5 10L12.5 5" />
          </svg>
        </button>

        <!-- Dots -->
        <div class="flex items-center gap-2" id="testimonial-dots">
          {testimonials.map((_, i) => (
            <button
              class={`w-2 h-2 rounded-full transition-all duration-300 cursor-pointer ${i === 0 ? 'bg-cream w-2.5 h-2.5' : 'bg-cream/30'}`}
              data-index={i}
              aria-label={`Go to testimonial ${i + 1}`}
            />
          ))}
        </div>

        <!-- Next -->
        <button
          id="testimonial-next"
          class="w-12 h-12 rounded-full border border-cream/20 flex items-center justify-center text-cream/40 hover:text-cream hover:border-cream/40 transition-colors cursor-pointer"
          aria-label="Next testimonial"
        >
          <svg class="w-5 h-5" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
            <path d="M7.5 5L12.5 10L7.5 15" />
          </svg>
        </button>
      </div>

    </div>
  </div>
</section>

<script>
  const testimonials = [
    {
      quote: "For years, I told doctors I just didn't feel 'right.' NimCore® was the first place that didn't just listen — they investigated. Seeing the data and finally understanding the 'why' behind my symptoms was a complete turning point.",
      name: 'Alex T.',
      detail: 'Age 42',
    },
    {
      quote: "I was exhausted all the time and my doctor kept saying my labs were 'normal.' NimCore® ran a full panel and found what everyone else missed. Three months in, I feel like a completely different person.",
      name: 'Sarah M.',
      detail: 'Age 38',
    },
    {
      quote: "The combination of real clinical oversight and access to compounded medications changed everything for me. No more guessing, no more generic advice — just a plan built around my actual data.",
      name: 'James R.',
      detail: 'Age 51',
    },
    {
      quote: "After menopause hit, I thought feeling this way was just my new normal. NimCore® showed me it didn't have to be. My energy is back, my sleep is better, and I finally feel like myself again.",
      name: 'Michelle K.',
      detail: 'Age 47',
    },
    {
      quote: "I've tried other hormone clinics before but they all felt like a 15-minute conveyor belt. NimCore® actually tracks my progress every 90 days and adjusts my protocol based on real results.",
      name: 'David L.',
      detail: 'Age 44',
    },
  ];

  let current = 0;

  const quoteEl = document.getElementById('testimonial-quote');
  const nameEl = document.getElementById('testimonial-name');
  const detailEl = document.getElementById('testimonial-detail');
  const dotsContainer = document.getElementById('testimonial-dots');
  const prevBtn = document.getElementById('testimonial-prev');
  const nextBtn = document.getElementById('testimonial-next');

  function goTo(index: number) {
    // Fade out
    if (quoteEl && nameEl && detailEl) {
      quoteEl.style.transition = 'opacity 0.3s ease';
      nameEl.style.transition = 'opacity 0.3s ease';
      detailEl.style.transition = 'opacity 0.3s ease';
      quoteEl.style.opacity = '0';
      nameEl.style.opacity = '0';
      detailEl.style.opacity = '0';

      setTimeout(() => {
        current = index;
        const t = testimonials[current];
        quoteEl.textContent = t.quote;
        nameEl.textContent = t.name;
        detailEl.textContent = t.detail;

        // Update dots
        dotsContainer?.querySelectorAll('button').forEach((dot, i) => {
          if (i === current) {
            dot.classList.add('bg-cream', 'w-2.5', 'h-2.5');
            dot.classList.remove('bg-cream/30');
          } else {
            dot.classList.remove('bg-cream', 'w-2.5', 'h-2.5');
            dot.classList.add('bg-cream/30');
          }
        });

        // Fade in
        quoteEl.style.opacity = '1';
        nameEl.style.opacity = '1';
        detailEl.style.opacity = '1';
      }, 300);
    }
  }

  prevBtn?.addEventListener('click', () => {
    goTo(current === 0 ? testimonials.length - 1 : current - 1);
  });

  nextBtn?.addEventListener('click', () => {
    goTo(current === testimonials.length - 1 ? 0 : current + 1);
  });

  dotsContainer?.querySelectorAll('button').forEach(dot => {
    dot.addEventListener('click', () => {
      const idx = Number((dot as HTMLElement).dataset.index);
      if (idx !== current) goTo(idx);
    });
  });
</script>
