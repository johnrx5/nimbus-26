---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="Nimbus Healthcare - Patient Login">
  <Navbar />
  <main>
    <section class="min-h-screen bg-dark flex items-center justify-center pt-[120px] pb-20 px-5">
      <div class="w-full max-w-[480px] mx-auto text-center">
        <!-- Heading -->
        <h1 class="font-fraunces text-cream text-[40px] md:text-[48px] leading-[1.1] mb-10">Patient Login</h1>

        <!-- Form -->
        <form id="login-form" class="flex flex-col gap-4" onsubmit="window.location.href='/price-change'; return false;">
          <input
            type="email"
            placeholder="Email"
            class="login-input"
            required
          />
          <input
            type="password"
            placeholder="Password"
            class="login-input"
          />
          <div class="text-right">
            <a href="#" class="font-inter text-cream/70 text-sm underline hover:text-cream transition-colors">Forgot Password</a>
          </div>

          <button type="submit" class="w-full bg-terracotta hover:bg-terracotta-hover text-cream font-montserrat font-semibold text-base rounded-full py-4 mt-2 transition-colors cursor-pointer">
            Login
          </button>
        </form>

        <!-- Divider -->
        <div class="flex items-center gap-4 my-6">
          <div class="flex-1 h-px bg-cream/10"></div>
          <span class="font-inter text-cream/30 text-xs uppercase tracking-wider">or</span>
          <div class="flex-1 h-px bg-cream/10"></div>
        </div>

        <!-- Social Logins -->
        <div class="flex flex-col gap-3">
          <button class="social-btn">
            <svg class="w-5 h-5" viewBox="0 0 24 24" fill="none">
              <path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92a5.06 5.06 0 0 1-2.2 3.32v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.1z" fill="#4285F4"/>
              <path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"/>
              <path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z" fill="#FBBC05"/>
              <path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335"/>
            </svg>
            <span>Continue with Google</span>
          </button>
          <button class="social-btn">
            <svg class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor">
              <path d="M17.05 20.28c-.98.95-2.05.88-3.08.4-1.09-.5-2.08-.48-3.24 0-1.44.62-2.2.44-3.06-.4C2.79 15.25 3.51 7.59 9.05 7.31c1.35.07 2.29.74 3.08.8 1.18-.24 2.31-.93 3.57-.84 1.51.12 2.65.72 3.4 1.8-3.12 1.87-2.38 5.98.48 7.13-.57 1.5-1.31 2.99-2.54 4.09zM12.03 7.25c-.15-2.23 1.66-4.07 3.74-4.25.32 2.32-2.12 4.53-3.74 4.25z"/>
            </svg>
            <span>Continue with Apple</span>
          </button>
        </div>

        <!-- Create Account -->
        <p class="font-inter text-cream/50 text-sm mt-8">
          New here? <a href="/get-started" class="text-cream underline hover:text-cream/80 transition-colors">Create account</a>
        </p>
      </div>
    </section>
  </main>
  <div class="bg-[#1A1816] pb-[10px] px-[10px]">
    <Footer />
  </div>
</Layout>

<style>
  .login-input {
    width: 100%;
    font-family: 'Inter', sans-serif;
    font-size: 16px;
    color: #F5F0EA;
    background: rgba(245, 240, 234, 0.06);
    border: 1px solid rgba(245, 240, 234, 0.1);
    border-radius: 14px;
    padding: 18px 24px;
    outline: none;
    transition: border-color 0.2s ease;
  }
  .login-input::placeholder {
    color: rgba(245, 240, 234, 0.35);
  }
  .login-input:focus {
    border-color: rgba(245, 240, 234, 0.25);
  }

  .social-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 12px;
    width: 100%;
    font-family: 'Inter', sans-serif;
    font-size: 16px;
    font-weight: 500;
    color: #1A1816;
    background: #F5F0EA;
    border: none;
    border-radius: 9999px;
    padding: 16px 24px;
    cursor: pointer;
    transition: opacity 0.2s ease;
  }
  .social-btn:hover {
    opacity: 0.9;
  }
</style>
