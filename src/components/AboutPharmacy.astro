---
const pharmacists = [
  {
    initials: 'RK',
    name: 'Rachel Kuretich, PharmD',
    title: 'Pharmacy Manager & Clinical Lead',
    focus: 'USP compliance, sterile compounding, workflow optimization',
  },
  {
    initials: 'DA',
    name: 'Daniel Alonso, PharmD',
    title: 'Clinical Pharmacist & Provider Liaison',
    focus: 'Pharmacy licensure, clinical protocols, operational compliance',
  },
  {
    initials: 'CG',
    name: 'Christina Gunter, PharmD',
    title: 'Pharmacist & Compliance Lead',
    focus: 'Patient engagement, clinical consultations, therapeutic adherence',
  },
  {
    initials: 'PG',
    name: 'Patrick Gurley, PharmD, MS',
    title: 'Wellness & Innovation Specialist',
    focus: 'Peptide formulations, custom compounding, product development',
  },
  {
    initials: 'GM',
    name: 'Gyu-Hee Min, PharmD',
    title: 'Pharmacist & Quality Assurance Officer',
    focus: 'Quality assurance, internal audits, sterility testing',
  },
];
---

<section id="pharmacy-team" class="bg-[#1A1816] py-24 px-[10px]">
  <div class="max-w-[1200px] mx-auto">
    <!-- Header -->
    <div class="mb-16" data-animate>
      <div class="flex items-center gap-3 mb-4">
        <span class="font-montserrat text-teal text-sm font-semibold tracking-[0.15em] uppercase">Pharmacy Committee</span>
        <div class="w-12 h-[2px] bg-teal"></div>
      </div>
      <h2 class="font-fraunces text-cream text-[clamp(32px,4vw,56px)] leading-[1.1] tracking-[-0.02em] mb-4">
        The experts behind every <em class="text-teal not-italic italic">formulation.</em>
      </h2>
      <p class="font-inter text-cream/50 text-base leading-[1.6] max-w-[700px]">
        Our Pharmacy Committee ensures that every formulation meets the highest clinical and regulatory standards, while advancing the role of pharmacy in personalized medicine.
      </p>
    </div>

    <!-- Pharmacist Grid -->
    <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-5 gap-5" data-stagger>
      {pharmacists.map(p => (
        <div class="bg-[#22201E] rounded-2xl p-6 text-center">
          <!-- Initials Avatar -->
          <div class="w-16 h-16 rounded-full bg-[#1A1816] flex items-center justify-center mx-auto mb-4">
            <span class="font-fraunces text-teal text-xl font-bold">{p.initials}</span>
          </div>
          <h4 class="font-inter text-cream text-sm font-semibold leading-[1.3] mb-1">{p.name}</h4>
          <p class="font-inter text-cream/40 text-xs leading-[1.5] mb-4">{p.title}</p>
          <div class="border-t border-white/10 pt-3">
            <span class="font-inter text-teal/70 text-xs leading-[1.5]">{p.focus}</span>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
