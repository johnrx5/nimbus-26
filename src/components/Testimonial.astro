---

<section class="bg-cream py-24 px-[10px]">
  <div class="max-w-[900px] mx-auto text-center">
    <!-- Decorative quote mark -->
    <span class="font-fraunces text-terracotta text-[120px] leading-none block -mb-8" data-animate="fade-in">&ldquo;</span>

    <blockquote class="font-fraunces text-dark text-[clamp(24px,2.8vw,36px)] leading-[1.35] font-normal mb-10" data-animate>
      My mind and body feel back in rhythm. Life feels lighter, and my days are easier to manage. Less mental noise, more time actually living.
    </blockquote>

    <div class="flex items-center justify-center gap-3 mb-16" data-animate data-delay="1">
      <p class="font-fraunces text-dark text-xl font-semibold">Anne</p>
    </div>

    <div class="border-t border-dark/10 pt-8 flex items-center justify-center gap-12" data-animate data-delay="2">
      <div class="font-inter text-dark text-base">
        <span class="font-bold text-teal">5,000+</span> patients served
      </div>
      <div class="font-inter text-dark text-base">
        <span class="font-bold text-teal">25,000+</span> prescriptions filled
      </div>
    </div>
  </div>
</section>
