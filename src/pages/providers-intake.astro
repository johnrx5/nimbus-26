<script>
  // Provider Intake JavaScript
  const TOTAL_STEPS = 10;
  let currentStep = 1;
  let clinicModel = ''; // 'direct', 'guided', or 'hybrid'

  // Agreement text for each clinic model
  const agreements = {
    guided: {
      title: 'Guided Clinic Program Agreement',
      content: `
        <p class="text-cream/40 text-xs uppercase tracking-wide font-semibold">NIMBUS PROVIDERS — GUIDED CLINIC PROGRAM AGREEMENT</p>
        <p>This Program Acknowledgement ("Agreement") governs the relationship between the undersigned clinic ("Clinic") and Nimbus Healthcare, Inc. ("Nimbus") for participation in the Nimbus Providers Guided Clinic Program.</p>
        <p><strong class="text-cream/70 intake-heading">1. PROGRAM STRUCTURE</strong></p>
        <p>The Clinic participates as a Guided clinic on the Nimbus Providers platform. Under this model:</p>
        <p class="pl-4">a. The Clinic does not employ or contract with prescribers for the purpose of Nimbus program orders. All prescribing decisions are made independently by Nimbus-affiliated licensed healthcare providers ("Nimbus Providers").</p>
        <p class="pl-4">b. The Clinic's role is limited to patient education, program presentation, intake facilitation, and follow-up coordination — collectively referred to as "Facilitation Services."</p>
        <p class="pl-4">c. Patients select from program options at published program prices. The Clinic does not recommend, suggest, or direct specific medications or treatment protocols.</p>
        <p><strong class="text-cream/70 intake-heading">2. COMPLIANCE</strong></p>
        <p>Provider agrees to comply with all applicable federal and state regulations regarding the prescribing and dispensing of compounded medications.</p>
        <p><strong class="text-cream/70 intake-heading">3. PATIENT SAFETY</strong></p>
        <p>Provider acknowledges responsibility for clinical decision-making and patient safety within their scope of practice.</p>
        <p><strong class="text-cream/70 intake-heading">4. CONFIDENTIALITY</strong></p>
        <p>Both parties agree to maintain the confidentiality of patient information in accordance with HIPAA regulations.</p>
        <p><strong class="text-cream/70 intake-heading">5. FEES & BILLING</strong></p>
        <p>Provider agrees to the fee schedule outlined during onboarding. Nimbus reserves the right to update pricing with 30 days notice.</p>
        <p><strong class="text-cream/70 intake-heading">6. TERM & TERMINATION</strong></p>
        <p>This agreement remains in effect until terminated by either party with 30 days written notice.</p>
      `
    },
    direct: {
      title: 'Direct Clinic Program Agreement',
      content: `
        <p class="text-cream/40 text-xs uppercase tracking-wide font-semibold">NIMBUS PROVIDERS — DIRECT CLINIC PROGRAM AGREEMENT</p>
        <p>This Program Acknowledgement ("Agreement") governs the relationship between the undersigned clinic ("Clinic") and Nimbus Healthcare, Inc. ("Nimbus") for participation in the Nimbus Providers Direct Clinic Program.</p>
        <p><strong class="text-cream/70 intake-heading">1. PROGRAM STRUCTURE</strong></p>
        <p>The Clinic participates as a Direct clinic on the Nimbus Providers platform. Under this model:</p>
        <p class="pl-4">a. The Clinic employs or contracts with its own licensed healthcare providers who are responsible for all prescribing decisions.</p>
        <p class="pl-4">b. The Clinic maintains full clinical and legal responsibility for patient care, including diagnosis, treatment selection, and ongoing monitoring.</p>
        <p class="pl-4">c. Nimbus provides platform access, pharmacy fulfillment, and operational support but does not provide clinical oversight or prescribing services.</p>
        <p><strong class="text-cream/70 intake-heading">2. COMPLIANCE</strong></p>
        <p>Clinic agrees to comply with all applicable federal and state regulations regarding the prescribing and dispensing of compounded medications.</p>
        <p><strong class="text-cream/70 intake-heading">3. CLINICAL RESPONSIBILITY</strong></p>
        <p>Clinic acknowledges sole responsibility for all clinical decision-making, patient safety, and medical malpractice liability.</p>
        <p><strong class="text-cream/70 intake-heading">4. CONFIDENTIALITY</strong></p>
        <p>Both parties agree to maintain the confidentiality of patient information in accordance with HIPAA regulations.</p>
        <p><strong class="text-cream/70 intake-heading">5. FEES & BILLING</strong></p>
        <p>Clinic agrees to the platform fee schedule outlined during onboarding. Nimbus reserves the right to update pricing with 30 days notice.</p>
        <p><strong class="text-cream/70 intake-heading">6. TERM & TERMINATION</strong></p>
        <p>This agreement remains in effect until terminated by either party with 30 days written notice.</p>
      `
    },
    hybrid: {
      title: 'Hybrid Clinic Program Agreement',
      content: `
        <p class="text-cream/40 text-xs uppercase tracking-wide font-semibold">NIMBUS PROVIDERS — HYBRID CLINIC PROGRAM AGREEMENT</p>
        <p>This Program Acknowledgement ("Agreement") governs the relationship between the undersigned clinic ("Clinic") and Nimbus Healthcare, Inc. ("Nimbus") for participation in the Nimbus Providers Hybrid Clinic Program.</p>
        <p><strong class="text-cream/70 intake-heading">1. PROGRAM STRUCTURE</strong></p>
        <p>The Clinic participates as a Hybrid clinic on the Nimbus Providers platform. Under this model:</p>
        <p class="pl-4">a. The Clinic may utilize both in-house prescribers and Nimbus-affiliated providers depending on patient needs and clinic capacity.</p>
        <p class="pl-4">b. For patients seen by clinic prescribers, the Clinic maintains full clinical and legal responsibility. For patients seen by Nimbus providers, Nimbus assumes prescribing responsibility.</p>
        <p class="pl-4">c. The Clinic and Nimbus will coordinate to ensure clear assignment of clinical responsibility for each patient encounter.</p>
        <p><strong class="text-cream/70 intake-heading">2. COMPLIANCE</strong></p>
        <p>Both parties agree to comply with all applicable federal and state regulations regarding the prescribing and dispensing of compounded medications.</p>
        <p><strong class="text-cream/70 intake-heading">3. CLINICAL RESPONSIBILITY</strong></p>
        <p>Clinical responsibility is determined on a per-patient basis. Clear documentation of the responsible provider is required for each encounter.</p>
        <p><strong class="text-cream/70 intake-heading">4. CONFIDENTIALITY</strong></p>
        <p>Both parties agree to maintain the confidentiality of patient information in accordance with HIPAA regulations.</p>
        <p><strong class="text-cream/70 intake-heading">5. FEES & BILLING</strong></p>
        <p>Hybrid clinics are billed based on actual services rendered. Fee schedule outlined during onboarding applies. Nimbus reserves the right to update pricing with 30 days notice.</p>
        <p><strong class="text-cream/70 intake-heading">6. TERM & TERMINATION</strong></p>
        <p>This agreement remains in effect until terminated by either party with 30 days written notice.</p>
      `
    }
  };

  // Update progress bar
  function updateProgress() {
    const percentage = (currentStep / TOTAL_STEPS) * 100;
    const progressBar = document.getElementById('progress-bar');
    const counter = document.getElementById('intake-counter');
    if (progressBar) progressBar.style.width = `${percentage}%`;
    if (counter) counter.textContent = `${Math.round(percentage)}%`;
  }

  // Go to a specific step with transition
  function goToStep(step) {
    if (step < 1 || step > TOTAL_STEPS) return;

    const currentActive = document.getElementById(`step-${currentStep}-active`);
    const currentCollapsed = document.getElementById(`step-${currentStep}-collapsed`);

    if (currentActive) {
      currentActive.classList.add('step-exit');
      setTimeout(() => {
        currentActive.classList.add('hidden');
        currentActive.classList.remove('step-exit');
      }, 150);
    }

    if (step > currentStep && currentCollapsed) {
      setTimeout(() => {
        currentCollapsed.classList.remove('hidden');
        currentCollapsed.classList.add('collapsed-enter');
        setTimeout(() => currentCollapsed.classList.add('collapsed-visible'), 10);
      }, 150);
    }

    currentStep = step;
    updateProgress();

    setTimeout(() => {
      const newActive = document.getElementById(`step-${step}-active`);
      if (newActive) {
        newActive.classList.remove('hidden');
        newActive.classList.add('step-enter');
        setTimeout(() => {
          newActive.classList.remove('step-enter');
          newActive.classList.add('step-visible');
        }, 10);
      }

      const newCollapsed = document.getElementById(`step-${step}-collapsed`);
      if (newCollapsed && !newCollapsed.classList.contains('hidden')) {
        newCollapsed.classList.add('hidden');
        newCollapsed.classList.remove('collapsed-enter', 'collapsed-visible');
      }

      document.getElementById('intake-content')?.scrollTo({ top: 0, behavior: 'smooth' });
    }, 200);
  }

  // Back button handler
  document.getElementById('intake-back')?.addEventListener('click', () => {
    if (currentStep === 1) {
      document.getElementById('exit-modal')?.classList.remove('hidden');
      document.getElementById('exit-modal')?.classList.add('flex');
    } else {
      goToStep(currentStep - 1);
    }
  });

  // Exit modal handlers
  document.getElementById('exit-modal-stay')?.addEventListener('click', () => {
    document.getElementById('exit-modal')?.classList.add('hidden');
    document.getElementById('exit-modal')?.classList.remove('flex');
  });

  document.getElementById('exit-modal-leave')?.addEventListener('click', () => {
    window.location.href = '/providers';
  });

  document.getElementById('exit-modal-overlay')?.addEventListener('click', () => {
    document.getElementById('exit-modal')?.classList.add('hidden');
    document.getElementById('exit-modal')?.classList.remove('flex');
  });

  // Theme toggle
  document.getElementById('theme-toggle')?.addEventListener('click', () => {
    const app = document.getElementById('intake-app');
    const logoWhite = document.getElementById('logo-white');
    const logoBlack = document.getElementById('logo-black');
    const iconSun = document.getElementById('icon-sun');
    const iconMoon = document.getElementById('icon-moon');

    app?.classList.toggle('light-mode');
    logoWhite?.classList.toggle('hidden');
    logoBlack?.classList.toggle('hidden');
    iconSun?.classList.toggle('hidden');
    iconMoon?.classList.toggle('hidden');
  });

  // Step 1: Clinical setup option selection
  document.querySelectorAll('#clinical-setup-options .option-btn').forEach(btn => {
    btn.addEventListener('click', function() {
      document.querySelectorAll('#clinical-setup-options .option-btn').forEach(b => b.classList.remove('selected'));
      this.classList.add('selected');
      clinicModel = this.dataset.value || '';
      
      const answer = document.getElementById('step-1-answer');
      if (answer) {
        if (clinicModel === 'direct') answer.textContent = 'In-house prescribers';
        else if (clinicModel === 'guided') answer.textContent = 'Nimbus oversight';
        else if (clinicModel === 'hybrid') answer.textContent = 'Hybrid model';
      }

      setTimeout(() => goToStep(2), 300);
    });
  });

  // Step 2: Clinic info continue
  document.getElementById('step-2-continue')?.addEventListener('click', () => {
    const clinicName = (document.getElementById('clinic-name') as HTMLInputElement)?.value;
    const answer = document.getElementById('step-2-answer');
    if (answer && clinicName) answer.textContent = clinicName;
    goToStep(3);
  });

  // Step 3: Address continue
  document.getElementById('step-3-continue')?.addEventListener('click', () => {
    const city = (document.getElementById('addr-city') as HTMLInputElement)?.value;
    const state = (document.getElementById('addr-state') as HTMLSelectElement)?.value;
    const answer = document.getElementById('step-3-answer');
    if (answer && city && state) answer.textContent = `${city}, ${state}`;
    goToStep(4);
  });

  // Step 4: Contact continue
  document.getElementById('step-4-continue')?.addEventListener('click', () => {
    const email = (document.getElementById('contact-email') as HTMLInputElement)?.value;
    const answer = document.getElementById('step-4-answer');
    if (answer && email) answer.textContent = email;
    goToStep(5);
  });

  // Step 5: Admin account continue
  document.getElementById('step-5-continue')?.addEventListener('click', () => {
    const firstName = (document.getElementById('admin-first') as HTMLInputElement)?.value;
    const lastName = (document.getElementById('admin-last') as HTMLInputElement)?.value;
    const answer = document.getElementById('step-5-answer');
    if (answer && firstName && lastName) answer.textContent = `${firstName} ${lastName}`;
    goToStep(6);
  });

  // Password visibility toggles
  document.querySelectorAll('.pw-toggle').forEach(btn => {
    btn.addEventListener('click', function() {
      const targetId = this.dataset.target || '';
      const input = document.getElementById(targetId) as HTMLInputElement;
      if (input) {
        input.type = input.type === 'password' ? 'text' : 'password';
      }
    });
  });

  // Step 6: Agreement scroll detection
  const agreementScroll = document.getElementById('agreement-scroll');
  const agreementBtn = document.getElementById('agreement-acknowledge-btn');
  const scrollHint = document.getElementById('scroll-hint');
  const step6Continue = document.getElementById('step-6-continue');

  // Update agreement content when entering step 6
  function updateAgreementContent() {
    const agreementTitle = document.getElementById('agreement-title');
    const agreementContent = document.getElementById('agreement-content');
    
    if (clinicModel && agreements[clinicModel]) {
      if (agreementTitle) agreementTitle.textContent = agreements[clinicModel].title;
      if (agreementContent) agreementContent.innerHTML = agreements[clinicModel].content;
    }
  }

  // Watch for when step 6 becomes active
  const observer = new MutationObserver(() => {
    const step6Active = document.getElementById('step-6-active');
    if (step6Active && !step6Active.classList.contains('hidden')) {
      updateAgreementContent();
    }
  });

  const step6Active = document.getElementById('step-6-active');
  if (step6Active) {
    observer.observe(step6Active, { attributes: true, attributeFilter: ['class'] });
  }

  agreementScroll?.addEventListener('scroll', () => {
    const scrolledToBottom = agreementScroll.scrollTop + agreementScroll.clientHeight >= agreementScroll.scrollHeight - 5;
    
    if (scrolledToBottom && agreementBtn) {
      agreementBtn.classList.remove('bg-teal/40', 'text-cream/50', 'cursor-not-allowed', 'pointer-events-none');
      agreementBtn.classList.add('bg-teal', 'hover:brightness-110', 'cursor-pointer');
      if (scrollHint) scrollHint.classList.add('hidden');
    }
  });

  agreementBtn?.addEventListener('click', () => {
    if (!agreementBtn.classList.contains('pointer-events-none')) {
      agreementBtn.classList.add('hidden');
      step6Continue?.classList.remove('hidden', 'opacity-40', 'pointer-events-none');
      step6Continue?.removeAttribute('disabled');
    }
  });

  step6Continue?.addEventListener('click', () => {
    goToStep(7);
  });

  // Step 7: Pricing accordion
  document.getElementById('pricing-toggle')?.addEventListener('click', () => {
    const details = document.getElementById('pricing-details');
    const chevron = document.getElementById('pricing-chevron');
    details?.classList.toggle('hidden');
    chevron?.classList.toggle('rotate-180');
  });

  // Step 7: Billing agreement checkbox
  let billingAgreed = false;
  document.getElementById('billing-agree-btn')?.addEventListener('click', () => {
    billingAgreed = !billingAgreed;
    const checkbox = document.querySelector('.billing-checkbox');
    const checkIcon = document.querySelector('.billing-check-icon');
    const continueBtn = document.getElementById('step-7-continue');

    if (billingAgreed) {
      checkbox?.classList.add('bg-teal/10', 'border-teal');
      checkIcon?.classList.remove('hidden');
      continueBtn?.classList.remove('opacity-40', 'pointer-events-none');
      continueBtn?.removeAttribute('disabled');
    } else {
      checkbox?.classList.remove('bg-teal/10', 'border-teal');
      checkIcon?.classList.add('hidden');
      continueBtn?.classList.add('opacity-40', 'pointer-events-none');
      continueBtn?.setAttribute('disabled', '');
    }
  });

  document.getElementById('step-7-continue')?.addEventListener('click', () => {
    const lastFour = (document.getElementById('card-number') as HTMLInputElement)?.value.slice(-4) || '••••';
    const answer = document.getElementById('step-7-answer');
    if (answer) answer.textContent = `Card ending ${lastFour}`;
    goToStep(8);
  });

  document.getElementById('step-7-skip')?.addEventListener('click', () => {
    const answer = document.getElementById('step-7-answer');
    if (answer) answer.textContent = 'Skipped';
    goToStep(8);
  });

  // Step 8: Stripe Connect
  document.getElementById('step-8-continue')?.addEventListener('click', () => {
    goToStep(9);
  });

  document.getElementById('step-8-skip')?.addEventListener('click', () => {
    const answer = document.getElementById('step-8-answer');
    if (answer) answer.textContent = 'Skipped';
    goToStep(9);
  });

  // Step 9: Populate review data
  function populateReview() {
    // Business type
    const reviewClinicModel = document.getElementById('review-clinic-model');
    const reviewModelDesc = document.getElementById('review-model-desc');
    if (clinicModel === 'direct') {
      if (reviewClinicModel) reviewClinicModel.textContent = 'Direct Clinic';
      if (reviewModelDesc) reviewModelDesc.textContent = 'In-house prescribers';
    } else if (clinicModel === 'guided') {
      if (reviewClinicModel) reviewClinicModel.textContent = 'Guided Clinic';
      if (reviewModelDesc) reviewModelDesc.textContent = 'Nimbus provides prescribers';
    } else if (clinicModel === 'hybrid') {
      if (reviewClinicModel) reviewClinicModel.textContent = 'Hybrid Clinic';
      if (reviewModelDesc) reviewModelDesc.textContent = 'Both in-house and Nimbus prescribers';
    }

    // Business details
    const clinicName = (document.getElementById('clinic-name') as HTMLInputElement)?.value;
    if (clinicName) {
      const reviewClinicName = document.getElementById('review-clinic-name');
      if (reviewClinicName) reviewClinicName.textContent = clinicName;
    }

    const addrLine1 = (document.getElementById('addr-line1') as HTMLInputElement)?.value;
    const city = (document.getElementById('addr-city') as HTMLInputElement)?.value;
    const state = (document.getElementById('addr-state') as HTMLSelectElement)?.value;
    const zip = (document.getElementById('addr-zip') as HTMLInputElement)?.value;
    if (addrLine1 && city && state && zip) {
      const reviewAddress = document.getElementById('review-address');
      if (reviewAddress) reviewAddress.innerHTML = `${addrLine1}<br>${city}, ${state} ${zip}`;
    }

    const phone = (document.getElementById('contact-phone') as HTMLInputElement)?.value;
    const email = (document.getElementById('contact-email') as HTMLInputElement)?.value;
    if (phone && email) {
      const reviewContact = document.getElementById('review-contact');
      if (reviewContact) reviewContact.textContent = email;
    }

    // Admin account
    const firstName = (document.getElementById('admin-first') as HTMLInputElement)?.value;
    const lastName = (document.getElementById('admin-last') as HTMLInputElement)?.value;
    const adminEmail = (document.getElementById('admin-email') as HTMLInputElement)?.value;
    if (firstName && lastName) {
      const reviewAdminName = document.getElementById('review-admin-name');
      if (reviewAdminName) reviewAdminName.textContent = `${firstName} ${lastName}`;
    }
    if (adminEmail) {
      const reviewAdminEmail = document.getElementById('review-admin-email');
      if (reviewAdminEmail) reviewAdminEmail.textContent = adminEmail;
    }
  }

  // Watch for step 9 becoming active
  const observerStep9 = new MutationObserver(() => {
    const step9Active = document.getElementById('step-9-active');
    if (step9Active && !step9Active.classList.contains('hidden')) {
      populateReview();
    }
  });

  const step9Active = document.getElementById('step-9-active');
  if (step9Active) {
    observerStep9.observe(step9Active, { attributes: true, attributeFilter: ['class'] });
  }

  document.getElementById('step-9-continue')?.addEventListener('click', () => {
    goToStep(10);
  });

  // Edit step buttons
  document.querySelectorAll('.edit-step-btn').forEach(btn => {
    btn.addEventListener('click', function() {
      const stepNum = parseInt(this.dataset.editStep || '0');
      if (stepNum > 0) goToStep(stepNum);
    });
  });

  // Initialize
  updateProgress();
</script>
</Layout>
