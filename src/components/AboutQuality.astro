---
const qualityPoints = [
  {
    title: 'Patient-specific preparation',
    description: 'Clinical review and pharmacy verification on every prescription, every time.',
  },
  {
    title: 'Process discipline',
    description: 'Designed to reduce errors and improve consistency across every step of care.',
  },
  {
    title: 'Quality assurance mindset',
    description: 'Applied from formulation to packaging—not as an afterthought, but as a standard.',
  },
  {
    title: 'Transparent communication',
    description: 'So expectations are clear and patients always know what to expect.',
  },
];
---

<section class="bg-[#1A1816] pt-10 pb-24 px-[10px]">
  <div class="max-w-[1200px] mx-auto">
    <!-- Heading -->
    <div class="mb-12" data-animate>
      <div class="flex items-center gap-3 mb-4">
        <span class="font-montserrat text-teal text-sm font-semibold tracking-[0.15em] uppercase">Quality & Safety</span>
        <div class="w-12 h-[2px] bg-teal"></div>
      </div>
      <h3 class="font-fraunces text-cream text-[clamp(32px,4vw,48px)] leading-[1.15] tracking-[-0.02em] max-w-[600px]">
        We treat safety and quality as part of the <em class="text-teal not-italic italic">product.</em>
      </h3>
    </div>

    <!-- 4-Column Grid -->
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-8" data-stagger>
      {qualityPoints.map(point => (
        <div class="border-t-2 border-teal/30 pt-6">
          <h4 class="font-inter text-cream text-base font-bold leading-[1.3] mb-3">
            {point.title}
          </h4>
          <p class="font-inter text-cream/40 text-sm leading-[1.6]">
            {point.description}
          </p>
        </div>
      ))}
    </div>
  </div>
</section>
