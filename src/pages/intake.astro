<script is:inline>
  (function() {
    var section = document.getElementById('intake-app');
    var counter = document.getElementById('intake-counter');
    var backBtn = document.getElementById('intake-back');
    var themeToggle = document.getElementById('theme-toggle');
    var iconSun = document.getElementById('icon-sun');
    var iconMoon = document.getElementById('icon-moon');
    var logoWhite = document.getElementById('logo-white');
    var logoBlack = document.getElementById('logo-black');

    var currentStep = 1;
    var totalQuestions = 18;
    var progressBar = document.getElementById('progress-bar');

    function updateProgress(step) {
      var pct = Math.round((step / totalQuestions) * 100);
      progressBar.style.width = pct + '%';
      counter.textContent = pct + '%';
    }

    // Restore saved theme
    var savedTheme = sessionStorage.getItem('intake_theme');
    if (savedTheme === 'light') applyLight();

    // Theme toggle
    themeToggle?.addEventListener('click', function() {
      if (section.classList.contains('light-mode')) {
        applyDark();
        sessionStorage.setItem('intake_theme', 'dark');
      } else {
        applyLight();
        sessionStorage.setItem('intake_theme', 'light');
      }
    });

    function applyLight() {
      section.classList.add('light-mode');
      iconSun.classList.add('hidden');
      iconMoon.classList.remove('hidden');
      logoWhite.classList.add('hidden');
      logoBlack.classList.remove('hidden');
    }
    function applyDark() {
      section.classList.remove('light-mode');
      iconSun.classList.remove('hidden');
      iconMoon.classList.add('hidden');
      logoWhite.classList.remove('hidden');
      logoBlack.classList.add('hidden');
    }

    // Back button
    backBtn?.addEventListener('click', function() {
      if (currentStep === 1) {
        window.location.href = '/get-started';
      } else if (currentStep >= 3) {
        showExitModal();
      } else {
        goToStep(currentStep - 1);
      }
    });

    // Exit modal
    var exitModal = document.getElementById('exit-modal');
    function showExitModal() {
      exitModal.classList.remove('hidden');
      exitModal.classList.add('flex');
    }
    function hideExitModal() {
      exitModal.classList.add('hidden');
      exitModal.classList.remove('flex');
    }
    document.getElementById('exit-modal-stay')?.addEventListener('click', hideExitModal);
    document.getElementById('exit-modal-overlay')?.addEventListener('click', hideExitModal);
    document.getElementById('exit-modal-leave')?.addEventListener('click', function() {
      window.location.href = '/get-started';
    });

    // Step navigation with transitions
    function goToStep(step) {
      var totalSteps = 5;

      // Exit current active step
      for (var i = 1; i <= totalSteps; i++) {
        var active = document.getElementById('step-' + i + '-active');
        var collapsed = document.getElementById('step-' + i + '-collapsed');
        if (active && !active.classList.contains('hidden')) {
          active.classList.remove('step-visible');
          active.classList.add('step-exit');
        }
        if (collapsed && !collapsed.classList.contains('hidden')) {
          collapsed.classList.add('hidden');
          collapsed.classList.remove('collapsed-visible', 'collapsed-enter');
        }
      }

      // After exit animation, show new state
      setTimeout(function() {
        for (var i = 1; i <= totalSteps; i++) {
          var active = document.getElementById('step-' + i + '-active');
          var collapsed = document.getElementById('step-' + i + '-collapsed');
          if (active) {
            active.classList.add('hidden');
            active.classList.remove('step-exit', 'step-enter', 'step-visible');
          }
          if (collapsed) {
            collapsed.classList.add('hidden');
            collapsed.classList.remove('collapsed-enter', 'collapsed-visible');
          }
        }

        // Show collapsed for completed steps
        for (var i = 1; i < step; i++) {
          var collapsed = document.getElementById('step-' + i + '-collapsed');
          if (collapsed) {
            collapsed.classList.remove('hidden');
            collapsed.classList.add('collapsed-enter');
            requestAnimationFrame(function(el) {
              return function() {
                requestAnimationFrame(function() {
                  el.classList.remove('collapsed-enter');
                  el.classList.add('collapsed-visible');
                });
              };
            }(collapsed));
          }
        }

        // Show active step with enter animation
        var activeEl = document.getElementById('step-' + step + '-active');
        if (activeEl) {
          activeEl.classList.remove('hidden');
          activeEl.classList.add('step-enter');
          requestAnimationFrame(function() {
            requestAnimationFrame(function() {
              activeEl.classList.remove('step-enter');
              activeEl.classList.add('step-visible');
            });
          });
        }

        currentStep = step;
        updateProgress(step);
        document.getElementById('intake-content').scrollTop = 0;
      }, 250);
    }

    // ===== STEP 1: State selection =====
    var stateButtons = document.querySelectorAll('.state-btn');
    stateButtons.forEach(function(btn) {
      btn.addEventListener('click', function() {
        stateButtons.forEach(function(b) { b.classList.remove('selected'); });
        btn.classList.add('selected');
        var state = btn.textContent.trim();
        sessionStorage.setItem('intake_state', state);
        document.getElementById('step-1-answer').textContent = state;

        // Advance to step 2 after brief delay
        setTimeout(function() { goToStep(2); }, 300);
      });
    });

    // Edit buttons — go back to that step
    document.querySelectorAll('.edit-step-btn').forEach(function(btn) {
      btn.addEventListener('click', function() {
        var step = parseInt(btn.getAttribute('data-edit-step'));
        goToStep(step);
      });
    });

    // ===== STEP 2: DOB + Sex =====
    // Auto-format DOB input
    var dobInput = document.getElementById('dob-input');
    dobInput?.addEventListener('input', function(e) {
      var val = dobInput.value.replace(/\D/g, '');
      if (val.length >= 4) {
        val = val.slice(0, 2) + '/' + val.slice(2, 4) + '/' + val.slice(4, 8);
      } else if (val.length >= 2) {
        val = val.slice(0, 2) + '/' + val.slice(2);
      }
      dobInput.value = val;
    });

    // Sex selection — advance to step 3
    var sexButtons = document.querySelectorAll('.sex-btn');
    sexButtons.forEach(function(btn) {
      btn.addEventListener('click', function() {
        sexButtons.forEach(function(b) { b.classList.remove('selected'); });
        btn.classList.add('selected');
        var sex = btn.getAttribute('data-value');
        sessionStorage.setItem('intake_sex', sex);

        // Update step 2 collapsed answer
        var dob = document.getElementById('dob-input').value || '';
        var answerText = dob + ' · ' + sex.toLowerCase();
        document.getElementById('step-2-answer').textContent = answerText;

        setTimeout(function() { goToStep(3); }, 300);
      });
    });

    // ===== STEP 3: Height + Weight Steppers =====
    var stepperLimits = {
      'height-ft': { min: 3, max: 8 },
      'height-in': { min: 0, max: 11 },
      'weight-lbs': { min: 50, max: 500 }
    };

    document.querySelectorAll('.stepper-btn').forEach(function(btn) {
      btn.addEventListener('click', function() {
        var targetId = btn.getAttribute('data-target');
        var dir = parseInt(btn.getAttribute('data-dir'));
        var el = document.getElementById(targetId);
        if (!el) return;
        var current = parseInt(el.textContent);
        var limits = stepperLimits[targetId];
        var next = current + dir;
        if (next < limits.min) next = limits.min;
        if (next > limits.max) next = limits.max;
        el.textContent = next;
      });
    });

    // Step 3 continue button
    var step3Continue = document.getElementById('step-3-continue');
    step3Continue?.addEventListener('click', function() {
      var ft = document.getElementById('height-ft').textContent;
      var inches = document.getElementById('height-in').textContent;
      var lbs = document.getElementById('weight-lbs').textContent;
      var heightStr = ft + "'" + inches + '"';
      sessionStorage.setItem('intake_height', heightStr);
      sessionStorage.setItem('intake_weight', lbs);
      document.getElementById('step-3-answer').textContent = heightStr + ' · ' + lbs + ' lbs';
      goToStep(4);
    });

    // ===== STEP 4: Goals (multi-select) =====
    var selectedGoals = [];
    var step4Continue = document.getElementById('step-4-continue');
    document.querySelectorAll('.goal-btn').forEach(function(btn) {
      btn.addEventListener('click', function() {
        btn.classList.toggle('selected');
        var val = btn.getAttribute('data-value');
        var idx = selectedGoals.indexOf(val);
        if (idx > -1) {
          selectedGoals.splice(idx, 1);
        } else {
          selectedGoals.push(val);
        }
        sessionStorage.setItem('intake_goals', JSON.stringify(selectedGoals));
        if (selectedGoals.length > 0) {
          step4Continue.classList.remove('hidden');
        } else {
          step4Continue.classList.add('hidden');
        }
      });
    });

    step4Continue?.addEventListener('click', function() {
      // Update step 4 collapsed answer
      var goalText = selectedGoals.join(', ');
      document.getElementById('step-4-answer').textContent = goalText;
      goToStep(5);
    });

    // ===== STEP 5: GLP-1 Experience (single-select) =====
    document.querySelectorAll('#glp1-options .option-btn').forEach(function(btn) {
      btn.addEventListener('click', function() {
        document.querySelectorAll('#glp1-options .option-btn').forEach(function(b) { b.classList.remove('selected'); });
        btn.classList.add('selected');
        sessionStorage.setItem('intake_glp1', btn.getAttribute('data-value'));
        // Future: setTimeout(function() { goToStep(6); }, 300);
      });
    });

  })();
</script>
