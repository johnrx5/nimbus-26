---
import photo1 from '../assets/[7] Photography/iStock-1337452483123123 1 (1).png';
import photo2 from '../assets/[7] Photography/iStock-2203624688.jpg';
import photo3 from '../assets/[7] Photography/iStock-2210163746.jpg';
import photo4 from '../assets/[7] Photography/iStock-1276569663.jpg';
import photo5 from '../assets/[7] Photography/iStock-1165116258.jpg';
import photo6 from '../assets/[7] Photography/iStock-1766905173.jpg';

const slides = [
  {
    image: photo1,
    title: 'It\'s biology, not willpower',
    description: 'By moving from shame to understanding, you can finally find the freedom you deserve.',
  },
  {
    image: photo2,
    title: 'Silencing the "food noise"',
    description: 'Our treatments help silence the intrusive thoughts, allowing you to reclaim your focus and your life.',
  },
  {
    image: photo3,
    title: 'The reset',
    description: 'We help you recalibrate your biological settings, so your body can finally find its balance.',
  },
  {
    image: photo4,
    title: 'Starting fresh',
    description: 'Change doesn\'t have to be complicated. Sometimes, it just takes the right guidance and the right tools.',
  },
  {
    image: photo5,
    title: 'Your body, your pace',
    description: 'Every journey is different. We meet you where you are and build a plan that works for your life.',
  },
  {
    image: photo6,
    title: 'Beyond the scale',
    description: 'Real progress isn\'t just a number. It\'s how you feel, how you move, and how you show up every day.',
  },
];
---

<section class="bg-cream pt-24 pb-20" data-animate>
  <!-- Header -->
  <div id="bio-header" class="max-w-[1200px] mx-auto px-[10px] mb-10">
    <div class="flex items-end justify-between">
      <div>
        <p class="font-inter text-terracotta text-base mb-3">Moving from struggle to science.</p>
        <h2 class="font-fraunces text-dark text-[clamp(40px,5vw,72px)] leading-[1.05] tracking-[-0.02em]">
          It's your biology.
        </h2>
      </div>
      <!-- Arrow Buttons -->
      <div class="flex items-center gap-2 pb-2">
        <button
          id="bio-prev"
          class="w-11 h-11 rounded-full border border-dark/20 flex items-center justify-center hover:bg-dark/5 transition-colors cursor-pointer"
          aria-label="Previous slide"
        >
          <svg width="18" height="18" viewBox="0 0 18 18" fill="none">
            <path d="M11 4L6 9l5 5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </button>
        <button
          id="bio-next"
          class="w-11 h-11 rounded-full border border-dark/20 flex items-center justify-center hover:bg-dark/5 transition-colors cursor-pointer"
          aria-label="Next slide"
        >
          <svg width="18" height="18" viewBox="0 0 18 18" fill="none">
            <path d="M7 4l5 5-5 5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </button>
      </div>
    </div>
  </div>

  <!-- Carousel (bleeds right) -->
  <div
    id="bio-carousel"
    class="flex gap-6 overflow-x-auto snap-x snap-mandatory pb-4"
    style="scrollbar-width: none;"
  >
    {slides.map(slide => (
      <div class="snap-start shrink-0 w-[500px]">
        <div class="rounded-2xl overflow-hidden mb-5">
          <img
            src={slide.image.src}
            alt={slide.title}
            class="w-[500px] h-[500px] object-cover"
            loading="lazy"
          />
        </div>
        <h3 class="font-inter text-dark text-lg font-bold mb-2 px-5">{slide.title}</h3>
        <p class="font-inter text-dark/60 text-sm leading-[1.6] px-5">{slide.description}</p>
      </div>
    ))}
  </div>

  <!-- CTA -->
  <div class="max-w-[1200px] mx-auto px-[10px] mt-10">
    <a href="/get-started" class="bg-terracotta hover:bg-terracotta-hover text-cream font-montserrat font-medium text-sm rounded-full px-8 py-4 inline-block transition-colors">
      Find your path
    </a>
  </div>
</section>

<style>
  #bio-carousel::-webkit-scrollbar {
    display: none;
  }
</style>

<script>
  const carousel = document.getElementById('bio-carousel');
  const header = document.getElementById('bio-header');
  const prevBtn = document.getElementById('bio-prev');
  const nextBtn = document.getElementById('bio-next');
  const cardWidth = 500 + 24; // card width + gap

  function alignCarousel() {
    if (header && carousel) {
      const left = header.getBoundingClientRect().left + 10; // +10 for px-[10px] padding
      carousel.style.paddingLeft = left + 'px';
    }
  }

  alignCarousel();
  window.addEventListener('resize', alignCarousel);

  prevBtn?.addEventListener('click', () => {
    carousel?.scrollBy({ left: -cardWidth, behavior: 'smooth' });
  });

  nextBtn?.addEventListener('click', () => {
    carousel?.scrollBy({ left: cardWidth, behavior: 'smooth' });
  });
</script>
