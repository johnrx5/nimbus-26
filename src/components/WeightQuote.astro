<section class="py-24 px-[10px]">
  <div class="max-w-[900px] mx-auto text-center">
    <!-- Decorative quote mark -->
    <span class="font-fraunces text-terracotta text-[120px] leading-none block -mb-8" data-animate="fade-in">&ldquo;</span>

    <blockquote class="font-fraunces text-dark text-[clamp(24px,2.8vw,36px)] leading-[1.35] font-normal mb-10" data-animate>
      I always thought you all were just stronger, that your willpower was greater... then I realized you weren't even thinking about food.
    </blockquote>

    <div class="flex items-center justify-center gap-3" data-animate data-delay="1">
      <p class="font-fraunces text-dark text-xl font-semibold">Oprah</p>
    </div>
  </div>
</section>
