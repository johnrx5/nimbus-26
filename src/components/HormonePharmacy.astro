---
const categories = [
  {
    title: 'Hormones',
    items: ['Testosterone', 'Bioidentical Estrogen/Progesterone', 'DHEA', 'hCG', 'Clomiphene'],
  },
  {
    title: 'Peptides',
    items: ['BPC-157', 'TB-500', 'Sermorelin', 'CJC/Ipamorelin', 'Dihexa', 'NAD+, Glutathione'],
  },
  {
    title: 'Performance & Metabolic',
    items: ['CarniSema', 'CarniTide (GLP-1 + L-Carnitine)', 'Anastrozole'],
  },
  {
    title: 'Sexual Health',
    items: ['Tadalafil', 'Bremelanotide (PT-141)', 'Oxytocin'],
  },
];
---

<section class="pt-6 px-[10px]">
  <div class="max-w-[1200px] mx-auto py-24">

    <!-- Video -->
    <div class="rounded-2xl overflow-hidden mb-16" data-animate>
      <video
        class="w-full h-auto"
        autoplay
        muted
        loop
        playsinline
      >
        <source src="/videos/Lab_v1.mp4" type="video/mp4" />
      </video>
    </div>

    <!-- Heading -->
    <h2 class="font-fraunces text-cream text-[clamp(32px,4vw,52px)] leading-[1.1] tracking-[-0.02em] mb-14" data-animate>
      NABP-accredited pharmacy.<br /><span class="text-teal">Premium</span> medications.
    </h2>

    <!-- 4-Column Medication Grid -->
    <div class="grid grid-cols-2 md:grid-cols-4 gap-10 mb-14" data-animate data-delay="1">
      {categories.map(cat => (
        <div>
          <h3 class="font-inter text-teal font-semibold text-sm mb-4">{cat.title}</h3>
          <ul class="flex flex-col gap-2">
            {cat.items.map(item => (
              <li class="font-inter text-cream/40 text-sm leading-[1.6]">{item}</li>
            ))}
          </ul>
        </div>
      ))}
    </div>

    <!-- Disclaimer -->
    <p class="font-inter text-cream/40 text-sm leading-[1.6] max-w-[460px]" data-animate data-delay="2">
      Your clinician will recommend what makes sense based on your labs and goals — never a one-size-fits-all approach.
    </p>

  </div>
</section>
