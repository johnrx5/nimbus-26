---
---

<section class="bg-[#1A1816] pt-24 pb-6 px-[10px]">
  <div class="max-w-[1200px] mx-auto">
    <div class="bg-[#22201E] rounded-3xl py-40 px-8 flex flex-col items-center justify-center text-center" data-animate="scale-in">
      <div class="flex items-center justify-center gap-3 mb-6">
        <div class="w-12 h-[2px] bg-teal"></div>
        <span class="font-montserrat text-teal text-sm font-semibold tracking-[0.15em] uppercase">Start Today</span>
        <div class="w-12 h-[2px] bg-teal"></div>
      </div>

      <h2 class="font-fraunces text-cream text-[clamp(48px,6vw,96px)] leading-[1] tracking-[-0.02em] mb-4">
        Ready for care that<br />feels <em class="text-teal not-italic italic">connected?</em>
      </h2>

      <p class="font-inter text-cream/50 text-base leading-[1.6] max-w-[500px] mb-10">
        Start your intake in minutes, and get a plan designed and verified by clinicians and pharmacists working as one team.
      </p>

      <div class="flex flex-col md:flex-row items-center gap-4">
        <a
          href="/get-started"
          class="bg-terracotta hover:bg-terracotta-hover text-cream font-montserrat font-medium text-base rounded-full px-10 py-4.5 transition-colors"
        >
          Get started
        </a>
        <a
          href="/contact"
          class="border border-cream/30 text-cream font-montserrat font-medium text-base rounded-full px-10 py-4.5 hover:bg-cream/10 transition-colors"
        >
          Contact us
        </a>
      </div>
    </div>
  </div>
</section>
