---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map(post => ({
    params: { slug: post.id.replace(/\.md$/, '') },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);

const allPosts = (await getCollection('blog')).sort(
  (a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime()
);
const currentIndex = allPosts.findIndex(p => p.id === post.id);
const related = allPosts.filter((p, i) => i !== currentIndex).slice(0, 3);
---

<Layout title={`${post.data.title} - Nimbus Healthcare`}>
  <Navbar />
  <main class="bg-cream">

    <!-- Back -->
    <div class="pt-28 px-6 md:px-10">
      <div class="max-w-[760px] mx-auto">
        <a href="/blog" class="inline-flex items-center gap-2 font-inter text-dark/40 text-sm hover:text-dark transition-colors">
          <svg class="w-4 h-4" viewBox="0 0 16 16" fill="none"><path d="M10 12L6 8l4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
          Back to Journal
        </a>
      </div>
    </div>

    <!-- Article Header -->
    <header class="pt-8 pb-10 px-6 md:px-10">
      <div class="max-w-[760px] mx-auto">
        {post.data.category && (
          <span class="font-montserrat text-xs font-semibold uppercase tracking-[0.15em] text-teal mb-4 block">
            {post.data.category}
          </span>
        )}
        <h1 class="font-fraunces text-dark text-[clamp(32px,4.5vw,52px)] leading-[1.1] tracking-[-0.02em] mb-6">
          {post.data.title}
        </h1>
        <div class="flex items-center gap-4 mb-10">
          <div class="w-10 h-10 rounded-full bg-dark/10 flex items-center justify-center">
            <span class="font-inter text-dark/50 text-sm font-medium">
              {post.data.author.split(' ').map((n: string) => n[0]).join('')}
            </span>
          </div>
          <div>
            <p class="font-inter text-dark text-sm font-medium">{post.data.author}</p>
            <p class="font-inter text-dark/40 text-xs">
              {new Date(post.data.date).toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' })}
            </p>
          </div>
        </div>
      </div>
    </header>

    <!-- Featured Image -->
    <div class="px-6 md:px-10 pb-12">
      <div class="max-w-[960px] mx-auto rounded-2xl overflow-hidden">
        <img src={post.data.image} alt={post.data.title} class="w-full h-auto object-cover" />
      </div>
    </div>

    <!-- Article Body -->
    <article class="px-6 md:px-10 pb-20">
      <div class="max-w-[760px] mx-auto prose-nimbus">
        <Content />
      </div>
    </article>

    <!-- Related Posts -->
    {related.length > 0 && (
      <section class="px-6 md:px-10 pb-24">
        <div class="max-w-[1200px] mx-auto">
          <div class="border-t border-dark/10 pt-16">
            <h2 class="font-fraunces text-dark text-2xl tracking-[-0.02em] mb-8">More from the Journal</h2>
            <div class="grid md:grid-cols-3 gap-6">
              {related.map(r => (
                <a href={`/blog/${r.id.replace(/\.md$/, '')}`} class="group block bg-white rounded-2xl overflow-hidden hover:-translate-y-1 hover:shadow-lg transition-all duration-300">
                  <div class="aspect-[16/10] overflow-hidden">
                    <img src={r.data.image} alt={r.data.title} class="w-full h-full object-cover group-hover:scale-[1.03] transition-transform duration-500" />
                  </div>
                  <div class="p-6">
                    {r.data.category && (
                      <span class="font-montserrat text-xs font-semibold uppercase tracking-[0.15em] text-teal mb-3 block">{r.data.category}</span>
                    )}
                    <h3 class="font-fraunces text-dark text-lg leading-[1.2] tracking-[-0.02em] group-hover:text-teal transition-colors duration-300 line-clamp-2">{r.data.title}</h3>
                  </div>
                </a>
              ))}
            </div>
          </div>
        </div>
      </section>
    )}

  </main>
  <div class="bg-cream px-[10px] pb-[10px]">
    <div class="bg-[#EAE4DD] rounded-[14px]">
      <Footer />
    </div>
  </div>
</Layout>

<style>
  .prose-nimbus :global(h2) {
    font-family: 'Fraunces', serif;
    font-size: clamp(24px, 3vw, 32px);
    line-height: 1.2;
    letter-spacing: -0.02em;
    color: #1A1816;
    margin-top: 2.5rem;
    margin-bottom: 1rem;
  }
  .prose-nimbus :global(h3) {
    font-family: 'Fraunces', serif;
    font-size: clamp(20px, 2.5vw, 24px);
    line-height: 1.3;
    letter-spacing: -0.02em;
    color: #1A1816;
    margin-top: 2rem;
    margin-bottom: 0.75rem;
  }
  .prose-nimbus :global(p) {
    font-family: 'Inter', sans-serif;
    font-size: 17px;
    line-height: 1.75;
    color: rgba(26, 24, 22, 0.7);
    margin-bottom: 1.25rem;
  }
  .prose-nimbus :global(strong) {
    color: #1A1816;
    font-weight: 600;
  }
  .prose-nimbus :global(em) {
    font-style: italic;
  }
  .prose-nimbus :global(ul), .prose-nimbus :global(ol) {
    font-family: 'Inter', sans-serif;
    font-size: 17px;
    line-height: 1.75;
    color: rgba(26, 24, 22, 0.7);
    margin-bottom: 1.25rem;
    padding-left: 1.5rem;
  }
  .prose-nimbus :global(li) {
    margin-bottom: 0.5rem;
  }
  .prose-nimbus :global(ul) {
    list-style-type: disc;
  }
  .prose-nimbus :global(ol) {
    list-style-type: decimal;
  }
  .prose-nimbus :global(blockquote) {
    border-left: 3px solid #2A9D8F;
    padding-left: 1.5rem;
    margin: 2rem 0;
    font-style: italic;
    color: rgba(26, 24, 22, 0.6);
  }
  .prose-nimbus :global(hr) {
    border: none;
    border-top: 1px solid rgba(26, 24, 22, 0.1);
    margin: 2.5rem 0;
  }
  .prose-nimbus :global(a) {
    color: #2A9D8F;
    text-decoration: underline;
    text-underline-offset: 2px;
  }
  .prose-nimbus :global(a:hover) {
    color: #1A1816;
  }
</style>
