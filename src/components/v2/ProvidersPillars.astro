---
---

<section class="bg-[#1A1816] py-24 px-[10px]">
  <div class="max-w-[1200px] mx-auto">
    <!-- Section Header -->
    <div class="text-center mb-6" data-animate>
      <p class="font-montserrat text-teal text-sm font-semibold tracking-[0.15em] uppercase mb-4">The Platform</p>
      <h2 class="font-fraunces text-cream text-[clamp(32px,4vw,56px)] leading-[1.08] tracking-[-0.02em]">
        One platform. Three pillars.<br />
        <em class="italic text-teal">Built for modern care.</em>
      </h2>
    </div>

    <div class="text-center max-w-[600px] mx-auto mb-16" data-animate data-delay="1">
      <p class="font-inter text-cream/50 text-base leading-[1.6]">
        NovaMed connects clinics, patients, and pharmacy into one end-to-end workflow. No integrations to manage. No gaps to fall through.
      </p>
    </div>

    <!-- Three Pillars -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6" data-stagger>
      <!-- For Clinics -->
      <div class="group bg-[#22201E] rounded-2xl border border-cream/5 overflow-hidden hover:border-teal/20 transition-colors">
        <div class="p-8">
          <div class="w-12 h-12 rounded-full bg-teal/10 flex items-center justify-center mb-5">
            <svg class="w-6 h-6 text-teal" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 21h16.5M4.5 3h15M5.25 3v18m13.5-18v18M9 6.75h1.5m-1.5 3h1.5m-1.5 3h1.5m3-6H15m-1.5 3H15m-1.5 3H15M9 21v-3.375c0-.621.504-1.125 1.125-1.125h3.75c.621 0 1.125.504 1.125 1.125V21" />
            </svg>
          </div>
          <p class="font-montserrat text-teal/60 text-xs font-semibold tracking-widest uppercase mb-2">For Clinics</p>
          <h3 class="font-fraunces text-cream text-2xl mb-3">NovaMed Platform</h3>
          <p class="font-inter text-cream/40 text-sm leading-[1.7] mb-6">
            The clinic-facing operating system for protocol-based care. Intake, prescribing, fulfillment, and patient management — all in one place.
          </p>
          <img
            src="/images/platform/03-programs.png"
            alt="NovaMed Program Management — 7 branded health programs"
            class="w-full rounded-lg border border-cream/5"
            loading="lazy"
          />
        </div>
      </div>

      <!-- For Patients -->
      <div class="group bg-[#22201E] rounded-2xl border border-cream/5 overflow-hidden hover:border-terracotta/20 transition-colors">
        <div class="p-8">
          <div class="w-12 h-12 rounded-full bg-terracotta/10 flex items-center justify-center mb-5">
            <svg class="w-6 h-6 text-terracotta" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 6a3.75 3.75 0 1 1-7.5 0 3.75 3.75 0 0 1 7.5 0ZM4.501 20.118a7.5 7.5 0 0 1 14.998 0A17.933 17.933 0 0 1 12 21.75c-2.676 0-5.216-.584-7.499-1.632Z" />
            </svg>
          </div>
          <p class="font-montserrat text-terracotta/60 text-xs font-semibold tracking-widest uppercase mb-2">For Patients</p>
          <h3 class="font-fraunces text-cream text-2xl mb-3">Patient Portal</h3>
          <p class="font-inter text-cream/40 text-sm leading-[1.7] mb-6">
            Patients see their protocol, track doses, get refill reminders, message their care team, and view lab trends — all in one place.
          </p>
          <div class="bg-[#1A1816] rounded-lg border border-cream/5 p-6 text-center">
            <p class="font-inter text-cream/20 text-sm">Patient app screenshots coming soon</p>
          </div>
        </div>
      </div>

      <!-- For Pharmacy -->
      <div class="group bg-[#22201E] rounded-2xl border border-cream/5 overflow-hidden hover:border-teal/20 transition-colors">
        <div class="p-8">
          <div class="w-12 h-12 rounded-full bg-teal/10 flex items-center justify-center mb-5">
            <svg class="w-6 h-6 text-teal" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9.75 3.104v5.714a2.25 2.25 0 0 1-.659 1.591L5 14.5M9.75 3.104c-.251.023-.501.05-.75.082m.75-.082a24.301 24.301 0 0 1 4.5 0m0 0v5.714c0 .597.237 1.17.659 1.591L19.8 15.3M14.25 3.104c.251.023.501.05.75.082M19.8 15.3l-1.57.393A9.065 9.065 0 0 1 12 15a9.065 9.065 0 0 0-6.23.693L5 14.5m14.8.8 1.402 1.402c1.232 1.232.65 3.318-1.067 3.611A48.309 48.309 0 0 1 12 21c-2.773 0-5.491-.235-8.135-.687-1.718-.293-2.3-2.379-1.067-3.61L5 14.5" />
            </svg>
          </div>
          <p class="font-montserrat text-teal/60 text-xs font-semibold tracking-widest uppercase mb-2">Our Pharmacy</p>
          <h3 class="font-fraunces text-cream text-2xl mb-3">Lake Hills Pharmacy</h3>
          <p class="font-inter text-cream/40 text-sm leading-[1.7] mb-6">
            We don't route to pharmacies — we ARE the pharmacy. NABP-accredited, 37 state licenses, 503A/503B compliant. End-to-end quality control.
          </p>
          <img
            src="/images/platform/04-formulary.png"
            alt="NovaMed Formulary — 131 compounds with real-time pricing"
            class="w-full rounded-lg border border-cream/5"
            loading="lazy"
          />
        </div>
      </div>
    </div>
  </div>
</section>
