---
import Layout from '../layouts/Layout.astro';
import logoWhite from '../assets/NB_br_Logo White/NB_br_Logo White_0325.png';
import logoBlack from '../assets/NB_br_Logo Black/NB_br_Logo Black_0325.png';
---

<Layout title="Nimbus Providers - Free Trial">
  <main>
    <section class="bg-[#1A1816] min-h-screen" id="trial-app">
      <!-- Sticky Top Bar -->
      <div class="px-6 shrink-0 trial-sticky-header">
        <div class="max-w-7xl mx-auto relative flex items-center justify-between py-5">
          <!-- Left: Back -->
          <div class="flex items-center gap-3">
            <a
              href="/providers"
              class="w-10 h-10 rounded-full border border-cream/15 flex items-center justify-center text-cream/50 hover:text-cream hover:border-cream/30 transition-colors cursor-pointer intake-back-btn"
              aria-label="Go back"
            >
              <svg width="18" height="18" viewBox="0 0 18 18" fill="none">
                <path d="M11 4L6 9l5 5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </a>
          </div>

          <!-- Center: Logo -->
          <div class="absolute left-1/2 -translate-x-1/2">
            <img src={logoWhite.src} alt="Nimbus Healthcare" class="h-[30px]" id="logo-white" />
            <img src={logoBlack.src} alt="Nimbus Healthcare" class="h-[30px] hidden" id="logo-black" />
          </div>

          <!-- Right: Theme Toggle -->
          <div class="flex items-center gap-4">
            <button
              id="theme-toggle"
              class="w-10 h-10 rounded-full border border-cream/15 flex items-center justify-center text-cream/50 hover:text-cream hover:border-cream/30 transition-colors cursor-pointer intake-back-btn"
              aria-label="Toggle light mode"
            >
              <svg id="icon-sun" width="18" height="18" viewBox="0 0 18 18" fill="none">
                <circle cx="9" cy="9" r="3.5" stroke="currentColor" stroke-width="1.3"/>
                <path d="M9 2v1.5M9 14.5V16M2 9h1.5M14.5 9H16M4.05 4.05l1.06 1.06M12.89 12.89l1.06 1.06M4.05 13.95l1.06-1.06M12.89 5.11l1.06-1.06" stroke="currentColor" stroke-width="1.3" stroke-linecap="round"/>
              </svg>
              <svg id="icon-moon" width="18" height="18" viewBox="0 0 18 18" fill="none" class="hidden">
                <path d="M15.36 10.68A6.5 6.5 0 017.32 2.64a7.5 7.5 0 108.04 8.04z" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </button>
          </div>
        </div>
      </div>

      <!-- Section 1: Hero -->
      <section class="px-6 py-20 md:py-28">
        <div class="max-w-4xl mx-auto text-center" data-animate>
          <p class="font-montserrat text-teal text-xs font-semibold tracking-[0.15em] uppercase mb-4">FREE TRIAL</p>
          <h1 class="font-fraunces text-cream text-[clamp(32px,5vw,56px)] leading-[1.1] tracking-[-0.02em] mb-5">
            See why 256+ clinics trust Nimbus.
          </h1>
          <p class="font-inter text-cream/50 text-lg md:text-xl leading-[1.6] mb-10 max-w-2xl mx-auto">
            7 days. Full platform access. 8 real patient scenarios. No credit card.
          </p>

          <!-- CTAs -->
          <div class="flex flex-col sm:flex-row items-center justify-center gap-4 mb-8" data-animate data-delay="1">
            <a
              href="https://novamed-admindev.nimbushealthcaretest.com/onboard/trial"
              class="scroll-to-signup w-full sm:w-auto bg-terracotta hover:brightness-110 text-cream font-montserrat font-medium text-base rounded-full px-10 py-4 transition-all cursor-pointer inline-flex items-center justify-center gap-2"
            >
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none">
                <path d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
              <span>Start Free Trial</span>
            </a>
            <a
              href="/contact"
              class="w-full sm:w-auto border border-cream/15 hover:border-cream/30 text-cream font-montserrat font-medium text-base rounded-full px-10 py-4 transition-all cursor-pointer inline-flex items-center justify-center gap-2"
            >
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none">
                <circle cx="12" cy="12" r="10" stroke="currentColor" stroke-width="1.5"/>
                <path d="M10 8l6 4-6 4V8z" fill="currentColor"/>
              </svg>
              <span>Watch Demo</span>
            </a>
          </div>

          <!-- Trust line -->
          <p class="font-inter text-cream/40 text-sm" data-animate data-delay="2">
            ✓ No credit card required · ✓ Set up in 2 minutes · ✓ Cancel anytime
          </p>
        </div>
      </section>

      <!-- Section 2: What You Get -->
      <section class="px-6 py-20 border-t border-cream/5">
        <div class="max-w-6xl mx-auto">
          <p class="font-montserrat text-teal text-xs font-semibold tracking-[0.15em] uppercase mb-3 text-center" data-animate>WHAT'S INCLUDED</p>
          <h2 class="font-fraunces text-cream text-[clamp(28px,4vw,42px)] leading-[1.15] tracking-[-0.02em] mb-16 text-center" data-animate data-delay="1">
            Everything you need to evaluate Nimbus
          </h2>

          <div class="grid md:grid-cols-3 gap-8" data-stagger>
            <!-- Card 1: 8 Sample Patients -->
            <div class="bg-[#22201E] border border-cream/10 rounded-2xl p-8 hover:border-cream/20 transition-colors">
              <div class="mb-5">
                <svg width="40" height="40" viewBox="0 0 24 24" fill="none" class="text-teal">
                  <path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2M9 11a4 4 0 100-8 4 4 0 000 8zM23 21v-2a4 4 0 00-3-3.87M16 3.13a4 4 0 010 7.75" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </div>
              <h3 class="font-inter font-semibold text-cream text-xl mb-3">8 Sample Patients</h3>
              <p class="font-inter text-cream/50 text-base leading-[1.6]">
                Pre-loaded with realistic medical histories, lab results, SOAP notes, and prescriptions. See exactly how the platform handles your workflow.
              </p>
            </div>

            <!-- Card 2: Full Dashboard Access -->
            <div class="bg-[#22201E] border border-cream/10 rounded-2xl p-8 hover:border-cream/20 transition-colors">
              <div class="mb-5">
                <svg width="40" height="40" viewBox="0 0 24 24" fill="none" class="text-teal">
                  <rect x="3" y="3" width="18" height="18" rx="2" stroke="currentColor" stroke-width="1.5"/>
                  <path d="M9 3v18M9 9h12M9 15h12" stroke="currentColor" stroke-width="1.5"/>
                </svg>
              </div>
              <h3 class="font-inter font-semibold text-cream text-xl mb-3">Full Dashboard Access</h3>
              <p class="font-inter text-cream/50 text-base leading-[1.6]">
                Every feature unlocked. Prescribing, IntelliHealth AI co-pilot, intake forms, formulary browsing, and clinic management tools.
              </p>
            </div>

            <!-- Card 3: IntelliHealth AI -->
            <div class="bg-[#22201E] border border-cream/10 rounded-2xl p-8 hover:border-cream/20 transition-colors">
              <div class="mb-5">
                <svg width="40" height="40" viewBox="0 0 24 24" fill="none" class="text-teal">
                  <path d="M21 16V8a2 2 0 00-1-1.73l-7-4a2 2 0 00-2 0l-7 4A2 2 0 003 8v8a2 2 0 001 1.73l7 4a2 2 0 002 0l7-4A2 2 0 0021 16z" stroke="currentColor" stroke-width="1.5"/>
                  <path d="M12 8v8M8 10v4M16 10v4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
                </svg>
              </div>
              <h3 class="font-inter font-semibold text-cream text-xl mb-3">IntelliHealth AI</h3>
              <p class="font-inter text-cream/50 text-base leading-[1.6]">
                Experience AI-powered clinical decision support. Drug interaction checks, protocol recommendations, and safety guardrails — all live in your trial.
              </p>
            </div>
          </div>
        </div>
      </section>

      <!-- Section 3: How It Works -->
      <section class="px-6 py-20 border-t border-cream/5">
        <div class="max-w-5xl mx-auto">
          <p class="font-montserrat text-teal text-xs font-semibold tracking-[0.15em] uppercase mb-3 text-center" data-animate>HOW IT WORKS</p>
          <h2 class="font-fraunces text-cream text-[clamp(28px,4vw,42px)] leading-[1.15] tracking-[-0.02em] mb-16 text-center" data-animate data-delay="1">
            Live in under 2 minutes
          </h2>

          <div class="grid md:grid-cols-3 gap-12" data-stagger>
            <!-- Step 1 -->
            <div class="text-center">
              <div class="w-16 h-16 rounded-full border-2 border-teal flex items-center justify-center mx-auto mb-6">
                <span class="font-fraunces text-teal text-2xl font-semibold">1</span>
              </div>
              <h3 class="font-inter font-semibold text-cream text-xl mb-3">Create your account</h3>
              <p class="font-inter text-cream/50 text-base leading-[1.6]">
                Enter your name, email, and clinic. That's it.
              </p>
            </div>

            <!-- Step 2 -->
            <div class="text-center">
              <div class="w-16 h-16 rounded-full border-2 border-teal flex items-center justify-center mx-auto mb-6">
                <span class="font-fraunces text-teal text-2xl font-semibold">2</span>
              </div>
              <h3 class="font-inter font-semibold text-cream text-xl mb-3">Explore the platform</h3>
              <p class="font-inter text-cream/50 text-base leading-[1.6]">
                8 sample patients are waiting. Browse prescriptions, run IntelliHealth, check labs.
              </p>
            </div>

            <!-- Step 3 -->
            <div class="text-center">
              <div class="w-16 h-16 rounded-full border-2 border-teal flex items-center justify-center mx-auto mb-6">
                <span class="font-fraunces text-teal text-2xl font-semibold">3</span>
              </div>
              <h3 class="font-inter font-semibold text-cream text-xl mb-3">Go live when ready</h3>
              <p class="font-inter text-cream/50 text-base leading-[1.6]">
                Love it? Complete onboarding to connect your real patients. We'll migrate everything.
              </p>
            </div>
          </div>
        </div>
      </section>

      <!-- Section 4: Social Proof Stats Bar -->
      <section class="px-6 py-16 border-t border-cream/5 bg-[#22201E]" data-animate>
        <div class="max-w-5xl mx-auto">
          <div class="grid grid-cols-2 md:grid-cols-4 gap-8 md:gap-12 text-center">
            <div>
              <div class="font-fraunces text-teal text-4xl md:text-5xl mb-2">256+</div>
              <div class="font-inter text-cream/40 text-sm uppercase tracking-wider">Clinics</div>
            </div>
            <div>
              <div class="font-fraunces text-teal text-4xl md:text-5xl mb-2">131</div>
              <div class="font-inter text-cream/40 text-sm uppercase tracking-wider">Compounds</div>
            </div>
            <div>
              <div class="font-fraunces text-teal text-4xl md:text-5xl mb-2">50</div>
              <div class="font-inter text-cream/40 text-sm uppercase tracking-wider">States</div>
            </div>
            <div>
              <div class="font-fraunces text-teal text-4xl md:text-5xl mb-2">7 days</div>
              <div class="font-inter text-cream/40 text-sm uppercase tracking-wider">To Go Live</div>
            </div>
          </div>
        </div>
      </section>

      <!-- Section 5: Signup Form -->
      <section class="px-6 py-20 border-t border-cream/5" id="signup-form">
        <div class="max-w-[620px] mx-auto">
          <!-- CTA Section -->
          <div id="trial-form">
            <p class="font-montserrat text-teal text-xs font-semibold tracking-[0.15em] uppercase mb-2 intake-label" data-animate>START YOUR TRIAL</p>
            <h2 class="font-fraunces text-cream text-[clamp(28px,4vw,40px)] leading-[1.15] tracking-[-0.02em] mb-4 intake-heading" data-animate data-delay="1">
              Ready? Let's set you up.
            </h2>
            <p class="font-inter text-cream/50 text-base leading-[1.6] mb-6 intake-body" data-animate data-delay="2">
              Create your free trial account on the NovaMed platform. No credit card required — full access starts immediately with 17 sample patients, IntelliHealth AI, and the complete clinic dashboard.
            </p>

            <!-- Direct CTA to Clinic App -->
            <div class="flex flex-col gap-4" data-animate data-delay="3">
              <a
                href="https://novamed-admindev.nimbushealthcaretest.com/onboard/trial"
                class="w-full bg-terracotta hover:brightness-110 text-cream font-montserrat font-medium text-base rounded-full px-10 py-4 transition-all cursor-pointer flex items-center justify-center gap-2"
              >
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none">
                  <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
                <span>Create Free Trial Account</span>
              </a>

              <p class="font-inter text-cream/50 text-sm text-center intake-body">
                Already have an account? <a href="https://novamed-admindev.nimbushealthcaretest.com/login" class="text-teal hover:underline">Log in</a>
              </p>

              <!-- Trust reinforcement -->
              <div class="flex items-center justify-center gap-6 mt-4">
                <span class="font-inter text-cream/30 text-xs flex items-center gap-2">
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
                  No credit card
                </span>
                <span class="font-inter text-cream/30 text-xs flex items-center gap-2">
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none"><circle cx="12" cy="12" r="10" stroke="currentColor" stroke-width="1.5"/><polyline points="12 6 12 12 16 14" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
                  2 min setup
                </span>
                <span class="font-inter text-cream/30 text-xs flex items-center gap-2">
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none"><path d="M22 11.08V12a10 10 0 11-5.93-9.14" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/><polyline points="22 4 12 14.01 9 11.01" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
                  Cancel anytime
                </span>
              </div>
            </div>

          </div>
        </div>
      </section>

      <!-- Section 6: FAQ -->
      <section class="px-6 py-20 border-t border-cream/5">
        <div class="max-w-3xl mx-auto">
          <p class="font-montserrat text-teal text-xs font-semibold tracking-[0.15em] uppercase mb-3 text-center" data-animate>QUESTIONS</p>
          <h2 class="font-fraunces text-cream text-[clamp(28px,4vw,42px)] leading-[1.15] tracking-[-0.02em] mb-12 text-center" data-animate data-delay="1">
            Frequently Asked Questions
          </h2>

          <div class="space-y-4" data-stagger>
            <!-- FAQ 1 -->
            <div class="faq-item border border-cream/10 rounded-2xl overflow-hidden">
              <button class="faq-question w-full text-left px-6 py-5 flex items-center justify-between hover:bg-cream/5 transition-colors cursor-pointer">
                <span class="font-inter font-semibold text-cream text-lg pr-4">What happens when my trial ends?</span>
                <svg class="faq-chevron w-5 h-5 text-cream/50 transition-transform flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
                </svg>
              </button>
              <div class="faq-answer hidden px-6 pb-5">
                <p class="font-inter text-cream/50 text-base leading-[1.6]">
                  Your account stays active but in read-only mode. No data is lost. Complete onboarding anytime to unlock full access.
                </p>
              </div>
            </div>

            <!-- FAQ 2 -->
            <div class="faq-item border border-cream/10 rounded-2xl overflow-hidden">
              <button class="faq-question w-full text-left px-6 py-5 flex items-center justify-between hover:bg-cream/5 transition-colors cursor-pointer">
                <span class="font-inter font-semibold text-cream text-lg pr-4">Is there really no credit card required?</span>
                <svg class="faq-chevron w-5 h-5 text-cream/50 transition-transform flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
                </svg>
              </button>
              <div class="faq-answer hidden px-6 pb-5">
                <p class="font-inter text-cream/50 text-base leading-[1.6]">
                  None. The trial is completely free. We only ask for payment information during full onboarding.
                </p>
              </div>
            </div>

            <!-- FAQ 3 -->
            <div class="faq-item border border-cream/10 rounded-2xl overflow-hidden">
              <button class="faq-question w-full text-left px-6 py-5 flex items-center justify-between hover:bg-cream/5 transition-colors cursor-pointer">
                <span class="font-inter font-semibold text-cream text-lg pr-4">Can I use my real patients during the trial?</span>
                <svg class="faq-chevron w-5 h-5 text-cream/50 transition-transform flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
                </svg>
              </button>
              <div class="faq-answer hidden px-6 pb-5">
                <p class="font-inter text-cream/50 text-base leading-[1.6]">
                  The trial uses sample data to protect patient privacy. Once you complete onboarding, you can start adding real patients immediately.
                </p>
              </div>
            </div>

            <!-- FAQ 4 -->
            <div class="faq-item border border-cream/10 rounded-2xl overflow-hidden">
              <button class="faq-question w-full text-left px-6 py-5 flex items-center justify-between hover:bg-cream/5 transition-colors cursor-pointer">
                <span class="font-inter font-semibold text-cream text-lg pr-4">What if I need help during my trial?</span>
                <svg class="faq-chevron w-5 h-5 text-cream/50 transition-transform flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
                </svg>
              </button>
              <div class="faq-answer hidden px-6 pb-5">
                <p class="font-inter text-cream/50 text-base leading-[1.6]">
                  Our team is available via email and chat. We also offer a guided onboarding call if you'd like a walkthrough.
                </p>
              </div>
            </div>
          </div>
        </div>
      </section>

      <!-- Footer: Trust + Badges -->
      <div class="flex flex-col md:flex-row items-center justify-center gap-6 md:gap-10 py-8 border-t border-cream/5 px-6">
        <div class="flex items-center gap-2 text-cream/30 intake-badge">
          <svg width="16" height="16" viewBox="0 0 16 16" fill="none">
            <path d="M8 1.33L2 4v4c0 3.47 2.56 6.71 6 7.33 3.44-.62 6-3.86 6-7.33V4L8 1.33z" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
          <span class="font-montserrat text-[11px] font-semibold tracking-[0.1em] uppercase">HIPAA Compliant</span>
        </div>

        <div class="flex items-center gap-2 text-cream/30 intake-badge">
          <svg width="16" height="16" viewBox="0 0 16 16" fill="none">
            <path d="M13.33 4L6 11.33 2.67 8" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
          <span class="font-montserrat text-[11px] font-semibold tracking-[0.1em] uppercase">Secure & Confidential</span>
        </div>
      </div>

      <div class="text-center pb-12 px-6">
        <p class="font-inter text-cream/40 text-xs max-w-2xl mx-auto">
          Powered by Lake Hills Pharmacy — NABP-accredited 503A/503B compounding facility
        </p>
      </div>

    </section>
  </main>
</Layout>

<style>
  /* Trial Page Styles */
  .trial-sticky-header {
    background: #1a1816;
    position: sticky;
    top: 0;
    z-index: 50;
  }

  /* Smooth scroll */
  html {
    scroll-behavior: smooth;
  }

  .step-enter {
    opacity: 0;
    transform: translateY(8px);
  }

  .step-visible {
    opacity: 1;
    transform: translateY(0);
    transition: opacity 0.28s ease, transform 0.28s ease;
  }

  .step-exit {
    opacity: 0;
    transition: opacity 0.15s ease;
  }

  /* Loading spinner */
  .spinner {
    display: inline-block;
    width: 16px;
    height: 16px;
    border: 2px solid rgba(245, 240, 234, 0.3);
    border-radius: 50%;
    border-top-color: #f5f0ea;
    animation: spin 0.6s linear infinite;
  }

  @keyframes spin {
    to { transform: rotate(360deg); }
  }

  /* FAQ Accordion */
  .faq-item.open .faq-chevron {
    transform: rotate(180deg);
  }

  .faq-answer {
    max-height: 0;
    overflow: hidden;
    transition: max-height 0.3s ease;
  }

  .faq-item.open .faq-answer {
    max-height: 500px;
  }

  /* Light Mode */
  .light-mode {
    background-color: #f5f0ea !important;
  }

  .light-mode .intake-heading {
    color: #1a1816;
  }

  .light-mode .intake-body {
    color: rgba(26, 24, 22, 0.55);
  }

  .light-mode .intake-bold {
    color: #1a1816;
  }

  .light-mode .intake-back-btn {
    border-color: rgba(26, 24, 22, 0.15);
    color: rgba(26, 24, 22, 0.5);
  }

  .light-mode .intake-back-btn:hover {
    border-color: rgba(26, 24, 22, 0.3);
    color: #1a1816;
  }

  .light-mode .intake-label {
    color: #2a9d8f;
  }

  .light-mode .intake-input {
    color: #1a1816;
    border-color: rgba(26, 24, 22, 0.15);
  }

  .light-mode .intake-input::placeholder {
    color: rgba(26, 24, 22, 0.25);
  }

  .light-mode .intake-input:focus {
    border-color: rgba(26, 24, 22, 0.35);
  }

  .light-mode .trial-sticky-header {
    background: #f5f0ea;
  }

  .light-mode .intake-badge {
    color: rgba(26, 24, 22, 0.3);
  }

  .light-mode .intake-border {
    border-color: rgba(26, 24, 22, 0.08);
  }
</style>

<script>
  // Theme toggle
  document.getElementById('theme-toggle')?.addEventListener('click', () => {
    const app = document.getElementById('trial-app');
    const logoWhite = document.getElementById('logo-white');
    const logoBlack = document.getElementById('logo-black');
    const iconSun = document.getElementById('icon-sun');
    const iconMoon = document.getElementById('icon-moon');

    app?.classList.toggle('light-mode');
    logoWhite?.classList.toggle('hidden');
    logoBlack?.classList.toggle('hidden');
    iconSun?.classList.toggle('hidden');
    iconMoon?.classList.toggle('hidden');
  });

  // Smooth scroll to signup form
  document.querySelectorAll('.scroll-to-signup').forEach(link => {
    link.addEventListener('click', (e) => {
      e.preventDefault();
      const target = document.querySelector('#signup-form');
      if (target) {
        target.scrollIntoView({ behavior: 'smooth', block: 'start' });
      }
    });
  });

  // FAQ accordion
  document.querySelectorAll('.faq-question').forEach(btn => {
    btn.addEventListener('click', function() {
      const item = this.closest('.faq-item');
      const wasOpen = item?.classList.contains('open');

      // Close all items
      document.querySelectorAll('.faq-item').forEach(i => {
        i.classList.remove('open');
        const answer = i.querySelector('.faq-answer');
        if (answer) answer.classList.add('hidden');
      });

      // Toggle current item
      if (!wasOpen && item) {
        item.classList.add('open');
        const answer = item.querySelector('.faq-answer');
        if (answer) answer.classList.remove('hidden');
      }
    });
  });

  // No form JS needed — trial signup happens on the clinic app at:
  // https://novamed-admindev.nimbushealthcaretest.com/onboard/trial
</script>
</Layout>
