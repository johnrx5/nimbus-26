---
---

<section class="bg-cream pt-10 pb-24 px-[10px]">
  <div class="max-w-[1200px] mx-auto">
    <div class="relative rounded-2xl overflow-hidden">
      <video
        id="snap-video"
        autoplay
        muted
        loop
        playsinline
        class="w-full object-cover"
      >
        <source src="/videos/snap-hero-1.mp4" type="video/mp4" />
      </video>

      <!-- Controls -->
      <div class="absolute bottom-5 left-5 flex items-center gap-3">
        <!-- Play/Pause -->
        <button
          id="snap-play-pause"
          class="w-10 h-10 rounded-full bg-dark/60 backdrop-blur-sm flex items-center justify-center hover:bg-dark/80 transition-colors cursor-pointer"
          aria-label="Pause video"
        >
          <svg id="snap-pause-icon" class="w-5 h-5 text-cream" viewBox="0 0 20 20" fill="currentColor">
            <path d="M5 4h3v12H5V4zm7 0h3v12h-3V4z"/>
          </svg>
          <svg id="snap-play-icon" class="w-5 h-5 text-cream hidden" viewBox="0 0 20 20" fill="currentColor">
            <path d="M6 4l10 6-10 6V4z"/>
          </svg>
        </button>

        <!-- Mute/Unmute -->
        <button
          id="snap-mute"
          class="w-10 h-10 rounded-full bg-dark/60 backdrop-blur-sm flex items-center justify-center hover:bg-dark/80 transition-colors cursor-pointer"
          aria-label="Unmute video"
        >
          <svg id="snap-muted-icon" class="w-5 h-5 text-cream" viewBox="0 0 20 20" fill="currentColor">
            <path d="M9 3L5 7H2v6h3l4 4V3zm8.5 7l1.5-1.5-1.06-1.06L16.5 8.88l-1.44-1.44L14 8.5 15.5 10 14 11.5l1.06 1.06 1.44-1.44 1.44 1.44L19 11.5 17.5 10z"/>
          </svg>
          <svg id="snap-unmuted-icon" class="w-5 h-5 text-cream hidden" viewBox="0 0 20 20" fill="currentColor">
            <path d="M9 3L5 7H2v6h3l4 4V3zm4 3.5c.88.88 1.5 2.19 1.5 3.5s-.62 2.62-1.5 3.5l1.06 1.06C15.56 13.06 16.5 11.12 16.5 10s-.94-3.06-2.44-4.56L13 6.5zm2.5-2.5c1.69 1.69 2.5 3.88 2.5 6s-.81 4.31-2.5 6l1.06 1.06C18.44 15.19 19.5 12.69 19.5 10s-1.06-5.19-2.94-7.06L15.5 4z"/>
          </svg>
        </button>
      </div>
    </div>
  </div>
</section>

<script>
  const video = document.getElementById('snap-video') as HTMLVideoElement;
  const playPauseBtn = document.getElementById('snap-play-pause');
  const pauseIcon = document.getElementById('snap-pause-icon');
  const playIcon = document.getElementById('snap-play-icon');
  const muteBtn = document.getElementById('snap-mute');
  const mutedIcon = document.getElementById('snap-muted-icon');
  const unmutedIcon = document.getElementById('snap-unmuted-icon');

  playPauseBtn?.addEventListener('click', () => {
    if (video.paused) {
      video.play();
      pauseIcon?.classList.remove('hidden');
      playIcon?.classList.add('hidden');
      playPauseBtn.setAttribute('aria-label', 'Pause video');
    } else {
      video.pause();
      pauseIcon?.classList.add('hidden');
      playIcon?.classList.remove('hidden');
      playPauseBtn.setAttribute('aria-label', 'Play video');
    }
  });

  muteBtn?.addEventListener('click', () => {
    video.muted = !video.muted;
    if (video.muted) {
      mutedIcon?.classList.remove('hidden');
      unmutedIcon?.classList.add('hidden');
      muteBtn.setAttribute('aria-label', 'Unmute video');
    } else {
      mutedIcon?.classList.add('hidden');
      unmutedIcon?.classList.remove('hidden');
      muteBtn.setAttribute('aria-label', 'Mute video');
    }
  });
</script>
