---
const trustItems = [
  {
    icon: 'chart',
    text: '94%  patient success rate',
  },
  {
    icon: 'shield',
    text: 'Licensed physicians',
  },
  {
    icon: 'tag',
    text: 'Flat-rate pricing',
  },
  {
    icon: 'heart',
    text: 'Ongoing clinical support',
  },
  {
    icon: 'pharmacy',
    text: 'Our own pharmacy',
  },
];
---

<section class="w-full bg-cream py-6">
  <div class="max-w-[1300px] mx-auto px-4 flex flex-wrap items-center justify-center gap-x-10 gap-y-3">
    {trustItems.map(item => (
      <div class="flex items-center gap-2 text-dark">
        <svg class="w-[18px] h-[18px] shrink-0" viewBox="0 0 18 18" fill="none" xmlns="http://www.w3.org/2000/svg">
          {item.icon === 'chart' && (
            <path d="M2 14V8h3v6H2zm5.5 0V4h3v10h-3zM13 14V1h3v13h-3z" fill="#1a1816"/>
          )}
          {item.icon === 'shield' && (
            <path d="M9 1L2 4v5c0 4.14 2.98 8.02 7 9 4.02-.98 7-4.86 7-9V4L9 1zm0 2.04l5 2.14v3.82c0 3.31-2.38 6.41-5 7.18-2.62-.77-5-3.87-5-7.18V5.18l5-2.14z" fill="#1a1816"/>
          )}
          {item.icon === 'tag' && (
            <path d="M16.5 1h-6.79a1.5 1.5 0 00-1.06.44L1.44 8.65a1.5 1.5 0 000 2.12l5.79 5.79a1.5 1.5 0 002.12 0l7.21-7.21A1.5 1.5 0 0017 8.29V2.5A1.5 1.5 0 0016.5 1zM13.5 6a1.5 1.5 0 110-3 1.5 1.5 0 010 3z" fill="#1a1816"/>
          )}
          {item.icon === 'heart' && (
            <path d="M9 16.35l-1.45-1.32C3.4 11.36 1 9.28 1 6.5 1 4.42 2.42 3 4.5 3c1.74 0 3.41 1.01 4.5 2.09C10.09 4.01 11.76 3 13.5 3 15.58 3 17 4.42 17 6.5c0 2.78-2.4 4.86-6.55 8.54L9 16.35z" fill="#1a1816"/>
          )}
          {item.icon === 'pharmacy' && (
            <path d="M16 6V2H2v4h1v10h10V6h1zm-4 7H9v3H7v-3H4V11h3V8h2v3h3v2z" fill="#1a1816"/>
          )}
        </svg>
        <span class="font-inter font-medium text-base text-dark whitespace-nowrap">{item.text}</span>
      </div>
    ))}
  </div>
</section>
