---
import tracyImg from '../assets/[9] Headshots/Dr Tracy Neal.png';
import thoppilImg from '../assets/[9] Headshots/Dr John Thoppil.png';

const boardMembers = [
  {
    name: 'Dr. Tracy Neal',
    title: 'Director, Women\'s Health Division',
    image: tracyImg,
    initials: null,
    bio: 'Board-certified physician focused on hormone health, reproductive wellness, and preventative care. Rooted in early detection, proactive optimization, and patient education.',
  },
  {
    name: 'Dr. John Thoppil',
    title: 'Board-Certified OB-GYN',
    image: thoppilImg,
    initials: null,
    bio: 'Founder of River Place OB/GYN and president of the Texas Association of Obstetricians and Gynecologists. A trusted physician in the Austin community for several decades.',
  },
  {
    name: 'Dr. Natalie Kash',
    title: 'Regenerative Medicine Specialist',
    image: null,
    initials: 'NK',
    bio: 'Regenerative medicine and hair restoration specialist at Root Hair Institute. Integrates precision diagnostics with innovative treatment modalities.',
  },
  {
    name: 'Dr. Rahil Roopani',
    title: 'Aesthetic & Regenerative Medicine',
    image: null,
    initials: 'RR',
    bio: 'Physician specializing in hair restoration and aesthetic medicine. Blends advanced regenerative therapies with aesthetic science for evidence-based treatment plans.',
  },
];
---

<section class="bg-[#1A1816] py-24 px-[10px]">
  <div class="max-w-[1200px] mx-auto">
    <!-- Header -->
    <div class="text-center mb-16" data-animate>
      <div class="flex items-center justify-center gap-3 mb-4">
        <div class="w-12 h-[2px] bg-teal"></div>
        <span class="font-montserrat text-teal text-sm font-semibold tracking-[0.15em] uppercase">Medical Board</span>
        <div class="w-12 h-[2px] bg-teal"></div>
      </div>
      <h2 class="font-fraunces text-cream text-[clamp(40px,5vw,72px)] leading-[1.05] tracking-[-0.02em]">
        Clinical <em class="text-teal not-italic italic">oversight.</em>
      </h2>
    </div>

    <!-- Board Grid -->
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6" data-animate data-delay="1">
      {boardMembers.map(member => (
        <div>
          <div class="bg-[#22201E] rounded-2xl overflow-hidden aspect-square mb-4">
            {member.image ? (
              <img
                src={member.image.src}
                alt={member.name}
                class="w-full h-full object-cover object-top"
              />
            ) : (
              <div class="w-full h-full flex items-center justify-center">
                <span class="font-fraunces text-teal/30 text-[72px] leading-none tracking-[-0.02em]">
                  {member.initials}
                </span>
              </div>
            )}
          </div>
          <h3 class="font-inter text-cream text-lg font-semibold leading-[1.3]">{member.name}</h3>
          <p class="font-inter text-cream/50 text-sm leading-[1.5] mb-2">{member.title}</p>
          <p class="font-inter text-cream/30 text-xs leading-[1.6]">{member.bio}</p>
        </div>
      ))}
    </div>
  </div>
</section>
