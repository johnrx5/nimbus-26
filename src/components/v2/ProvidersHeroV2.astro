---
---

<section class="relative bg-[#1A1816] min-h-[90vh] flex items-center px-[10px] pt-32 pb-16 overflow-hidden">
  <div class="max-w-[1200px] mx-auto w-full">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
      <!-- Left: Copy -->
      <div>
        <div class="mb-6 hero-animate">
          <span class="font-montserrat text-teal text-sm font-semibold tracking-[0.15em] uppercase">NovaMed Platform</span>
        </div>

        <h1 class="hero-animate font-fraunces text-cream text-[clamp(36px,5vw,64px)] leading-[1.08] tracking-[-0.02em] mb-6">
          The clinic-to-pharmacy<br />
          operating system for<br />
          <em class="italic text-teal">protocol-based care.</em>
        </h1>

        <p class="hero-animate hero-animate-delay-1 font-inter text-cream/50 text-lg leading-[1.6] max-w-[520px] mb-8">
          Intake. Protocols. Prescribing. Compounding. Fulfillment. Refills. One platform — backed by our own NABP-accredited pharmacy. Built by a pharmacist with 20 years in compounding.
        </p>

        <!-- CTA Buttons -->
        <div class="hero-animate hero-animate-delay-2 flex flex-col sm:flex-row gap-4 mb-10">
          <a href="/contact" class="bg-terracotta hover:bg-terracotta-hover text-cream font-montserrat font-medium text-base rounded-full px-8 py-4 transition-colors text-center">
            Get Started Free
          </a>
          <a href="/contact" class="border border-cream/20 hover:border-cream/40 text-cream/70 hover:text-cream font-montserrat font-medium text-base rounded-full px-8 py-4 transition-colors text-center">
            Schedule a Demo
          </a>
        </div>

        <!-- Social Proof Bar -->
        <div class="hero-animate hero-animate-delay-3 flex flex-wrap items-center gap-6 text-cream/30 font-inter text-sm">
          <span class="flex items-center gap-2">
            <span class="text-teal font-semibold">256+</span> Clinics
          </span>
          <span class="w-px h-4 bg-cream/10"></span>
          <span class="flex items-center gap-2">
            <span class="text-teal font-semibold">37</span> States
          </span>
          <span class="w-px h-4 bg-cream/10"></span>
          <span class="flex items-center gap-2">
            <span class="text-teal font-semibold">NABP</span> Accredited
          </span>
          <span class="w-px h-4 bg-cream/10"></span>
          <span class="flex items-center gap-2">
            <span class="text-teal font-semibold">131</span> Compounds
          </span>
        </div>
      </div>

      <!-- Right: Dashboard Screenshot -->
      <div class="hero-animate hero-animate-delay-2 relative">
        <div class="relative rounded-2xl overflow-hidden border border-cream/10 shadow-2xl shadow-black/30">
          <img
            src="/images/platform/01-dashboard-overview.png"
            alt="NovaMed Dashboard — Revenue overview, clinic management, and analytics"
            class="w-full h-auto"
            loading="eager"
          />
          <!-- Subtle gradient overlay at bottom -->
          <div class="absolute inset-x-0 bottom-0 h-20 bg-gradient-to-t from-[#1A1816] to-transparent"></div>
        </div>
        <!-- Floating accent -->
        <div class="absolute -bottom-4 -right-4 w-32 h-32 bg-teal/5 rounded-full blur-3xl"></div>
        <div class="absolute -top-4 -left-4 w-24 h-24 bg-terracotta/5 rounded-full blur-3xl"></div>
      </div>
    </div>
  </div>
</section>
