---
const steps = [
  {
    number: '01',
    title: 'Start with a health intake',
    description: 'Share your context, goals, and medical history.',
  },
  {
    number: '02',
    title: 'Provider review and plan design',
    description: 'A licensed clinician reviews your information and designs a plan based on clinical appropriateness.',
  },
  {
    number: '03',
    title: 'Pharmacy verification and preparation',
    description: 'Pharmacists verify the prescription and prepare patient-specific medication.',
  },
  {
    number: '04',
    title: 'Delivery with guidance',
    description: 'Medication is shipped with clear instructions and support.',
  },
  {
    number: '05',
    title: 'Ongoing support and adjustments',
    description: 'Care continues after delivery, with follow-ups and changes as needed.',
  },
];
---

<section class="bg-[#1A1816] pt-24 pb-20 overflow-x-clip" data-animate>
  <!-- Header -->
  <div id="about-loop-header" class="max-w-[1200px] mx-auto px-[10px] mb-10">
    <div class="flex items-end justify-between">
      <div>
        <p class="font-inter text-teal text-base mb-3">How Nimbus care works</p>
        <h2 class="font-fraunces text-cream text-[clamp(40px,5vw,72px)] leading-[1.05] tracking-[-0.02em]">
          The <em class="text-teal not-italic italic">loop.</em>
        </h2>
      </div>
      <!-- Arrow Buttons -->
      <div class="flex items-center gap-2 pb-2">
        <button
          id="about-loop-prev"
          class="w-10 h-10 rounded-full bg-cream/10 flex items-center justify-center text-cream/40 hover:text-cream hover:bg-cream/20 transition-colors cursor-pointer"
          aria-label="Previous slide"
        >
          <svg width="18" height="18" viewBox="0 0 18 18" fill="none">
            <path d="M11 4L6 9l5 5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </button>
        <button
          id="about-loop-next"
          class="w-10 h-10 rounded-full bg-cream/10 flex items-center justify-center text-cream/40 hover:text-cream hover:bg-cream/20 transition-colors cursor-pointer"
          aria-label="Next slide"
        >
          <svg width="18" height="18" viewBox="0 0 18 18" fill="none">
            <path d="M7 4l5 5-5 5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </button>
      </div>
    </div>
  </div>

  <!-- Carousel (bleeds right) -->
  <div
    id="about-loop-carousel"
    class="about-loop-carousel flex gap-6 overflow-x-auto snap-x snap-mandatory pb-4"
    style="scrollbar-width: none;"
  >
    {steps.map(step => (
      <div class="snap-start shrink-0 w-[400px]">
        <div class="bg-[#22201E] rounded-2xl h-[360px] flex flex-col justify-end p-8 mb-5 relative overflow-hidden">
          <span class="font-fraunces text-teal/40 text-[120px] leading-none tracking-[-0.04em] absolute top-4 right-6">
            {step.number}
          </span>
        </div>
        <h3 class="font-inter text-cream text-lg font-bold mb-2 px-2">{step.title}</h3>
        <p class="font-inter text-cream/40 text-sm leading-[1.6] px-2">{step.description}</p>
      </div>
    ))}
  </div>
</section>

<style>
  .about-loop-carousel::-webkit-scrollbar {
    display: none;
  }
  .about-loop-carousel {
    padding-left: 10px;
  }
  @media (min-width: 1200px) {
    .about-loop-carousel {
      padding-left: calc((100vw - 1200px) / 2 + 10px);
    }
  }
</style>

<script is:inline>
  (function() {
    var prevBtn = document.getElementById('about-loop-prev');
    var nextBtn = document.getElementById('about-loop-next');
    var carousel = document.getElementById('about-loop-carousel');
    var cardWidth = 400 + 24;

    prevBtn?.addEventListener('click', function() {
      carousel?.scrollBy({ left: -cardWidth, behavior: 'smooth' });
    });

    nextBtn?.addEventListener('click', function() {
      carousel?.scrollBy({ left: cardWidth, behavior: 'smooth' });
    });
  })();
</script>
