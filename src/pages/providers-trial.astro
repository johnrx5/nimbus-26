---
import Layout from '../layouts/Layout.astro';
import logoWhite from '../assets/NB_br_Logo White/NB_br_Logo White_0325.png';
import logoBlack from '../assets/NB_br_Logo Black/NB_br_Logo Black_0325.png';
---

<Layout title="Nimbus Providers - Free Trial">
  <main>
    <section class="bg-[#1A1816] min-h-screen flex flex-col" id="trial-app">
      <!-- Sticky Top Bar -->
      <div class="px-6 shrink-0 trial-sticky-header">
        <div class="max-w-[620px] mx-auto relative flex items-center justify-between py-5">
          <!-- Left: Back -->
          <div class="flex items-center gap-3">
            <a
              href="/providers"
              class="w-10 h-10 rounded-full border border-cream/15 flex items-center justify-center text-cream/50 hover:text-cream hover:border-cream/30 transition-colors cursor-pointer intake-back-btn"
              aria-label="Go back"
            >
              <svg width="18" height="18" viewBox="0 0 18 18" fill="none">
                <path d="M11 4L6 9l5 5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </a>
          </div>

          <!-- Center: Logo -->
          <div class="absolute left-1/2 -translate-x-1/2">
            <img src={logoWhite.src} alt="Nimbus Healthcare" class="h-[30px]" id="logo-white" />
            <img src={logoBlack.src} alt="Nimbus Healthcare" class="h-[30px] hidden" id="logo-black" />
          </div>

          <!-- Right: Theme Toggle -->
          <div class="flex items-center gap-4">
            <button
              id="theme-toggle"
              class="w-10 h-10 rounded-full border border-cream/15 flex items-center justify-center text-cream/50 hover:text-cream hover:border-cream/30 transition-colors cursor-pointer intake-back-btn"
              aria-label="Toggle light mode"
            >
              <svg id="icon-sun" width="18" height="18" viewBox="0 0 18 18" fill="none">
                <circle cx="9" cy="9" r="3.5" stroke="currentColor" stroke-width="1.3"/>
                <path d="M9 2v1.5M9 14.5V16M2 9h1.5M14.5 9H16M4.05 4.05l1.06 1.06M12.89 12.89l1.06 1.06M4.05 13.95l1.06-1.06M12.89 5.11l1.06-1.06" stroke="currentColor" stroke-width="1.3" stroke-linecap="round"/>
              </svg>
              <svg id="icon-moon" width="18" height="18" viewBox="0 0 18 18" fill="none" class="hidden">
                <path d="M15.36 10.68A6.5 6.5 0 017.32 2.64a7.5 7.5 0 108.04 8.04z" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </button>
          </div>
        </div>
      </div>

      <!-- Scrollable Content -->
      <div class="flex-1 overflow-y-auto px-6 pb-8" id="trial-content">
        <div class="max-w-[620px] mx-auto">

          <!-- Form View -->
          <div id="trial-form" class="mt-4">
            <p class="font-montserrat text-teal text-xs font-semibold tracking-[0.15em] uppercase mb-2 intake-label">FREE TRIAL</p>
            <h1 class="font-fraunces text-cream text-[clamp(28px,4vw,40px)] leading-[1.15] tracking-[-0.02em] mb-4 intake-heading">
              Try Nimbus Providers free for 7 days
            </h1>
            <p class="font-inter text-cream/50 text-base leading-[1.6] mb-6 intake-body">
              Explore the platform with real sample data. No credit card required. Set up in under 2 minutes.
            </p>

            <!-- Feature Pills -->
            <div class="flex flex-wrap gap-3 mb-10">
              <div class="border border-cream/15 rounded-full px-4 py-2 text-sm font-inter text-cream/60">8 Sample Patients</div>
              <div class="border border-cream/15 rounded-full px-4 py-2 text-sm font-inter text-cream/60">Full Dashboard Access</div>
              <div class="border border-cream/15 rounded-full px-4 py-2 text-sm font-inter text-cream/60">IntelliHealth AI</div>
            </div>

            <!-- Form Fields -->
            <form id="trial-signup-form">
              <!-- First Name + Last Name -->
              <div class="grid grid-cols-2 gap-4 mb-6">
                <div>
                  <label class="font-inter text-cream font-semibold text-base block mb-3 intake-bold">First Name <span class="text-red-400 text-sm">*</span></label>
                  <input type="text" id="first-name" required placeholder="Enter first name" class="w-full bg-transparent border border-cream/15 rounded-2xl px-5 py-4 font-inter text-cream text-base placeholder:text-cream/25 focus:outline-none focus:border-cream/40 transition-colors intake-input">
                </div>

                <div>
                  <label class="font-inter text-cream font-semibold text-base block mb-3 intake-bold">Last Name <span class="text-red-400 text-sm">*</span></label>
                  <input type="text" id="last-name" required placeholder="Enter last name" class="w-full bg-transparent border border-cream/15 rounded-2xl px-5 py-4 font-inter text-cream text-base placeholder:text-cream/25 focus:outline-none focus:border-cream/40 transition-colors intake-input">
                </div>
              </div>

              <!-- Email -->
              <div class="mb-6">
                <label class="font-inter text-cream font-semibold text-base block mb-3 intake-bold">Email <span class="text-red-400 text-sm">*</span></label>
                <input type="email" id="email" required placeholder="you@example.com" class="w-full bg-transparent border border-cream/15 rounded-2xl px-5 py-4 font-inter text-cream text-base placeholder:text-cream/25 focus:outline-none focus:border-cream/40 transition-colors intake-input">
              </div>

              <!-- Clinic Name -->
              <div class="mb-6">
                <label class="font-inter text-cream font-semibold text-base block mb-3 intake-bold">Clinic Name <span class="text-red-400 text-sm">*</span></label>
                <input type="text" id="clinic-name" required placeholder="Enter clinic name" class="w-full bg-transparent border border-cream/15 rounded-2xl px-5 py-4 font-inter text-cream text-base placeholder:text-cream/25 focus:outline-none focus:border-cream/40 transition-colors intake-input">
              </div>

              <!-- Password -->
              <div class="mb-2">
                <label class="font-inter text-cream font-semibold text-base block mb-3 intake-bold">
                  <span class="inline-flex items-center gap-2">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" class="text-cream/40">
                      <rect x="3" y="11" width="18" height="11" rx="2" stroke="currentColor" stroke-width="1.5"/>
                      <path d="M7 11V7a5 5 0 0110 0v4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
                    </svg>
                    Password <span class="text-red-400 text-sm">*</span>
                  </span>
                </label>
                <div class="relative">
                  <input type="password" id="password" required placeholder="Create a password" class="w-full bg-transparent border border-cream/15 rounded-2xl px-5 py-4 pr-12 font-inter text-cream text-base placeholder:text-cream/25 focus:outline-none focus:border-cream/40 transition-colors intake-input">
                  <button type="button" class="pw-toggle absolute right-4 top-1/2 -translate-y-1/2 text-cream/30 hover:text-cream/60 transition-colors cursor-pointer" data-target="password">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none">
                      <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z" stroke="currentColor" stroke-width="1.5"/>
                      <circle cx="12" cy="12" r="3" stroke="currentColor" stroke-width="1.5"/>
                    </svg>
                  </button>
                </div>
              </div>

              <!-- Confirm Password -->
              <div class="mb-2">
                <label class="font-inter text-cream font-semibold text-base block mb-3 intake-bold">
                  <span class="inline-flex items-center gap-2">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" class="text-cream/40">
                      <rect x="3" y="11" width="18" height="11" rx="2" stroke="currentColor" stroke-width="1.5"/>
                      <path d="M7 11V7a5 5 0 0110 0v4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
                    </svg>
                    Confirm Password <span class="text-red-400 text-sm">*</span>
                  </span>
                </label>
                <div class="relative">
                  <input type="password" id="password-confirm" required placeholder="Confirm your password" class="w-full bg-transparent border border-cream/15 rounded-2xl px-5 py-4 pr-12 font-inter text-cream text-base placeholder:text-cream/25 focus:outline-none focus:border-cream/40 transition-colors intake-input">
                  <button type="button" class="pw-toggle absolute right-4 top-1/2 -translate-y-1/2 text-cream/30 hover:text-cream/60 transition-colors cursor-pointer" data-target="password-confirm">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none">
                      <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z" stroke="currentColor" stroke-width="1.5"/>
                      <circle cx="12" cy="12" r="3" stroke="currentColor" stroke-width="1.5"/>
                    </svg>
                  </button>
                </div>
              </div>
              <p class="font-inter text-cream/30 text-xs mb-8 intake-body">Password must be at least 8 characters and include uppercase, lowercase, number, and special character.</p>

              <!-- Error Message -->
              <div id="error-message" class="hidden mb-6 rounded-2xl border border-red-400/20 bg-red-400/5 px-5 py-4">
                <p class="font-inter text-red-400 text-sm"></p>
              </div>

              <!-- Submit Button -->
              <button type="submit" id="submit-btn" class="w-full bg-terracotta hover:brightness-110 text-cream font-montserrat font-medium text-base rounded-full px-10 py-4 transition-all cursor-pointer flex items-center justify-center gap-2">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none">
                  <path d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
                <span>Start Free Trial</span>
              </button>

              <!-- Login Link -->
              <p class="font-inter text-cream/50 text-sm text-center mt-6 intake-body">
                Already have an account? <a href="/login" class="text-teal hover:underline">Log in</a>
              </p>
            </form>
          </div>

          <!-- Success View -->
          <div id="trial-success" class="hidden mt-10 pb-10">
            <!-- Checkmark Icon -->
            <div class="flex justify-center mb-7 mt-2">
              <svg width="76" height="76" viewBox="0 0 76 76" fill="none" xmlns="http://www.w3.org/2000/svg">
                <circle cx="38" cy="38" r="35" stroke="#2A9D8F" stroke-width="2"/>
                <path d="M23 38l12 12 19-21" stroke="#2A9D8F" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </div>

            <h2 class="font-fraunces text-cream text-[clamp(38px,8vw,58px)] leading-[1.1] tracking-[-0.02em] text-center mb-5 intake-heading">
              You're in!
            </h2>

            <p class="font-inter text-cream/50 text-base leading-[1.7] text-center mb-10 mx-auto max-w-[380px] intake-body">
              Your 7-day trial is ready. Check your email for login details.
            </p>

            <a href="/dashboard" class="w-full bg-teal hover:brightness-110 text-cream font-montserrat font-medium text-base rounded-full px-10 py-4 transition-all cursor-pointer flex items-center justify-center gap-2">
              Go to Dashboard
            </a>
          </div>

        </div>
      </div>

      <!-- Bottom Trust Badges -->
      <div class="flex items-center justify-center gap-8 py-5 border-t border-cream/5 intake-border">
        <div class="flex items-center gap-2 text-cream/30 intake-badge">
          <svg width="16" height="16" viewBox="0 0 16 16" fill="none">
            <path d="M8 1.33L2 4v4c0 3.47 2.56 6.71 6 7.33 3.44-.62 6-3.86 6-7.33V4L8 1.33z" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
          <span class="font-montserrat text-[11px] font-semibold tracking-[0.1em] uppercase">HIPAA Compliant</span>
        </div>

        <div class="flex items-center gap-2 text-cream/30 intake-badge">
          <svg width="16" height="16" viewBox="0 0 16 16" fill="none">
            <path d="M13.33 4L6 11.33 2.67 8" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
          <span class="font-montserrat text-[11px] font-semibold tracking-[0.1em] uppercase">Secure & Confidential</span>
        </div>
      </div>

    </section>
  </main>
</Layout>

<style>
  /* Trial Page Styles */
  .trial-sticky-header {
    background: #1a1816;
  }

  .step-enter {
    opacity: 0;
    transform: translateY(8px);
  }

  .step-visible {
    opacity: 1;
    transform: translateY(0);
    transition: opacity 0.28s ease, transform 0.28s ease;
  }

  .step-exit {
    opacity: 0;
    transition: opacity 0.15s ease;
  }

  /* Loading spinner */
  .spinner {
    display: inline-block;
    width: 16px;
    height: 16px;
    border: 2px solid rgba(245, 240, 234, 0.3);
    border-radius: 50%;
    border-top-color: #f5f0ea;
    animation: spin 0.6s linear infinite;
  }

  @keyframes spin {
    to { transform: rotate(360deg); }
  }

  /* Light Mode */
  .light-mode {
    background-color: #f5f0ea !important;
  }

  .light-mode .intake-heading {
    color: #1a1816;
  }

  .light-mode .intake-body {
    color: rgba(26, 24, 22, 0.55);
  }

  .light-mode .intake-bold {
    color: #1a1816;
  }

  .light-mode .intake-back-btn {
    border-color: rgba(26, 24, 22, 0.15);
    color: rgba(26, 24, 22, 0.5);
  }

  .light-mode .intake-back-btn:hover {
    border-color: rgba(26, 24, 22, 0.3);
    color: #1a1816;
  }

  .light-mode .intake-label {
    color: #2a9d8f;
  }

  .light-mode .intake-input {
    color: #1a1816;
    border-color: rgba(26, 24, 22, 0.15);
  }

  .light-mode .intake-input::placeholder {
    color: rgba(26, 24, 22, 0.25);
  }

  .light-mode .intake-input:focus {
    border-color: rgba(26, 24, 22, 0.35);
  }

  .light-mode .trial-sticky-header {
    background: #f5f0ea;
  }

  .light-mode .intake-badge {
    color: rgba(26, 24, 22, 0.3);
  }

  .light-mode .intake-border {
    border-color: rgba(26, 24, 22, 0.08);
  }
</style>

<script>
  // Theme toggle
  document.getElementById('theme-toggle')?.addEventListener('click', () => {
    const app = document.getElementById('trial-app');
    const logoWhite = document.getElementById('logo-white');
    const logoBlack = document.getElementById('logo-black');
    const iconSun = document.getElementById('icon-sun');
    const iconMoon = document.getElementById('icon-moon');

    app?.classList.toggle('light-mode');
    logoWhite?.classList.toggle('hidden');
    logoBlack?.classList.toggle('hidden');
    iconSun?.classList.toggle('hidden');
    iconMoon?.classList.toggle('hidden');
  });

  // Password visibility toggles
  document.querySelectorAll('.pw-toggle').forEach(btn => {
    btn.addEventListener('click', function() {
      const targetId = this.dataset.target || '';
      const input = document.getElementById(targetId) as HTMLInputElement;
      if (input) {
        input.type = input.type === 'password' ? 'text' : 'password';
      }
    });
  });

  // Form validation and submission
  const form = document.getElementById('trial-signup-form') as HTMLFormElement;
  const submitBtn = document.getElementById('submit-btn');
  const errorMessage = document.getElementById('error-message');
  const trialForm = document.getElementById('trial-form');
  const trialSuccess = document.getElementById('trial-success');

  function showError(message: string) {
    if (errorMessage) {
      const p = errorMessage.querySelector('p');
      if (p) p.textContent = message;
      errorMessage.classList.remove('hidden');
      setTimeout(() => errorMessage.classList.add('hidden'), 5000);
    }
  }

  function validatePassword(password: string): boolean {
    if (password.length < 8) return false;
    if (!/[A-Z]/.test(password)) return false;
    if (!/[a-z]/.test(password)) return false;
    if (!/[0-9]/.test(password)) return false;
    if (!/[!@#$%^&*()_+\-=\[\]{};':"\\|,.<>\/?]/.test(password)) return false;
    return true;
  }

  function validateEmail(email: string): boolean {
    return /^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email);
  }

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();

    // Get form values
    const firstName = (document.getElementById('first-name') as HTMLInputElement)?.value.trim();
    const lastName = (document.getElementById('last-name') as HTMLInputElement)?.value.trim();
    const email = (document.getElementById('email') as HTMLInputElement)?.value.trim();
    const clinicName = (document.getElementById('clinic-name') as HTMLInputElement)?.value.trim();
    const password = (document.getElementById('password') as HTMLInputElement)?.value;
    const passwordConfirm = (document.getElementById('password-confirm') as HTMLInputElement)?.value;

    // Validate all fields are filled
    if (!firstName || !lastName || !email || !clinicName || !password || !passwordConfirm) {
      showError('Please fill in all required fields');
      return;
    }

    // Validate email format
    if (!validateEmail(email)) {
      showError('Please enter a valid email address');
      return;
    }

    // Validate password requirements
    if (!validatePassword(password)) {
      showError('Password must be at least 8 characters with uppercase, lowercase, number, and special character');
      return;
    }

    // Validate passwords match
    if (password !== passwordConfirm) {
      showError('Passwords do not match');
      return;
    }

    // Show loading state
    if (submitBtn) {
      const btnText = submitBtn.querySelector('span');
      if (btnText) btnText.textContent = 'Creating your trial...';
      submitBtn.innerHTML = '<div class="spinner"></div> Creating your trial...';
      submitBtn.setAttribute('disabled', 'true');
    }

    // Simulate API call (replace with actual endpoint)
    try {
      // TODO: Replace with actual API endpoint
      // const response = await fetch('/api/trial-signup', {
      //   method: 'POST',
      //   headers: { 'Content-Type': 'application/json' },
      //   body: JSON.stringify({ firstName, lastName, email, clinicName, password })
      // });

      // Simulate delay
      await new Promise(resolve => setTimeout(resolve, 1500));

      // Show success view
      if (trialForm && trialSuccess) {
        trialForm.classList.add('step-exit');
        setTimeout(() => {
          trialForm.classList.add('hidden');
          trialSuccess.classList.remove('hidden');
          trialSuccess.classList.add('step-enter');
          setTimeout(() => trialSuccess.classList.add('step-visible'), 10);
        }, 150);
      }

    } catch (error) {
      showError('An error occurred. Please try again.');
      
      // Reset button
      if (submitBtn) {
        submitBtn.innerHTML = `
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none">
            <path d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
          <span>Start Free Trial</span>
        `;
        submitBtn.removeAttribute('disabled');
      }
    }
  });
</script>
</Layout>
