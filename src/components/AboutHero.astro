---
---

<section class="relative w-full h-[100vh] p-0 md:p-[10px]">
  <!-- Background Video -->
  <div class="absolute inset-0 md:inset-[10px] rounded-none md:rounded-[14px] overflow-hidden">
    <video
      autoplay
      muted
      loop
      playsinline
      class="w-full h-full object-cover"
    >
      <source src="/videos/Lab_v1.mp4" type="video/mp4" />
    </video>
    <div class="absolute inset-0 bg-[#1A1816]/70"></div>
  </div>

  <!-- Content -->
  <div class="relative z-10 flex flex-col items-start md:items-center justify-end md:justify-center h-full text-left md:text-center px-6 md:px-4 pt-20 pb-24 md:pb-0">
    <h1 class="hero-animate hero-animate-delay-1 font-fraunces text-cream text-[clamp(48px,8vw,96px)] leading-[1] tracking-[-0.02em] mb-8">
      Made by us,<br />for you.<span class="text-[0.5em] align-super">&#8482;</span>
    </h1>

    <p class="hero-animate hero-animate-delay-1 font-inter text-cream/60 text-[15px] md:text-lg leading-[1.5] max-w-[650px] mb-12">
      Nimbus Healthcare is a clinician-led care platform built around the pharmacy. We connect intake, provider oversight, and precision compounding into one continuous loop—so care feels accountable, consistent, and human.
    </p>

    <div class="hero-animate hero-animate-delay-2">
      <a
        href="#jobby"
        class="bg-terracotta hover:bg-terracotta-hover text-cream font-montserrat font-medium text-base rounded-full px-8 md:px-10 py-4.5 transition-colors"
      >
        Meet the team
      </a>
    </div>
  </div>
</section>
