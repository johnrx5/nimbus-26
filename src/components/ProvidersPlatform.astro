---
---

<section class="bg-[#1A1816] pt-32 pb-24 px-[10px]">
  <div class="max-w-[1200px] mx-auto">
    <!-- Heading -->
    <div class="text-center mb-6" data-animate>
      <h2 class="font-fraunces text-cream text-[clamp(48px,6vw,88px)] leading-[1.05] tracking-[-0.02em]">
        One platform.<br />
        End-to-end <em class="text-teal not-italic">automation.</em>
      </h2>
    </div>

    <!-- Subtitle -->
    <div class="text-center max-w-[640px] mx-auto mb-20" data-animate data-delay="1">
      <p class="font-inter text-cream/50 text-lg leading-[1.5]">
        Replace your entire prescription management stack. From clinic to pharmacy to patient with a single, automated platform.
      </p>
    </div>

    <!-- Dashboard Mockup -->
    <div class="mb-20" data-animate data-delay="2">
      <img
        src="/images/Provider Dashboard 1.png"
        alt="Nimbus Provider Dashboard"
        class="w-full"
      />
    </div>

    <!-- Features Heading -->
    <div class="mb-12" data-animate>
      <h3 class="font-fraunces text-cream text-[clamp(32px,4vw,48px)] leading-[1.15] tracking-[-0.02em] max-w-[700px]">
        Engineered to eliminate friction<br />from your workflow.
      </h3>
    </div>

    <!-- 4-Column Feature Grid -->
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-8" data-animate data-delay="1">
      <div class="border-t border-teal/30 pt-6">
        <h4 class="font-inter text-cream font-semibold text-base leading-[1.4] mb-3">
          Real-time tracking &amp; network
        </h4>
        <p class="font-inter text-cream/40 text-sm leading-[1.6]">
          Track orders in real-time across your pharmacy network and eliminate status calls with total visibility.
        </p>
      </div>

      <div class="border-t border-teal/30 pt-6">
        <h4 class="font-inter text-cream font-semibold text-base leading-[1.4] mb-3">
          Automated billing &amp; finance
        </h4>
        <p class="font-inter text-cream/40 text-sm leading-[1.6]">
          Sync invoices and payments automatically to end manual reconciliation in one view.
        </p>
      </div>

      <div class="border-t border-teal/30 pt-6">
        <h4 class="font-inter text-cream font-semibold text-base leading-[1.4] mb-3">
          Price transparency &amp; analytics
        </h4>
        <p class="font-inter text-cream/40 text-sm leading-[1.6]">
          Compare costs instantly for the best patient rates and monitor volume with actionable data.
        </p>
      </div>

      <div class="border-t border-teal/30 pt-6">
        <h4 class="font-inter text-cream font-semibold text-base leading-[1.4] mb-3">
          Smart refill management
        </h4>
        <p class="font-inter text-cream/40 text-sm leading-[1.6]">
          Automate renewals and reminders to drive adherence and boost revenue while eliminating manual outreach.
        </p>
      </div>
    </div>

    <!-- IntelliHealth Screen -->
    <div class="mt-20" data-animate>
      <img
        src="/images/Provider Screen 2.png"
        alt="Nimbus IntelliHealth AI-powered patient recommendations"
        class="w-full"
      />
    </div>
  </div>
</section>
