---
import nutritionImg from '../assets/[7] Photography/iStock-1206537120.jpg';

const pills = [
  '80–120g protein / day',
  'Low glycemic load',
  'High fiber for GI tolerance',
  'Up to 6 meals / week',
];
---

<section class="bg-cream px-[10px]" data-animate>
  <div class="bg-[#EAE4DD] rounded-3xl pt-24 pb-20 px-10 md:px-16">
    <div class="max-w-[1200px] mx-auto">

      <!-- Header -->
      <div class="text-center mb-12" data-animate>
        <p class="font-inter text-dark/50 text-base mb-3">The diet</p>
        <h2 class="font-fraunces text-dark text-[clamp(40px,5vw,72px)] leading-[1.05] tracking-[-0.02em]">
          Clinician-guided nutrition
        </h2>
      </div>

      <!-- Video -->
      <div class="relative rounded-2xl overflow-hidden mb-16" data-animate data-delay="1">
        <video
          id="teams-nutrition-video"
          autoplay
          muted
          loop
          playsinline
          class="w-full object-cover"
        >
          <source src="/videos/snap-hero-1.mp4" type="video/mp4" />
        </video>

        <!-- Controls -->
        <div class="absolute bottom-5 left-5 flex items-center gap-3">
          <!-- Restart -->
          <button
            id="teams-nutrition-restart"
            class="w-10 h-10 rounded-full bg-dark/60 backdrop-blur-sm flex items-center justify-center hover:bg-dark/80 transition-colors cursor-pointer"
            aria-label="Restart video"
          >
            <svg class="w-4.5 h-4.5 text-cream" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M1 4v6h6"/><path d="M3.51 15a9 9 0 1 0 2.13-9.36L1 10"/>
            </svg>
          </button>

          <!-- Play/Pause -->
          <button
            id="teams-nutrition-play-pause"
            class="w-10 h-10 rounded-full bg-dark/60 backdrop-blur-sm flex items-center justify-center hover:bg-dark/80 transition-colors cursor-pointer"
            aria-label="Pause video"
          >
            <svg id="teams-nutrition-pause-icon" class="w-5 h-5 text-cream" viewBox="0 0 20 20" fill="currentColor">
              <path d="M5 4h3v12H5V4zm7 0h3v12h-3V4z"/>
            </svg>
            <svg id="teams-nutrition-play-icon" class="w-5 h-5 text-cream hidden" viewBox="0 0 20 20" fill="currentColor">
              <path d="M6 4l10 6-10 6V4z"/>
            </svg>
          </button>

          <!-- Mute/Unmute -->
          <button
            id="teams-nutrition-mute"
            class="w-10 h-10 rounded-full bg-dark/60 backdrop-blur-sm flex items-center justify-center hover:bg-dark/80 transition-colors cursor-pointer"
            aria-label="Unmute video"
          >
            <svg id="teams-nutrition-muted-icon" class="w-5 h-5 text-cream" viewBox="0 0 20 20" fill="currentColor">
              <path d="M9 3L5 7H2v6h3l4 4V3zm8.5 7l1.5-1.5-1.06-1.06L16.5 8.88l-1.44-1.44L14 8.5 15.5 10 14 11.5l1.06 1.06 1.44-1.44 1.44 1.44L19 11.5 17.5 10z"/>
            </svg>
            <svg id="teams-nutrition-unmuted-icon" class="w-5 h-5 text-cream hidden" viewBox="0 0 20 20" fill="currentColor">
              <path d="M9 3L5 7H2v6h3l4 4V3zm4 3.5c.88.88 1.5 2.19 1.5 3.5s-.62 2.62-1.5 3.5l1.06 1.06C15.56 13.06 16.5 11.12 16.5 10s-.94-3.06-2.44-4.56L13 6.5zm2.5-2.5c1.69 1.69 2.5 3.88 2.5 6s-.81 4.31-2.5 6l1.06 1.06C18.44 15.19 19.5 12.69 19.5 10s-1.06-5.19-2.94-7.06L15.5 4z"/>
            </svg>
          </button>
        </div>
      </div>

      <!-- Why Nutrition Matters -->
      <div class="grid grid-cols-1 md:grid-cols-2 gap-0 mb-20 bg-cream rounded-2xl overflow-hidden" data-animate data-delay="2">
        <!-- Image -->
        <div class="h-[500px] md:h-auto">
          <img src={nutritionImg.src} alt="Nutrition for GLP-1 outcomes" class="w-full h-full object-cover" />
        </div>
        <!-- Content -->
        <div class="flex flex-col justify-center p-10 md:p-14">
          <h3 class="font-fraunces text-dark text-[clamp(28px,3.5vw,44px)] leading-[1.15] tracking-[-0.02em] mb-8">
            Why Nutrition Matters for GLP-1 Outcomes
          </h3>
          <p class="font-inter text-dark/50 text-sm leading-[1.7] mb-5">
            GLP-1 therapy changes how the body processes hunger signals, but without nutritional guidance, employees often struggle with what and how to eat, leading to avoidable side effects and premature discontinuation.
          </p>
          <p class="font-inter text-dark/50 text-sm leading-[1.7]">
            Nimbus meals are designed by clinicians around GLP-1-specific nutritional needs, making adherence easier and outcomes more durable.
          </p>
        </div>
      </div>

      <!-- Subheading + Description -->
      <div class="text-center mb-10 max-w-[700px] mx-auto" data-animate data-delay="2">
        <h3 class="font-fraunces text-dark text-[clamp(28px,3.5vw,44px)] leading-[1.15] tracking-[-0.02em] mb-5">
          What should I actually be eating while on GLP-1s?
        </h3>
        <p class="font-inter text-dark/50 text-sm leading-[1.6]">
          Nutrition is an optional, additive layer designed to support GLP-1 therapy and reduce common barriers to adherence. Employees enrolled in GLP-1 care may opt into structured, clinician-guided meals delivered weekly.
        </p>
      </div>

      <!-- Pill Tags -->
      <div class="flex flex-wrap justify-center gap-4" data-animate data-delay="3">
        {pills.map(pill => (
          <span class="font-inter text-dark text-sm border border-teal/40 rounded-full px-6 py-3">
            {pill}
          </span>
        ))}
      </div>

    </div>
  </div>
</section>

<script is:inline>
  (function() {
    var video = document.getElementById('teams-nutrition-video');
    var playPauseBtn = document.getElementById('teams-nutrition-play-pause');
    var pauseIcon = document.getElementById('teams-nutrition-pause-icon');
    var playIcon = document.getElementById('teams-nutrition-play-icon');
    var restartBtn = document.getElementById('teams-nutrition-restart');
    var muteBtn = document.getElementById('teams-nutrition-mute');
    var mutedIcon = document.getElementById('teams-nutrition-muted-icon');
    var unmutedIcon = document.getElementById('teams-nutrition-unmuted-icon');

    playPauseBtn?.addEventListener('click', function() {
      if (video.paused) {
        video.play();
        pauseIcon?.classList.remove('hidden');
        playIcon?.classList.add('hidden');
        playPauseBtn.setAttribute('aria-label', 'Pause video');
      } else {
        video.pause();
        pauseIcon?.classList.add('hidden');
        playIcon?.classList.remove('hidden');
        playPauseBtn.setAttribute('aria-label', 'Play video');
      }
    });

    restartBtn?.addEventListener('click', function() {
      video.currentTime = 0;
      video.play();
      pauseIcon?.classList.remove('hidden');
      playIcon?.classList.add('hidden');
      playPauseBtn?.setAttribute('aria-label', 'Pause video');
    });

    muteBtn?.addEventListener('click', function() {
      video.muted = !video.muted;
      if (video.muted) {
        mutedIcon?.classList.remove('hidden');
        unmutedIcon?.classList.add('hidden');
        muteBtn.setAttribute('aria-label', 'Unmute video');
      } else {
        mutedIcon?.classList.add('hidden');
        unmutedIcon?.classList.remove('hidden');
        muteBtn.setAttribute('aria-label', 'Mute video');
      }
    });
  })();
</script>
