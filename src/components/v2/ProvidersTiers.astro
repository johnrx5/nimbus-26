---
---

<section class="bg-[#1A1816] py-24 px-[10px]">
  <div class="max-w-[1200px] mx-auto">
    <!-- Header -->
    <div class="text-center mb-6" data-animate>
      <p class="font-montserrat text-teal text-sm font-semibold tracking-[0.15em] uppercase mb-4">Get Started</p>
      <h2 class="font-fraunces text-cream text-[clamp(32px,4vw,56px)] leading-[1.08] tracking-[-0.02em]">
        Start free. Scale when you're ready.
      </h2>
    </div>

    <div class="text-center max-w-[600px] mx-auto mb-16" data-animate data-delay="1">
      <p class="font-inter text-cream/50 text-base leading-[1.6]">
        No contracts. No platform fees. Explore NovaMed at your own pace, then unlock the full platform when your clinic is ready.
      </p>
    </div>

    <!-- Three Tiers -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6" data-stagger>
      <!-- Explore (Free) -->
      <div class="bg-[#22201E] rounded-2xl border border-cream/5 p-8 flex flex-col">
        <div class="mb-6">
          <p class="font-montserrat text-cream/40 text-xs font-semibold tracking-widest uppercase mb-2">Explore</p>
          <div class="flex items-baseline gap-2">
            <span class="font-fraunces text-cream text-4xl">Free</span>
          </div>
          <p class="font-inter text-cream/30 text-sm mt-2">See the platform. No commitment.</p>
        </div>

        <div class="border-t border-cream/5 pt-6 mb-8 flex-1">
          <ul class="space-y-3">
            <li class="flex items-start gap-3">
              <span class="text-teal text-sm mt-0.5">✓</span>
              <span class="font-inter text-cream/50 text-sm">Dashboard access with sample data</span>
            </li>
            <li class="flex items-start gap-3">
              <span class="text-teal text-sm mt-0.5">✓</span>
              <span class="font-inter text-cream/50 text-sm">Browse protocol templates</span>
            </li>
            <li class="flex items-start gap-3">
              <span class="text-teal text-sm mt-0.5">✓</span>
              <span class="font-inter text-cream/50 text-sm">View formulary & pricing</span>
            </li>
            <li class="flex items-start gap-3">
              <span class="text-teal text-sm mt-0.5">✓</span>
              <span class="font-inter text-cream/50 text-sm">Educational resources</span>
            </li>
            <li class="flex items-start gap-3">
              <span class="text-cream/20 text-sm mt-0.5">—</span>
              <span class="font-inter text-cream/25 text-sm">Live prescribing & fulfillment</span>
            </li>
            <li class="flex items-start gap-3">
              <span class="text-cream/20 text-sm mt-0.5">—</span>
              <span class="font-inter text-cream/25 text-sm">Patient portal</span>
            </li>
          </ul>
        </div>

        <a href="/providers-trial" class="block text-center border border-cream/20 hover:border-cream/40 text-cream/70 hover:text-cream font-montserrat font-medium text-sm rounded-full px-8 py-3.5 transition-colors">
          Get Started Free
        </a>
      </div>

      <!-- Launch (Recommended) -->
      <div class="bg-[#22201E] rounded-2xl border-2 border-teal/30 p-8 flex flex-col relative">
        <div class="absolute -top-3 left-1/2 -translate-x-1/2">
          <span class="bg-teal text-[#1A1816] font-montserrat text-xs font-bold tracking-wider uppercase px-4 py-1 rounded-full">Most Popular</span>
        </div>

        <div class="mb-6">
          <p class="font-montserrat text-teal text-xs font-semibold tracking-widest uppercase mb-2">Launch</p>
          <div class="flex items-baseline gap-2">
            <span class="font-fraunces text-cream text-4xl">Per-Patient</span>
          </div>
          <p class="font-inter text-cream/30 text-sm mt-2">Full platform. Pay as you grow.</p>
        </div>

        <div class="border-t border-cream/5 pt-6 mb-8 flex-1">
          <ul class="space-y-3">
            <li class="flex items-start gap-3">
              <span class="text-teal text-sm mt-0.5">✓</span>
              <span class="font-inter text-cream/50 text-sm">Everything in Explore</span>
            </li>
            <li class="flex items-start gap-3">
              <span class="text-teal text-sm mt-0.5">✓</span>
              <span class="font-inter text-cream/50 text-sm">Live prescribing & pharmacy fulfillment</span>
            </li>
            <li class="flex items-start gap-3">
              <span class="text-teal text-sm mt-0.5">✓</span>
              <span class="font-inter text-cream/50 text-sm">Patient portal & messaging</span>
            </li>
            <li class="flex items-start gap-3">
              <span class="text-teal text-sm mt-0.5">✓</span>
              <span class="font-inter text-cream/50 text-sm">Automated refill management</span>
            </li>
            <li class="flex items-start gap-3">
              <span class="text-teal text-sm mt-0.5">✓</span>
              <span class="font-inter text-cream/50 text-sm">Analytics dashboard</span>
            </li>
            <li class="flex items-start gap-3">
              <span class="text-teal text-sm mt-0.5">✓</span>
              <span class="font-inter text-cream/50 text-sm">Compliance & audit trails</span>
            </li>
          </ul>
        </div>

        <a href="/contact" class="block text-center bg-teal hover:bg-teal/80 text-[#1A1816] font-montserrat font-semibold text-sm rounded-full px-8 py-3.5 transition-colors">
          Schedule a Demo
        </a>
      </div>

      <!-- Scale (Enterprise) -->
      <div class="bg-[#22201E] rounded-2xl border border-cream/5 p-8 flex flex-col">
        <div class="mb-6">
          <p class="font-montserrat text-cream/40 text-xs font-semibold tracking-widest uppercase mb-2">Scale</p>
          <div class="flex items-baseline gap-2">
            <span class="font-fraunces text-cream text-4xl">Enterprise</span>
          </div>
          <p class="font-inter text-cream/30 text-sm mt-2">Multi-location. Custom terms.</p>
        </div>

        <div class="border-t border-cream/5 pt-6 mb-8 flex-1">
          <ul class="space-y-3">
            <li class="flex items-start gap-3">
              <span class="text-teal text-sm mt-0.5">✓</span>
              <span class="font-inter text-cream/50 text-sm">Everything in Launch</span>
            </li>
            <li class="flex items-start gap-3">
              <span class="text-teal text-sm mt-0.5">✓</span>
              <span class="font-inter text-cream/50 text-sm">Multi-location management</span>
            </li>
            <li class="flex items-start gap-3">
              <span class="text-teal text-sm mt-0.5">✓</span>
              <span class="font-inter text-cream/50 text-sm">Volume-based tiered pricing</span>
            </li>
            <li class="flex items-start gap-3">
              <span class="text-teal text-sm mt-0.5">✓</span>
              <span class="font-inter text-cream/50 text-sm">Network-wide analytics</span>
            </li>
            <li class="flex items-start gap-3">
              <span class="text-teal text-sm mt-0.5">✓</span>
              <span class="font-inter text-cream/50 text-sm">Dedicated account manager</span>
            </li>
            <li class="flex items-start gap-3">
              <span class="text-teal text-sm mt-0.5">✓</span>
              <span class="font-inter text-cream/50 text-sm">Custom integrations & white-label</span>
            </li>
          </ul>
        </div>

        <a href="/contact" class="block text-center border border-cream/20 hover:border-cream/40 text-cream/70 hover:text-cream font-montserrat font-medium text-sm rounded-full px-8 py-3.5 transition-colors">
          Contact Sales
        </a>
      </div>
    </div>
  </div>
</section>
