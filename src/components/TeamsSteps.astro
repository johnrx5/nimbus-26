---
import img1 from '../assets/[7] Photography/iStock-2187968525.jpg';
import img2 from '../assets/[7] Photography/iStock-1276569663.jpg';
import img3 from '../assets/[7] Photography/iStock-2189538504.jpg';
import img4 from '../assets/[7] Photography/iStock-1165116258.jpg';

const cards = [
  {
    number: '01',
    image: img1.src,
    title: 'Employer Defines Eligibility',
    description: 'Your team defines a cohort of eligible employees. Nimbus handles census ingestion and secure, cohort-based access verification.',
  },
  {
    number: '02',
    image: img2.src,
    title: 'Employees Enroll',
    description: 'Employees access a dedicated, employer-branded landing page and enroll in a 12-month program at no cost to them.',
  },
  {
    number: '03',
    image: img3.src,
    title: 'Clinical Care Begins',
    description: 'Licensed clinicians prescribe, manage dosing, monitor tolerance, and adjust treatment — all within a single integrated platform.',
  },
  {
    number: '04',
    image: img4.src,
    title: 'Nutrition Support Activates',
    description: 'Employees can opt into clinician-guided meals designed around their GLP-1 therapy — delivered to home or workplace.',
  },
];
---

<section class="bg-cream py-24 overflow-hidden" data-animate>
  <!-- Header -->
  <div id="teams-steps-header" class="max-w-[1200px] mx-auto px-[10px] mb-16">
    <p class="font-inter text-dark/50 text-base mb-3">How it works</p>
    <h2 class="font-fraunces text-dark text-[clamp(40px,5vw,72px)] leading-[1.05] tracking-[-0.02em]">
      Simple. Seamless.
    </h2>
  </div>

  <!-- Carousel -->
  <div class="relative overflow-hidden">
    <div id="teams-steps-track" class="flex gap-6 transition-transform duration-500 ease-in-out">
      {cards.map((card) => (
        <div class="shrink-0 w-[500px]">
          <div class="relative rounded-2xl h-[500px] overflow-hidden mb-5">
            <img src={card.image} alt="" class="w-full h-full object-cover" />
            <div class="absolute inset-0 bg-dark/10"></div>
            <span class="absolute bottom-6 left-6 font-fraunces text-white text-[100px] leading-none tracking-[-0.04em]">
              {card.number}
            </span>
          </div>
          <h3 class="font-inter text-dark text-lg font-bold mb-2 px-1">{card.title}</h3>
          <p class="font-inter text-dark/50 text-sm leading-[1.6] px-1">{card.description}</p>
        </div>
      ))}
    </div>
  </div>

  <!-- Controls -->
  <div class="flex items-center justify-center gap-6 mt-8">
    <button
      id="teams-steps-prev"
      class="flex items-center justify-center text-dark/40 hover:text-dark transition-colors cursor-pointer"
      aria-label="Previous slide"
    >
      <svg width="18" height="18" viewBox="0 0 18 18" fill="none">
        <path d="M11 4L6 9l5 5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
    </button>

    <!-- Progress bar -->
    <div class="w-20 h-[2px] bg-dark/20 rounded-full overflow-hidden">
      <div id="teams-steps-progress" class="h-full bg-teal rounded-full" style="width: 0%"></div>
    </div>

    <button
      id="teams-steps-next"
      class="flex items-center justify-center text-dark/40 hover:text-dark transition-colors cursor-pointer"
      aria-label="Next slide"
    >
      <svg width="18" height="18" viewBox="0 0 18 18" fill="none">
        <path d="M7 4l5 5-5 5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
    </button>
  </div>
</section>

<script is:inline>
  (function() {
    var track = document.getElementById('teams-steps-track');
    var header = document.getElementById('teams-steps-header');
    var prevBtn = document.getElementById('teams-steps-prev');
    var nextBtn = document.getElementById('teams-steps-next');
    var progress = document.getElementById('teams-steps-progress');
    var current = 0;
    var total = 4;
    var cardWidth = 500;
    var gap = 24;
    var DURATION = 4;

    function getLeftStart() {
      if (header) {
        var rect = header.getBoundingClientRect();
        var padding = parseFloat(getComputedStyle(header).paddingLeft);
        return rect.left + padding;
      }
      return 10;
    }

    function getOffset(index) {
      return -(index * (cardWidth + gap)) + getLeftStart();
    }

    function startProgress() {
      if (!progress) return;
      progress.style.transition = 'none';
      progress.style.width = '0%';
      progress.getBoundingClientRect();
      progress.style.transition = 'width ' + DURATION + 's linear';
      progress.style.width = '100%';
    }

    function goTo(index) {
      if (index < 0) index = total - 1;
      if (index > total - 1) index = 0;
      current = index;
      track.style.transform = 'translateX(' + getOffset(current) + 'px)';
      startProgress();
    }

    // Auto-advance when progress bar finishes
    progress.addEventListener('transitionend', function(e) {
      if (e.propertyName === 'width' && progress.style.width === '100%') {
        goTo(current + 1);
      }
    });

    // Set initial carousel position (no transition)
    track.style.transition = 'none';
    track.style.transform = 'translateX(' + getLeftStart() + 'px)';
    requestAnimationFrame(function() {
      requestAnimationFrame(function() {
        track.style.transition = '';
      });
    });

    // Only start autoplay once the section scrolls into view
    var section = track.closest('section');
    var hasStarted = false;
    var observer = new IntersectionObserver(function(entries) {
      entries.forEach(function(entry) {
        if (entry.isIntersecting && !hasStarted) {
          hasStarted = true;
          startProgress();
          observer.disconnect();
        }
      });
    }, { threshold: 0.4 });
    if (section) observer.observe(section);

    prevBtn?.addEventListener('click', function() { goTo(current - 1); });
    nextBtn?.addEventListener('click', function() { goTo(current + 1); });

    window.addEventListener('resize', function() {
      track.style.transition = 'none';
      track.style.transform = 'translateX(' + getOffset(current) + 'px)';
      requestAnimationFrame(function() {
        requestAnimationFrame(function() {
          track.style.transition = '';
        });
      });
    });
  })();
</script>
