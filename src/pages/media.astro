---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';

const featuredEpisode = {
  id: '5oC3U26qPhs',
  title: 'The Honest Dose — Episode 1',
  date: 'Mar 2026',
};

const shorts = [
  { id: 'ChQzSXf-ND4', title: 'Can AI replace your pharmacist?' },
  { id: 'aEns-7pt6tk', title: 'FIBER! #glp1 #healthyliving' },
  { id: 'rrNw8O4QvCc', title: "You don't have to tough it out through perimenopause" },
  { id: 'Dc4aGV8gGhg', title: 'This moment hit different' },
  { id: 'Ww1utz_VpFs', title: 'Level Up — Hormone Optimization' },
  { id: 'loHufThBhvs', title: 'Nobody cares about...' },
];

const episodes = [
  { id: 'YUWmSHNNUdc', title: 'GLP-1 Medications: How They Manage Blood Sugar & Aid Weight Loss', date: 'Apr 2024' },
  { id: 'VJ3JFMi5Sz8', title: 'Nimbus Mary Testimonial', date: 'Mar 2024' },
  { id: 'sPeLhyyWmoo', title: 'How To Use GLP-1 Medication', date: 'Feb 2024' },
  { id: 'tXyYoPsV7YM', title: 'Hair Restoration: How To Apply Prescription Solution', date: 'Jan 2024' },
  { id: 'zw-0wR0eEKg', title: 'Jobby — Alopecia Journey', date: 'Jan 2024' },
  { id: 'XHXucruRNLI', title: "Women's Hormone Optimization: How To Collect Your Sample", date: 'Dec 2023' },
];
---

<Layout title="The Honest Dose — Nimbus Healthcare Podcast">
  <Navbar />
  <main class="bg-[#1A1816]">

    <!-- Hero -->
    <section class="pt-44 pb-20 px-[10px]">
      <div class="max-w-7xl mx-auto flex flex-col lg:flex-row items-center gap-12 lg:gap-20">

        <!-- Podcast Artwork + Info -->
        <div class="flex-shrink-0 w-full lg:w-auto flex flex-col items-center lg:items-start">
          <img
            src="/images/Podcast/THD-Artwork 1x1.jpg"
            alt="The Honest Dose Podcast"
            class="w-[280px] h-[280px] rounded-2xl shadow-2xl object-cover"
          />
          <h1 class="font-fraunces text-cream text-[clamp(36px,5vw,52px)] leading-[1.05] font-light mt-8 text-center lg:text-left">
            The Honest Dose
          </h1>
          <p class="font-inter text-cream/40 text-sm mt-2 text-center lg:text-left">with Dr. Jobby John</p>
          <p class="font-inter text-cream/40 text-sm mt-4 max-w-[320px] leading-relaxed text-center lg:text-left">Real talk about health, weight loss, hormones, and compounded medications — straight from the pharmacist.</p>

          <!-- Listen On Buttons -->
          <div class="flex flex-wrap items-center gap-3 mt-6">
            <a href="https://www.youtube.com/@NimbusHealthcare" target="_blank" rel="noopener noreferrer" class="listen-btn">
              <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.546 12 3.546 12 3.546s-7.505 0-9.377.504A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.504 9.376.504 9.376.504s7.505 0 9.377-.504a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814z"/><path fill="#22201E" d="M9.545 15.568V8.432L15.818 12l-6.273 3.568z"/></svg>
              YouTube
            </a>
            <a href="#" class="listen-btn">
              <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M18.71 19.5c-.83 1.24-1.71 2.45-3.05 2.47-1.34.03-1.77-.79-3.29-.79-1.53 0-2 .77-3.27.82-1.31.05-2.3-1.32-3.14-2.53C4.25 17 2.94 12.45 4.7 9.39c.87-1.52 2.43-2.48 4.12-2.51 1.28-.02 2.5.87 3.29.87.78 0 2.26-1.07 3.8-.91.65.03 2.47.26 3.64 1.98-.09.06-2.17 1.28-2.15 3.81.03 3.02 2.65 4.03 2.68 4.04-.03.07-.42 1.44-1.38 2.83M13 3.5c.73-.83 1.94-1.46 2.94-1.5.13 1.17-.34 2.35-1.04 3.19-.69.85-1.83 1.51-2.95 1.42-.15-1.15.41-2.35 1.05-3.11z"/></svg>
              Apple Podcasts
            </a>
            <a href="#" class="listen-btn">
              <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0C5.4 0 0 5.4 0 12s5.4 12 12 12 12-5.4 12-12S18.66 0 12 0zm5.521 17.34c-.24.359-.66.48-1.021.24-2.82-1.74-6.36-2.101-10.561-1.141-.418.122-.779-.179-.899-.539-.12-.421.18-.78.54-.9 4.56-1.021 8.52-.6 11.64 1.32.42.18.479.659.301 1.02zm1.44-3.3c-.301.42-.841.6-1.262.3-3.239-1.98-8.159-2.58-11.939-1.38-.479.12-1.02-.12-1.14-.6-.12-.48.12-1.021.6-1.141C9.6 9.9 15 10.561 18.72 12.84c.361.181.54.78.241 1.2zm.12-3.36C15.24 8.4 8.82 8.16 5.16 9.301c-.6.179-1.2-.181-1.38-.721-.18-.601.18-1.2.72-1.381 4.26-1.26 11.28-1.02 15.721 1.621.539.3.719 1.02.419 1.56-.299.421-1.02.599-1.559.3z"/></svg>
              Spotify
            </a>
          </div>
        </div>

        <!-- Featured Episode -->
        <div class="flex-1 w-full">
          <p class="font-inter text-teal text-xs font-bold tracking-[0.15em] uppercase mb-4">Latest Episode</p>
          <div class="relative aspect-video rounded-2xl overflow-hidden bg-[#22201E]">
            <iframe
              src={`https://www.youtube.com/embed/${featuredEpisode.id}`}
              title={featuredEpisode.title}
              class="absolute inset-0 w-full h-full"
              frameborder="0"
              allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
              allowfullscreen
            ></iframe>
          </div>
          <div class="mt-4">
            <p class="font-inter text-teal text-xs font-semibold tracking-wide">{featuredEpisode.date}</p>
            <h2 class="font-inter text-cream text-lg font-semibold mt-1">{featuredEpisode.title}</h2>
          </div>
        </div>
      </div>
    </section>

    <!-- Clips & Shorts -->
    <section class="py-20 px-[10px]">
      <div class="max-w-7xl mx-auto">
        <h2 class="font-fraunces text-cream text-[clamp(36px,5vw,56px)] leading-[1] font-light mb-10">Clips</h2>
        <div class="flex gap-4 overflow-x-auto pb-4 -mx-[10px] px-[10px] scrollbar-hide">
          {shorts.map((short) => (
            <a
              href={`https://www.youtube.com/shorts/${short.id}`}
              target="_blank"
              rel="noopener noreferrer"
              class="flex-shrink-0 w-[200px] group"
            >
              <div class="relative aspect-[9/16] rounded-2xl overflow-hidden bg-[#22201E] border border-cream/10">
                <img
                  src={`https://img.youtube.com/vi/${short.id}/maxresdefault.jpg`}
                  alt={short.title}
                  class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300"
                  loading="lazy"
                />
                <div class="absolute inset-0 bg-gradient-to-t from-dark/80 via-transparent to-transparent"></div>
                <div class="absolute inset-0 flex items-center justify-center opacity-0 group-hover:opacity-100 transition-opacity">
                  <div class="w-12 h-12 rounded-full bg-cream/20 backdrop-blur-sm flex items-center justify-center">
                    <svg class="w-5 h-5 text-cream ml-0.5" fill="currentColor" viewBox="0 0 24 24"><path d="M8 5v14l11-7z"/></svg>
                  </div>
                </div>
                <p class="absolute bottom-3 left-3 right-3 font-inter text-cream text-xs font-medium leading-tight">{short.title}</p>
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>

    <!-- More Episodes -->
    <section class="py-20 px-[10px]">
      <div class="max-w-7xl mx-auto">
        <h2 class="font-fraunces text-cream text-[clamp(36px,5vw,56px)] leading-[1] font-light mb-10">More Episodes</h2>
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
          {episodes.map((ep) => (
            <a
              href={`https://www.youtube.com/watch?v=${ep.id}`}
              target="_blank"
              rel="noopener noreferrer"
              class="group"
            >
              <div class="relative aspect-video rounded-2xl overflow-hidden bg-[#22201E] border border-cream/10">
                <img
                  src={`https://img.youtube.com/vi/${ep.id}/maxresdefault.jpg`}
                  alt={ep.title}
                  class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300"
                  loading="lazy"
                />
                <div class="absolute inset-0 flex items-center justify-center">
                  <div class="w-14 h-14 rounded-full bg-dark/60 backdrop-blur-sm flex items-center justify-center group-hover:bg-teal/80 transition-colors">
                    <svg class="w-6 h-6 text-cream ml-0.5" fill="currentColor" viewBox="0 0 24 24"><path d="M8 5v14l11-7z"/></svg>
                  </div>
                </div>
              </div>
              <div class="mt-3">
                <p class="font-inter text-teal text-xs font-semibold tracking-wide">{ep.date}</p>
                <h3 class="font-inter text-cream text-sm font-semibold mt-1 leading-snug group-hover:text-cream/80 transition-colors">{ep.title}</h3>
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>

  </main>

  <!-- Footer -->
  <div class="bg-[#1A1816] pb-[10px] px-[10px]">
    <Footer />
  </div>
</Layout>

<style>
  .scrollbar-hide::-webkit-scrollbar {
    display: none;
  }
  .scrollbar-hide {
    -ms-overflow-style: none;
    scrollbar-width: none;
  }

  .listen-btn {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 10px 18px;
    border-radius: 9999px;
    border: 1px solid rgba(245, 240, 234, 0.15);
    background: rgba(245, 240, 234, 0.06);
    color: #F5F0EA;
    font-family: 'Inter', sans-serif;
    font-size: 13px;
    font-weight: 600;
    transition: all 0.2s ease;
  }
  .listen-btn:hover {
    background: rgba(245, 240, 234, 0.12);
    border-color: rgba(245, 240, 234, 0.3);
  }
</style>
